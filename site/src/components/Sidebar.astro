---
import { rulesNav } from '../data/rules-nav';

const base = import.meta.env.BASE_URL;

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const sections = rulesNav.map(section => ({
  title: section.title,
  links: section.links.map(link => ({
    label: link.label,
    href: `${base}rules/${link.slug}/`,
  })),
}));
---

<!-- Mobile sidebar toggle (visible < 960px) -->
<button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M3 12h18M3 6h18M3 18h18"/>
  </svg>
  <span>Menu</span>
</button>

<!-- Backdrop for mobile overlay -->
<div class="sidebar-backdrop" id="sidebar-backdrop"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <span class="sidebar-title">Navigation</span>
    <button class="sidebar-close" id="sidebar-close" aria-label="Close sidebar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <nav class="sidebar-nav">
    {sections.map((section, sIdx) => {
      const hasActive = section.links.some(l => currentPath === l.href);
      return (
        <details class="sidebar-section" open={hasActive || sIdx < 2}>
          <summary class="sidebar-heading">{section.title}</summary>
          <div class="sidebar-links">
            {section.links.map(link => (
              <a
                href={link.href}
                class:list={['sidebar-link', { active: currentPath === link.href }]}
              >
                {link.label}
              </a>
            ))}
          </div>
        </details>
      );
    })}
  </nav>
</aside>

<style>
  .sidebar {
    width: var(--sidebar-width);
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--header-height) + var(--space-lg));
    max-height: calc(100vh - var(--header-height) - var(--space-2xl));
    overflow-y: auto;
    padding-right: var(--space-md);
  }

  .sidebar-header {
    display: none;
  }

  .sidebar-section {
    margin-bottom: var(--space-sm);
  }

  .sidebar-heading {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: var(--space-xs);
    padding: var(--space-xs) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
  }
  .sidebar-heading::-webkit-details-marker { display: none; }
  .sidebar-heading::after {
    content: '';
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid var(--text-muted);
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  details[open] > .sidebar-heading::after {
    transform: rotate(180deg);
  }

  .sidebar-links {
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .sidebar-link {
    display: block;
    font-size: 0.85rem;
    color: var(--text-muted);
    padding: 4px 0 4px var(--space-sm);
    border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    line-height: 1.5;
  }
  .sidebar-link:hover {
    color: var(--text-primary);
    border-left-color: var(--accent-dim);
  }
  .sidebar-link.active {
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  /* Mobile toggle button */
  .sidebar-toggle {
    display: none;
    position: fixed;
    bottom: var(--space-lg);
    left: var(--space-lg);
    z-index: 90;
    align-items: center;
    gap: var(--space-sm);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--space-sm) var(--space-md);
    color: var(--text-muted);
    font-family: var(--font-heading);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: all 0.2s;
  }
  .sidebar-toggle:hover {
    color: var(--accent);
    border-color: var(--border-accent);
  }

  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 149;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
  }
  .sidebar-backdrop.visible { display: block; }

  .sidebar-close {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: var(--space-xs);
    border-radius: 4px;
    transition: color 0.2s;
  }
  .sidebar-close:hover { color: var(--accent); }

  @media (max-width: 960px) {
    .sidebar-toggle { display: flex; }

    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 18rem;
      max-height: 100vh;
      z-index: 150;
      background: var(--bg-secondary);
      border-right: 1px solid var(--border);
      padding: 0 var(--space-lg) var(--space-lg);
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      box-shadow: var(--shadow-lg);
    }
    .sidebar.open {
      transform: translateX(0);
    }

    .sidebar-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-md) 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: var(--space-md);
    }

    .sidebar-title {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-primary);
    }
  }
</style>

<script>
  const sidebar = document.getElementById('sidebar');
  const toggle = document.getElementById('sidebar-toggle');
  const close = document.getElementById('sidebar-close');
  const backdrop = document.getElementById('sidebar-backdrop');

  function openSidebar() {
    sidebar?.classList.add('open');
    backdrop?.classList.add('visible');
  }
  function closeSidebar() {
    sidebar?.classList.remove('open');
    backdrop?.classList.remove('visible');
  }

  toggle?.addEventListener('click', openSidebar);
  close?.addEventListener('click', closeSidebar);
  backdrop?.addEventListener('click', closeSidebar);
</script>
