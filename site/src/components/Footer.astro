---
const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo"><img src="/images/ashfall-logo.png" alt="" width="20" height="20" style="vertical-align: middle; margin-right: 0.4rem;" />Ashfall RPG</span>
        <p>The world burned. Humanity endures.</p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>Play</h4>
          <a href={`${base}getting-started/`}>Player's Guide</a>
          <a href={`${base}rules/`}>Rules</a>
          <a href={`${base}rules/classes/`}>Classes</a>
          <a href={`${base}character-builder/`}>Character Builder</a>
        </div>
        <div class="footer-col">
          <h4>Run</h4>
          <a href={`${base}dm-guide/`}>Game Master's Guide</a>
          <a href={`${base}rules/bestiary/fauna-flora/`}>Bestiary</a>
          <a href={`${base}rules/generators/`}>Random Generators</a>
          <a href={`${base}rules/setting/`}>Setting & Lore</a>
        </div>
        <div class="footer-col">
          <h4>Connect</h4>
          <a href={`${base}community/`}>Community</a>
          <a href="https://discord.gg/pTUYgRsXRc" target="_blank" rel="noopener noreferrer">Discord</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 ByteSnap. <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" class="license-link" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0</a></span>
      <span class="memorial">In loving memory of Daryl Sackett — forever in the party</span>
      <span class="version">v0.5</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    margin-top: var(--space-3xl);
    padding: var(--space-2xl) 0 var(--space-lg);
    transition: var(--theme-transition);
  }

  .footer-inner {
    max-width: 76rem;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2xl);
    margin-bottom: var(--space-xl);
  }

  .footer-brand {
    flex-shrink: 0;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .footer-brand p {
    margin-top: var(--space-xs);
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .footer-links {
    display: flex;
    gap: var(--space-2xl);
  }

  .footer-col h4 {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .footer-col a {
    display: block;
    color: var(--text-secondary);
    font-size: 0.85rem;
    padding: 2px 0;
    transition: color 0.15s;
  }
  .footer-col a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .license-link {
    color: var(--text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .license-link:hover {
    color: var(--accent);
  }

  .memorial {
    font-style: italic;
    opacity: 0.5;
    transition: opacity 0.3s ease;
    cursor: default;
  }
  .memorial:hover {
    opacity: 1;
    color: var(--accent);
  }

  .version {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: var(--space-lg);
    }
    .footer-links {
      flex-wrap: wrap;
      gap: var(--space-lg);
    }
    .footer-bottom {
      flex-direction: column;
      gap: var(--space-xs);
      text-align: center;
    }
  }
</style>
