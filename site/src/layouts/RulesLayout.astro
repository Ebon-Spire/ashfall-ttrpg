---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description}>
  <div class="rules-wrapper">
    <Sidebar currentPath={currentPath} />
    <main class="rules-content">
      <details class="toc-mobile" id="toc-mobile">
        <summary class="toc-mobile-header">On This Page</summary>
        <ul class="toc-mobile-list" id="toc-mobile-list"></ul>
      </details>
      <article class="prose">
        <slot />
      </article>
    </main>
    <TableOfContents />
  </div>

</BaseLayout>

<style>
  .rules-wrapper {
    max-width: 82rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg);
    display: flex;
    gap: var(--space-xl);
  }

  .rules-content {
    flex: 1;
    min-width: 0;
  }

  .prose {
    max-width: var(--content-width);
  }

  /* Markdown content typography refinements */
  .prose :global(h1) {
    font-size: 2.1rem;
    border-bottom: 2px solid var(--accent-dim);
    padding-bottom: var(--space-sm);
  }

  .prose :global(h2) {
    color: var(--accent);
    font-size: 1.5rem;
    padding-top: var(--space-sm);
  }

  .prose :global(h3) {
    color: var(--accent-hover);
  }

  .prose :global(table) {
    font-size: 0.88rem;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
  }

  /* ---- Mobile TOC (visible only when sidebar TOC is hidden) ---- */
  .toc-mobile {
    display: none;
    margin-bottom: var(--space-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .toc-mobile-header {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    list-style: none;
  }
  .toc-mobile-header::after {
    content: '+';
    float: right;
    color: var(--text-muted);
  }
  .toc-mobile[open] .toc-mobile-header::after {
    content: '\2212';
  }
  .toc-mobile-list {
    list-style: none;
    padding: 0 var(--space-lg) var(--space-md);
    margin: 0;
  }
  .toc-mobile-list li a {
    display: block;
    font-size: 0.82rem;
    color: var(--text-muted);
    padding: var(--space-xs) 0;
    text-decoration: none;
    border-bottom: 1px solid var(--border);
  }
  .toc-mobile-list li:last-child a {
    border-bottom: none;
  }
  .toc-mobile-list li a:hover {
    color: var(--accent);
  }
  .toc-mobile-list li a.toc-h3 {
    padding-left: var(--space-lg);
    font-size: 0.78rem;
  }
  @media (max-width: 1200px) {
    .toc-mobile { display: block; }
  }

  @media (max-width: 960px) {
    .rules-wrapper {
      padding: var(--space-md);
    }
  }
</style>
