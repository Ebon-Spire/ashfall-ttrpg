---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import FeedbackModal from '../components/FeedbackModal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A Post-Apocalyptic Tabletop Roleplaying Game' } = Astro.props;
const fullTitle = title === 'Home' ? 'Ashfall RPG' : `${title} — Ashfall RPG`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://ashfallrpg.com/images/og-image.png" />
    <meta property="og:url" content={`https://ashfallrpg.com${Astro.url.pathname}`} />
    <meta property="og:site_name" content="Ashfall RPG" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://ashfallrpg.com/images/og-image.png" />

    <!-- Additional SEO -->
    <meta name="theme-color" content="#e8631b" />
    <link rel="canonical" href={`https://ashfallrpg.com${Astro.url.pathname}`} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Ashfall RPG",
      "url": "https://ashfallrpg.com",
      "description": "A post-apocalyptic tabletop roleplaying game with 8 archetypes, modular spell crafting, and gritty survival mechanics.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://ashfallrpg.com/rules/?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />

    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="64x64" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('ashfall-theme');
        const pref = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', saved || pref);
      })();
    </script>
  </head>
  <body>
    <Header />
    <div class="scroll-progress" id="scroll-progress"></div>
    <SearchModal />
    <FeedbackModal />
    <slot />
    <Footer />
    <script is:inline>
      window.addEventListener('scroll', function() {
        var el = document.getElementById('scroll-progress');
        if (!el) return;
        var h = document.documentElement.scrollHeight - window.innerHeight;
        if (h > 0) el.style.width = (window.scrollY / h * 100) + '%';
      }, { passive: true });
    </script>
  </body>
</html>
