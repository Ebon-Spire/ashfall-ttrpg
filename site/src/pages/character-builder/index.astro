  .feature-tag { font-family: var(--font-mono); font-size: 0.75rem; padding: 3px 8px; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 3px; color: var(--text-secondary); }
  .tree-block { margin: var(--space-md) 0; padding: var(--space-sm) var(--space-md); background: var(--bg-elevated); border-radius: 4px; border-left: 2px solid var(--accent-dim); }
  .tree-block h5 { font-size: 0.9rem; color: var(--text-primary); margin-bottom: var(--space-xs); }
  .tree-focus { color: var(--text-muted); font-size: 0.8rem; }
  .tree-block ul { padding-left: var(--space-md); margin: var(--space-xs) 0; }
