      var(--bg-primary);
  }

  .builder-container {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  /* ---- Progress breadcrumbs ---- */
  .progress-crumbs {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
    min-height: 1.4rem;
  }

  .progress-crumbs.hidden { display: none; }

  .crumb {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    padding: 2px 8px;
    background: rgba(232, 99, 27, 0.08);
    border: 1px solid var(--border-accent);
    border-radius: 3px;
  }

  .crumb-sep {
    color: var(--text-muted);
    font-size: 0.7rem;
  }

  /* ---- Step navigation ---- */
  .step-nav {
    display: flex;
