  /* ---- Equipment ---- */
  .equipment-layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  .equip-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: 6px; padding: var(--space-lg); }
