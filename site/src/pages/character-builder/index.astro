---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { loadGameData } from '../../lib/loadGameData';

const gameData = loadGameData();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Character Builder">
  <main class="builder-page">
    <div class="builder-container">

      <!-- Progress breadcrumb -->
      <div class="progress-crumbs" id="progress-crumbs"></div>

      <!-- Step indicators -->
      <nav class="step-nav" id="step-nav">
        <button class="step-tab active" data-step="0">Identity</button>
        <button class="step-tab" data-step="1">Chassis</button>
        <button class="step-tab" data-step="2">Build</button>
        <button class="step-tab" data-step="3">Equipment</button>
        <button class="step-tab" data-step="4">Summary</button>
      </nav>

      <!-- Step panels -->
      <div id="builder-app">

        <!-- Step 0: Identity (Species + Background) -->
        <section class="step-panel active" data-panel="0">
          <h2>Who Are You?</h2>

          <details class="config-section" open>
            <summary class="config-section-header">Species</summary>
            <p class="step-desc">Each species provides unique attribute bonuses and traits that shape your survivor.</p>
            <div class="card-grid" id="species-grid"></div>
            <div id="species-detail" class="detail-box hidden"></div>
          </details>

          <details class="config-section" id="background-section">
            <summary class="config-section-header">Background</summary>
            <p class="step-desc">Your background determines the skills and experiences you bring from before your adventures.</p>
            <div class="card-grid" id="background-grid"></div>
            <div id="background-detail" class="detail-box hidden"></div>
          </details>
        </section>

        <!-- Step 1: Chassis + optional Recommended Build -->
        <section class="step-panel" data-panel="1">
          <h2>Choose Your Chassis</h2>
          <p class="step-desc">Your chassis is your starting frame — HP, proficiencies, and saves. Build any character on top.</p>
          <div class="card-grid" id="chassis-grid"></div>
          <div id="chassis-detail" class="detail-box hidden"></div>

          <div id="archetype-section" style="display:none">
            <h3 class="section-heading">Recommended Build <span class="step-desc">(optional)</span></h3>
            <p class="step-desc">Choose a recommended build for suggested skill trees, or skip and spend CP freely in any tree.</p>
            <div class="card-grid" id="class-grid"></div>
            <div id="class-detail" class="detail-box hidden"></div>
          </div>

          <div class="level-selector" id="class-level-selector" style="display:none">
            <label for="level-slider">Character Level</label>
            <div class="level-slider-row">
              <input type="range" id="level-slider" min="1" max="20" value="1" />
              <span class="level-display" id="level-display">1</span>
            </div>
          </div>
        </section>

        <!-- Step 2: Build (Attributes + Proficiencies + Abilities + Progression) -->
        <section class="step-panel" data-panel="2">
          <h2>Build Your Character</h2>

          <!-- Collapsible: Attributes -->
          <details class="config-section" open>
            <summary class="config-section-header">Attributes</summary>
            <div class="method-selector">
              <button class="method-btn active" data-method="standard">Standard Array</button>
              <button class="method-btn" data-method="pointbuy">Point Buy</button>
              <button class="method-btn" data-method="manual">Manual</button>
            </div>
            <p class="step-desc" id="attr-desc">Drag values from the pool to assign them to attributes.</p>
            <div class="attr-layout">
              <div class="attr-pool" id="attr-pool"></div>
              <div class="attr-assignments" id="attr-assignments"></div>
            </div>
            <div class="derived-preview" id="derived-preview"></div>
          </details>

          <!-- Collapsible: Proficiencies -->
          <details class="config-section">
            <summary class="config-section-header">Skill Proficiencies</summary>
            <p class="step-desc">Your chassis and background grant fixed proficiencies. Choose <strong id="prof-pick-count">—</strong> additional skills.</p>
            <div id="prof-picks-remaining" class="cp-budget"></div>
            <div id="skills-list" class="skills-grid"></div>
          </details>

          <!-- Collapsible: Abilities -->
          <details class="config-section">
            <summary class="config-section-header">Character Points</summary>
            <p class="step-desc">Spend CP on skill tree abilities. Tier 2 requires Tier 1 in the same tree. Tier 3 unlocks at Level 5, Capstone at Level 10, Signature at Level 15.</p>
            <div id="cp-budget" class="cp-budget"></div>
            <div id="skill-trees-panel" class="skill-trees-panel"></div>
          </details>

          <!-- Collapsible: Progression -->
          <details class="config-section">
            <summary class="config-section-header">Level Progression</summary>
            <p class="step-desc">Milestone choices at each level. Every level grants 10 CP.</p>
            <div id="progression-timeline" class="progression-timeline"></div>
          </details>
        </section>

        <!-- Step 3: Equipment -->
        <section class="step-panel" data-panel="3">
          <h2>Starting Equipment</h2>
          <p class="step-desc">Your chassis provides a free starting package. Review your gear below.</p>
          <div id="equipment-panel" class="equipment-layout"></div>
        </section>

        <!-- Step 4: Summary -->
        <section class="step-panel" data-panel="4">
          <h2>Character Summary</h2>
          <div id="summary-sheet" class="summary-sheet"></div>
          <div class="summary-actions">
            <button class="btn-primary" id="export-text-btn">Copy as Text</button>
            <button class="btn-primary" id="export-pdf-btn">Download PDF</button>
          </div>
        </section>

      </div>

      <!-- Navigation buttons -->
      <div class="step-buttons">
        <button class="btn-secondary" id="prev-btn" disabled>Back</button>
        <button class="btn-primary" id="next-btn">Next</button>
      </div>

    </div>
  </main>
</BaseLayout>

<!-- Inject game data -->
<script type="application/json" id="game-data" set:html={JSON.stringify(gameData)} />

<script>
  // ========================================
  // Ashfall Character Builder — Client Logic
  // ========================================

  const GAME = JSON.parse(document.getElementById('game-data').textContent);
  const STEPS = 5;
  let currentStep = 0;

  // Chassis definitions (from rules/chassis.md)
  const CHASSIS_DATA = [
    {
      name: 'Heavy',
      role: 'Tank / Frontliner',
      hit_die: 'd12',
      hp_base: 14,
      hp_per_level: 7,
      armor_proficiency: ['Light', 'Medium', 'Heavy', 'Shields'],
      weapon_proficiency: ['Simple weapons', 'Martial melee weapons'],
      save_proficiencies: ['Fortitude', 'Will'],
      starting_skills: 2,
      quick_start: 'Tank, bruiser, or frontline fighter who wades into melee and refuses to go down.',
      equipment_packages: [
        { label: 'A — Frontliner', items: ['Heavy armor (Tier 1)', 'Martial melee weapon', 'Scrap shield', '2 rations', '50 cr'] },
        { label: 'B — Bruiser', items: ['Medium armor (Tier 1)', 'Two-handed martial melee weapon', 'Simple ranged weapon', '2 rations', '75 cr'] },
      ],
    },
    {
      name: 'Striker',
      role: 'Versatile Combatant',
      hit_die: 'd8',
      hp_base: 10,
      hp_per_level: 5,
      armor_proficiency: ['Light', 'Medium'],
      weapon_proficiency: ['Simple weapons', 'Martial weapons (all)'],
      save_proficiencies: ['Reflex', 'Fortitude'],
      starting_skills: 3,
      quick_start: 'Gunfighter, duelist, or any combat-focused character who values weapon versatility.',
      equipment_packages: [
        { label: 'A — Sharpshooter', items: ['Light armor (Tier 1)', 'Martial ranged weapon', 'Simple melee weapon', '20 ammo', '2 rations', '50 cr'] },
        { label: 'B — Skirmisher', items: ['Medium armor (Tier 1)', 'Martial melee weapon', 'Sidearm', '10 ammo', '2 rations', '50 cr'] },
      ],
    },
    {
      name: 'Specialist',
      role: 'Skill Expert',
      hit_die: 'd8',
      hp_base: 10,
      hp_per_level: 5,
      armor_proficiency: ['Light'],
      weapon_proficiency: ['Simple weapons', 'Sidearms', 'Melee finesse weapons'],
      save_proficiencies: ['Reflex', 'Will'],
      starting_skills: 5,
      quick_start: 'Medic, hacker, spy, operative, or any skill-heavy character.',
      equipment_packages: [
        { label: 'A — Field Agent', items: ['Light armor (Tier 1)', 'Finesse melee weapon', 'Sidearm', '10 ammo', 'Toolkit (choose one)', '2 rations', '50 cr'] },
        { label: 'B — Medic\'s Kit', items: ['Light armor (Tier 1)', 'Simple weapon', 'Sidearm', '10 ammo', 'Medical kit', '2 rations', '75 cr'] },
        { label: 'C — Technician\'s Rig', items: ['Light armor (Tier 1)', 'Simple weapon', 'Hacking terminal', 'Toolkit (Technology)', '2 rations', '50 cr'] },
      ],
    },
    {
      name: 'Adept',
      role: 'Supernatural Channeler',
      hit_die: 'd6',
      hp_base: 8,
      hp_per_level: 4,
      armor_proficiency: ['Light'],
      weapon_proficiency: ['Simple weapons'],
      save_proficiencies: ['Will', 'Fortitude'],
      starting_skills: 3,
      special: 'Focused Channeling: +1 to spell attack rolls and spell save DCs',
      quick_start: 'Mage, psion, or any character whose primary power comes from supernatural ability.',
      equipment_packages: [
        { label: 'A — Arcanist', items: ['Light armor (Tier 1)', 'Simple weapon', 'Arcane focus', '2 rations', '100 cr'] },
        { label: 'B — Psion', items: ['Light armor (Tier 1)', 'Simple weapon', 'Psionic focus', '2 rations', '100 cr'] },
      ],
    },
    {
      name: 'Survivor',
      role: 'Wasteland Forged',
      hit_die: 'd10',
      hp_base: 12,
      hp_per_level: 6,
      armor_proficiency: ['Light', 'Medium'],
      weapon_proficiency: ['Simple weapons', 'Improvised weapons', 'Sidearms'],
      save_proficiencies: ['Fortitude', 'Reflex'],
      starting_skills: 4,
      quick_start: 'Scavenger, mutant, wasteland ranger, or any character forged by survival.',
      equipment_packages: [
        { label: 'A — Scavenger', items: ['Medium armor (Tier 1)', 'Improvised weapon', 'Sidearm', '10 ammo', 'Scavenging kit', '2 rations', '25 cr'] },
        { label: 'B — Wasteland Mutant', items: ['Light armor (Tier 1)', 'Simple melee weapon', '4 rations', 'Antitoxin (2 doses)', '50 cr'] },
      ],
    },
  ];

  /** Returns the frame (chassis if set, else class) used for HP, saves, and proficiencies. */
  function getFrame() {
    return char.chassis || char.class;
  }

  // Proficiency bonus by level
  function getProfBonus(level) {
    if (level <= 4) return 2;
    if (level <= 8) return 3;
    if (level <= 12) return 4;
    if (level <= 16) return 5;
    return 6;
  }

  // Character state
  const char = {
    species: null,
    speciesChoices: {},
    background: null,
    chassis: null,   // selected chassis object (from CHASSIS_DATA)
    class: null,
    method: 'standard',
    attributes: { MIG: 0, AGI: 0, END: 0, INT: 0, WIS: 0, PRE: 0 },
    assignedPool: [],
    pointBuyScores: { MIG: 8, AGI: 8, END: 8, INT: 8, WIS: 8, PRE: 8 },
    skills: [],
    chosenProficiencies: [], // player-chosen skill proficiency names
    expertiseSkills: [],     // skill names upgraded to Expert tier
    purchasedAbilities: [],  // [{treeName, abilityName, cp_cost, tier, effect}]
    featureChoices: {},      // {featureName: choiceName}
    selectedSpecialization: null, // specialization name string
    startingCredits: 70,     // 2d6 x 10 credits (default to average)
    selectedWeapons: [],     // weapon objects from equipment catalog
    selectedArmor: null,     // armor object
    selectedShield: null,    // shield object
    selectedAugments: [],    // augment objects from equipment catalog
    selectedCantrips: [],    // cantrip names for caster classes
    selectedDoctrine: null,  // {name, effect} from L1 doctrines
    name: '',
    // Progression (levels 2-20)
    level: 1,                    // current character level
    selectedDoctrine2: null,     // L6 doctrine {name, effect}
    selectedTalents: {},         // {level: {name, effect, enhances?, ...}}
    selectedASIs: {},            // {level: {attr1: name, attr2: name|null, mode: '+2'/'+1+1'}}
    selectedMasteryPath: null,   // mastery path object from GAME.mastery_paths

    progressionProfPicks: {},    // {level: skillName} for free proficiency picks at L3/8/15
    progressionExpertise: {},    // {level: skillName} for free expertise at L6/12 (legacy Operative)
    skillFocuses: {},            // {level: {skill: skillName, focus: focusName}} for L5/10/15 Skill Focus
    purchasedProfUpgrades: {},   // {upgradeName: true} for CP-purchased proficiency upgrades
    purchasedAttrBoosts: { MIG: 0, AGI: 0, END: 0, INT: 0, WIS: 0, PRE: 0 }, // CP-purchased +1s (10 CP each, cap score 20)
    cpSkillProficiency: [],  // skill names bought via CP (2 CP; 1 CP Specialist)
    cpSkillExpertise: [],    // skill names upgraded to expertise via CP (4 CP; 2 CP Specialist)
    cpAdvancedAccess: [],    // advanced skill names unlocked via CP (3 CP; 2 CP Specialist), max 2 (3 Specialist)
    cpCantripPurchases: [],  // cantrip names bought via CP (15/12/10 CP based on archetype)
    selectedEquipmentPackage: null, // index of chosen chassis equipment package
  };

  // ---- Utility ----
  function getMod(score) {
    return Math.floor((score - 10) / 2);
  }

  function modStr(m) {
    return m >= 0 ? '+' + m : '' + m;
  }

  function el(id) {
    return document.getElementById(id);
  }

  function $$(sel, parent) {
    return Array.from((parent || document).querySelectorAll(sel));
  }

  // ---- Step navigation ----
  const tabs = $$('.step-tab');
  const panels = $$('.step-panel');
  const prevBtn = el('prev-btn');
  const nextBtn = el('next-btn');

  function isStepValid(step) {
    if (step === 0) return !!char.species && !!char.background;
    if (step === 1) return !!char.chassis;
    return true;
  }

  function updateNextBtn() {
    var valid = isStepValid(currentStep);
    if (currentStep === STEPS - 1) {
      nextBtn.textContent = 'Done';
      nextBtn.disabled = false;
    } else {
      nextBtn.textContent = 'Next';
      nextBtn.disabled = !valid;
    }
  }

  function updateBreadcrumbs() {
    var crumbs = [];
    if (char.species) crumbs.push(char.species.name);
    if (char.background) crumbs.push(char.background.name);
    if (char.chassis) crumbs.push(char.chassis.name + (char.class ? ' / ' + char.class.name : '') + ' L' + char.level);
    var crumbEl = el('progress-crumbs');
    if (crumbs.length === 0) {
      crumbEl.classList.add('hidden');
    } else {
      crumbEl.classList.remove('hidden');
      crumbEl.innerHTML = crumbs.map(function(c) { return '<span class="crumb">' + c + '</span>'; }).join('<span class="crumb-sep">/</span>');
    }
  }

  function goToStep(step) {
    if (step < 0 || step >= STEPS) return;
    var oldStep = currentStep;
    currentStep = step;
    tabs.forEach(function(t, i) {
      t.classList.toggle('active', i === step);
      t.classList.toggle('completed', i < step);
    });

    // Animate panel transition
    panels.forEach(function(p, i) {
      if (i === step) {
        p.classList.add('active');
        p.style.animation = 'panelFadeIn 0.25s ease-out';
      } else {
        p.classList.remove('active');
        p.style.animation = '';
      }
    });

    prevBtn.disabled = step === 0;
    updateNextBtn();
    updateBreadcrumbs();

    // Scroll to top of builder
    el('step-nav').scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    // Render current step
    if (step === 1) renderClassStep();
    if (step === 2) renderBuild();
    if (step === 3) renderEquipment();
    if (step === 4) renderSummary();
  }

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = Number(tab.getAttribute('data-step'));
      // Validate all prior steps before allowing forward jumps
      if (target > currentStep) {
        for (var s = 0; s < target; s++) {
          if (!isStepValid(s)) return;
        }
      }
      goToStep(target);
    });
  });

  prevBtn.addEventListener('click', function() { goToStep(currentStep - 1); });
  nextBtn.addEventListener('click', function() {
    if (currentStep === STEPS - 1) {
      // Finish: scroll to export buttons
      var actions = document.querySelector('.summary-actions');
      if (actions) actions.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    if (isStepValid(currentStep)) goToStep(currentStep + 1);
  });

  // ---- Step 0: Species ----
  var SPECIES_IMAGES = {
    'Human': '/images/illustrations/species-human.png',
    'Altered Human': '/images/illustrations/species-altered-human.png',
    'Synthetic': '/images/illustrations/species-synthetic.png',
    'Xylar': '/images/illustrations/species-xylar.png',
    'Kromath': '/images/illustrations/species-kromath.png',
    'Neo-Bestial': '/images/illustrations/species-neo-bestial.png',
    'Alien Hybrid': '/images/illustrations/species-alien-hybrid.png',
  };

  function renderSpecies() {
    var grid = el('species-grid');
    grid.innerHTML = '';
    GAME.species.forEach(function(sp, i) {
      var card = document.createElement('button');
      card.className = 'select-card species-card';
      var img = SPECIES_IMAGES[sp.name];
      card.innerHTML = (img ? '<div class="species-card-img"><img src="' + img + '" alt="' + sp.name + '" loading="lazy" /></div>' : '') +
        '<h3>' + sp.name + '</h3><span class="card-sub">' + sp.attribute_bonus + '</span>';
      card.addEventListener('click', function() { selectSpecies(i); });
      grid.appendChild(card);
    });
  }

  function selectSpecies(idx) {
    char.species = GAME.species[idx];
    char.speciesChoices = {};
    $$('.select-card', el('species-grid')).forEach(function(c, i) {
      c.classList.toggle('selected', i === idx);
    });
    updateNextBtn();
    updateBreadcrumbs();
    var sp = char.species;
    var detail = el('species-detail');
    detail.classList.remove('hidden');
    // Smooth scroll to detail
    setTimeout(function() { detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 50);
    var spImg = SPECIES_IMAGES[sp.name];
    var html = '<div class="species-detail-header">' +
      (spImg ? '<div class="species-detail-portrait"><img src="' + spImg + '" alt="' + sp.name + '" /></div>' : '') +
      '<div class="species-detail-info"><h3>' + sp.name + '</h3><p class="detail-bonus">' + sp.attribute_bonus + '</p></div></div><ul>';
    sp.traits.forEach(function(t) {
      html += '<li><strong>' + t.name + ':</strong> ' + t.effect;
      if (t.choices && t.choices.length) {
        html += '<div class="choice-row" data-trait="' + t.name + '">';
        t.choices.forEach(function(c) {
          var label = typeof c === 'object' ? c.name : c;
          var val = typeof c === 'object' ? c.name : c;
          var tooltip = typeof c === 'object' && c.effect ? ' title="' + c.effect.replace(/"/g, '&quot;') + '"' : '';
          html += '<button class="choice-btn"' + tooltip + ' data-choice="' + val + '">' + label + '</button>';
        });
        html += '</div>';
      }
      html += '</li>';
    });
    html += '</ul>';
    detail.innerHTML = html;

    $$('.choice-btn', detail).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var trait = btn.parentElement.getAttribute('data-trait');
        char.speciesChoices[trait] = btn.getAttribute('data-choice');
        $$('.choice-btn', btn.parentElement).forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
      });
    });

    // Auto-open Background section and scroll to it
    var bgSection = el('background-section');
    if (bgSection) {
      bgSection.open = true;
      setTimeout(function() { bgSection.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 100);
    }
  }

  // ---- Background ----
  function renderBackgrounds() {
    var grid = el('background-grid');
    grid.innerHTML = '';
    GAME.backgrounds.forEach(function(bg, i) {
      var card = document.createElement('button');
      card.className = 'select-card';
      card.innerHTML = '<h3>' + bg.name + '</h3><span class="card-sub">' + bg.skill_bonus + '</span>';
      card.addEventListener('click', function() { selectBackground(i); });
      grid.appendChild(card);
    });
  }

  function selectBackground(idx) {
    char.background = GAME.backgrounds[idx];
    $$('.select-card', el('background-grid')).forEach(function(c, i) {
      c.classList.toggle('selected', i === idx);
    });
    updateNextBtn();
    updateBreadcrumbs();
    var bg = char.background;
    var detail = el('background-detail');
    detail.classList.remove('hidden');
    detail.innerHTML = '<h3>' + bg.name + '</h3>' +
      '<p class="detail-bonus">' + bg.skill_bonus + '</p>' +
      '<p class="detail-feature"><strong>Feature:</strong> ' + bg.feature + '</p>';
    setTimeout(function() { detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 50);
  }

  // ---- Step 2: Chassis selection ----
  var CHASSIS_IMAGES = {
    'Heavy': '/images/illustrations/chassis-heavy.png',
    'Striker': '/images/illustrations/chassis-striker.png',
    'Specialist': '/images/illustrations/chassis-specialist.png',
    'Adept': '/images/illustrations/chassis-adept.png',
    'Survivor': '/images/illustrations/chassis-survivor.png',
  };

  function renderChassis() {
    var grid = el('chassis-grid');
    grid.innerHTML = '';
    CHASSIS_DATA.forEach(function(ch, i) {
      var card = document.createElement('button');
      card.className = 'select-card chassis-card';
      var img = CHASSIS_IMAGES[ch.name];
      card.innerHTML = (img ? '<div class="chassis-card-img"><img src="' + img + '" alt="' + ch.name + '" loading="lazy" /></div>' : '') +
        '<h3>' + ch.name + '</h3>' +
        '<span class="card-sub">' + ch.role + '</span>' +
        '<span class="card-tag">' + ch.hit_die + '</span>';
      card.addEventListener('click', function() { selectChassis(i); });
      grid.appendChild(card);
    });
  }

  function selectChassis(idx) {
    char.chassis = CHASSIS_DATA[idx];
    char.selectedEquipmentPackage = null; // reset package when chassis changes
    char.purchasedProfUpgrades = {};
    char.purchasedAttrBoosts = { MIG: 0, AGI: 0, END: 0, INT: 0, WIS: 0, PRE: 0 };
    char.cpSkillProficiency = [];
    char.cpSkillExpertise = [];
    char.cpAdvancedAccess = [];
    char.cpCantripPurchases = [];
    char.skillFocuses = {};
    $$('.chassis-card', el('chassis-grid')).forEach(function(c, i) {
      c.classList.toggle('selected', i === idx);
    });
    // Show chassis detail
    var ch = char.chassis;
    var detail = el('chassis-detail');
    detail.classList.remove('hidden');
    var chImg = CHASSIS_IMAGES[ch.name];
    detail.innerHTML = '<div class="chassis-detail-header">' +
      (chImg ? '<div class="chassis-detail-emblem"><img src="' + chImg + '" alt="' + ch.name + '" /></div>' : '') +
      '<div class="chassis-detail-info">' +
      '<h3>' + ch.name + ' <span class="tag">' + ch.hit_die + '</span></h3>' +
      '<div class="class-stats">' +
      '<div class="stat-row"><span class="stat-label">Role</span><span>' + ch.role + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">HP at L1</span><span>' + ch.hp_base + ' + END mod</span></div>' +
      '<div class="stat-row"><span class="stat-label">HP/Level</span><span>' + ch.hp_per_level + ' + END mod</span></div>' +
      '<div class="stat-row"><span class="stat-label">Saves</span><span>' + ch.save_proficiencies.join(', ') + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Armor</span><span>' + ch.armor_proficiency.join(', ') + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Weapons</span><span>' + ch.weapon_proficiency.join(', ') + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Starting Skills</span><span>' + ch.starting_skills + '</span></div>' +
      (ch.special ? '<div class="stat-row chassis-special"><span class="stat-label">Special</span><span>' + ch.special + '</span></div>' : '') +
      '</div>' +
      '<p class="step-desc"><em>' + ch.quick_start + '</em></p>' +
      '</div></div>';
    // Show optional archetype section and level selector
    el('archetype-section').style.display = '';
    var lvlSelector = el('class-level-selector');
    if (lvlSelector) lvlSelector.style.display = '';
    updateNextBtn();
    updateBreadcrumbs();
  }

  // ---- Step 2: Archetype (optional recommended build) ----
  function renderClasses() {
    var grid = el('class-grid');
    grid.innerHTML = '';
    GAME.classes.forEach(function(cls, i) {
      var card = document.createElement('button');
      card.className = 'select-card';
      card.innerHTML = '<h3>' + cls.name + '</h3>' +
        '<span class="card-sub">' + cls.role + '</span>' +
        '<span class="card-tag">' + cls.hit_die + '</span>';
      card.addEventListener('click', function() { selectClass(i); });
      grid.appendChild(card);
    });
  }

  function selectClass(idx) {
    char.class = GAME.classes[idx];
    // Reset purchased abilities and feature choices when class changes
    char.purchasedAbilities = [];
    char.featureChoices = {};
    char.selectedSpecialization = null;
    char.selectedAugments = [];
    char.selectedCantrips = [];
    char.selectedDoctrine = null;
    char.selectedDoctrine2 = null;
    char.selectedTalents = {};
    char.selectedASIs = {};
    char.selectedMasteryPath = null;

    char.progressionProfPicks = {};
    char.progressionExpertise = {};
    char.purchasedAttrBoosts = { MIG: 0, AGI: 0, END: 0, INT: 0, WIS: 0, PRE: 0 };
    char.cpSkillProficiency = [];
    char.cpSkillExpertise = [];
    char.cpAdvancedAccess = [];
    char.cpCantripPurchases = [];
    char.skillFocuses = {};
    $$('.select-card', el('class-grid')).forEach(function(c, i) {
      c.classList.toggle('selected', i === idx);
    });
    updateNextBtn();
    updateBreadcrumbs();
    var cls = char.class;
    var detail = el('class-detail');
    detail.classList.remove('hidden');

    // Recommended trees for this archetype (SITE-048)
    var recTrees = ARCHETYPE_RECOMMENDED_TREES[cls.name] || [];
    var trees = (GAME.shared_skill_trees && GAME.shared_skill_trees.length > 0) ? GAME.shared_skill_trees : [];

    var html = '<h3>' + cls.name + '</h3>';
    html += '<p class="arch-guidance-note">This is a <strong>recommended build path</strong>, not a restriction. You can spend CP in any tree.</p>';
    html += '<div class="class-stats">' +
      '<div class="stat-row"><span class="stat-label">Role</span><span>' + cls.role + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Primary Stats</span><span>' + (cls.primary_stats || []).join(', ') + '</span></div>' +
      '</div>';

    // Recommended trees + suggested first purchases
    if (recTrees.length) {
      html += '<h4>Recommended Skill Trees</h4>';
      html += '<div class="rec-trees-list">';
      recTrees.forEach(function(treeName) {
        var treeData = trees.find(function(t) { return t.name === treeName; });
        if (!treeData) {
          html += '<div class="rec-tree"><strong>' + treeName + '</strong></div>';
          return;
        }
        var t1Abilities = (treeData.abilities || []).filter(function(a) { return a.tier === 1; }).slice(0, 3);
        html += '<div class="rec-tree">';
        html += '<div class="rec-tree-name"><strong>' + treeName + '</strong> <span class="tree-focus-sm">(' + treeData.focus + ')</span></div>';
        if (t1Abilities.length) {
          html += '<div class="rec-tree-purchases"><span class="rec-label">Start with:</span>';
          t1Abilities.forEach(function(a) {
            html += '<span class="rec-ability">' + a.name + ' (' + a.cp_cost + ' CP)</span>';
          });
          html += '</div>';
        }
        if (treeData.milestones) {
          html += '<div class="rec-tree-milestones">' +
            '<span class="ms-note">Initiate at ' + treeData.milestones.initiate.cp + ' CP: ' + treeData.milestones.initiate.bonus + '</span>' +
            '</div>';
        }
        html += '</div>';
      });
      html += '</div>';
    }

    // Archetype talents preview
    var classTalents = GAME.class_talents && GAME.class_talents[cls.name];
    if (classTalents && classTalents.length) {
      html += '<details class="ref-panel"><summary><h4>Build Talents <span class="feature-meta">Available at L2, 4, 7, 9, 12, 14</span></h4></summary>';
      html += '<div class="talent-list">';
      classTalents.forEach(function(t) {
        html += '<div class="talent-item"><strong>' + t.name + '</strong>' +
          (t.enhances ? '<span class="talent-enhances">Enhances: ' + t.enhances + '</span>' : '') +
          '<span class="talent-effect">' + t.effect + '</span>' +
          (t.requires ? '<span class="talent-requires">Requires: ' + t.requires + '</span>' : '') +
          '</div>';
      });
      html += '</div></details>';
    }

    // Universal Talents preview
    if (GAME.universal_talents) {
      html += '<details class="ref-panel"><summary><h4>Universal Talents <span class="feature-meta">Available to all characters</span></h4></summary>';
      html += '<div class="talent-list">';
      ['combat', 'exploration', 'skill'].forEach(function(cat) {
        var talents = GAME.universal_talents[cat] || [];
        if (talents.length) {
          html += '<h5>' + cat.charAt(0).toUpperCase() + cat.slice(1) + '</h5>';
          talents.forEach(function(t) {
            html += '<div class="talent-item"><strong>' + t.name + '</strong>' +
              '<span class="talent-effect">' + t.effect + '</span></div>';
          });
        }
      });
      html += '</div></details>';
    }

    // Mastery Paths preview
    if (GAME.mastery_paths && GAME.mastery_paths.length) {
      html += '<details class="ref-panel"><summary><h4>Mastery Paths <span class="feature-meta">Available at L11+</span></h4></summary>';
      html += '<div class="mastery-list">';
      GAME.mastery_paths.forEach(function(mp) {
        html += '<div class="mastery-item">' +
          '<div class="mastery-header"><strong>' + mp.name + '</strong><span class="mastery-stats">' + mp.stats + '</span></div>' +
          '<span class="mastery-narrative">' + mp.narrative + '</span>' +
          '</div>';
      });
      html += '</div></details>';
    }


    detail.innerHTML = html;

    renderClassStep();
    setTimeout(function() { detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 50);
  }

  function ordinal(n) {
    var s = ['th', 'st', 'nd', 'rd'];
    var v = n % 100;
    return n + (s[(v - 20) % 10] || s[v] || s[0]);
  }

  // Determine armor type and AGI cap for DV calculation
  function getArmorAgiCap(armor) {
    if (!armor) return 99; // no cap without armor
    var eq = GAME.equipment;
    if ((eq.light_armor || []).some(function(a) { return a.name === armor.name; })) return 5;
    if ((eq.medium_armor || []).some(function(a) { return a.name === armor.name; })) return 3;
    if ((eq.heavy_armor || []).some(function(a) { return a.name === armor.name; })) return 1;
    return 99;
  }

  function calcDV(agiMod, armor, shield) {
    var cap = getArmorAgiCap(armor);
    var effectiveAgi = Math.min(agiMod, cap);
    return 10 + effectiveAgi + (armor ? armor.dv_bonus : 0) + (shield ? shield.dv_bonus : 0);
  }

  function calcHumanity(cls) {
    var base = cls ? cls.starting_humanity : GAME.base_humanity;
    var augCost = char.selectedAugments.reduce(function(sum, a) { return sum + a.humanity_cost; }, 0);
    return Math.max(0, base - augCost);
  }

  function getHumanitySpent() {
    return char.selectedAugments.reduce(function(sum, a) { return sum + a.humanity_cost; }, 0);
  }

  // Look up the spell slot entry for the character's current level.
  // Returns the highest-level entry whose level <= char.level, or the first entry.
  function getSpellSlotEntry(cls) {
    if (!cls || !cls.spell_slots || !cls.spell_slots.length) return null;
    var entry = cls.spell_slots[0];
    for (var i = 0; i < cls.spell_slots.length; i++) {
      if (cls.spell_slots[i].level <= char.level) entry = cls.spell_slots[i];
    }
    return entry;
  }

  // Get the starting cantrip count for the character's current level.
  // Cantrip count scales with level for casters (encoded in the spell_slots data).
  function getCantripsForLevel(cls) {
    if (!cls || !cls.starting_cantrips) return 0;
    // If the class data has a cantrips_by_level array, use it; otherwise use starting_cantrips
    if (cls.cantrips_by_level) {
      var cantrips = cls.starting_cantrips;
      for (var i = 0; i < cls.cantrips_by_level.length; i++) {
        if (cls.cantrips_by_level[i].level <= char.level) cantrips = cls.cantrips_by_level[i].count;
      }
      return cantrips;
    }
    return cls.starting_cantrips;
  }

  // Spell slot tiers lost due to humanity spent on augmentations.
  // Each point of humanity spent removes the highest remaining spell tier (from 9th down).
  // The 10th point spent (humanity reaches 0) also removes cantrips.
  function getSpellSlotsAfterHumanity(cls) {
    var entry = getSpellSlotEntry(cls);
    if (!entry) return { slots: [], cantrips: 0 };
    var humSpent = getHumanitySpent();
    var baseSlots = (entry.slots || []).slice(); // clone array
    var cantrips = getCantripsForLevel(cls);

    // Remove spell tiers from highest (index 8 = 9th-level) down
    // Each humanity point spent removes one tier from the top
    var tiersToRemove = humSpent;
    for (var tier = baseSlots.length - 1; tier >= 0 && tiersToRemove > 0; tier--) {
      if (baseSlots[tier] > 0) {
        baseSlots[tier] = 0;
        tiersToRemove--;
      }
    }

    // If all spell tiers are removed and there are still points to "spend",
    // the last point removes cantrips
    if (tiersToRemove > 0) {
      cantrips = 0;
    }

    return { slots: baseSlots, cantrips: cantrips };
  }

  // Compute spell slots from skill tree investment (classless — SITE-079).
  // Replaces archetype-based isCaster checks throughout the builder.
  function computeTreeSpellSlots() {
    var cpSys = computeCPSystem();
    var baseCP = cpSys.baseCpPerTree;
    var arcaneDepth  = baseCP['Arcane Arts']       || 0;
    var divineDepth  = baseCP['Divine Channeling']  || 0;
    var medDepth     = baseCP['Medicine']           || 0;

    function hasPurch(treeName, abilityName) {
      return char.purchasedAbilities.some(function(ab) {
        return ab.treeName === treeName && ab.abilityName === abilityName;
      });
    }

    var slots = [0, 0, 0, 0, 0, 0, 0]; // indices 0–6 = 1st–7th level

    // ---- Arcane Arts ----
    if (hasPurch('Arcane Arts', 'Spell Crafting (Basic)')) {
      slots[0] = Math.max(slots[0], 2);
    }
    // "Spell Slots (Expanded)" OR Journeyman milestone (30 CP) auto-unlocks 2nd-level
    if (slots[0] > 0 && (hasPurch('Arcane Arts', 'Spell Slots (Expanded)') || arcaneDepth >= 30)) {
      slots[0] = Math.max(slots[0], 3);
      slots[1] = Math.max(slots[1], 2);
    }
    // "Spell Slots (Advanced)" OR Master milestone (50 CP) auto-unlocks 3rd-level
    if (hasPurch('Arcane Arts', 'Spell Slots (Advanced)') || arcaneDepth >= 50) {
      slots[0] = Math.max(slots[0], 4);
      slots[1] = Math.max(slots[1], 3);
      slots[2] = Math.max(slots[2], 2);
    }
    // "Spell Slots (Advanced)" grants 4th-level; Expert (60 CP) also auto-unlocks 4th
    if (hasPurch('Arcane Arts', 'Spell Slots (Advanced)') || arcaneDepth >= 60) {
      slots[3] = Math.max(slots[3], 1);
    }
    // 5th-Level Spell Access (Capstone, L10+)
    if (hasPurch('Arcane Arts', '5th-Level Spell Access') && char.level >= 10) {
      slots[4] = Math.max(slots[4], 1);
    }
    // 6th-level (L11+, milestone within Capstone tier)
    if (hasPurch('Arcane Arts', '5th-Level Spell Access') && char.level >= 11) {
      slots[5] = Math.max(slots[5], 1);
    }
    // 7th-level (L13+)
    if (hasPurch('Arcane Arts', '5th-Level Spell Access') && char.level >= 13) {
      slots[6] = Math.max(slots[6], 1);
    }

    // ---- Divine Channeling ----
    if (hasPurch('Divine Channeling', 'Spell Slots (Divine)')) {
      slots[0] = Math.max(slots[0], 2);
      slots[1] = Math.max(slots[1], 2);
    } else if (divineDepth >= 30) {
      // Journeyman auto-unlock: 1st-level divine only
      slots[0] = Math.max(slots[0], 2);
    }
    // "Spell Slots (Advanced Divine)" OR Master milestone (50 CP) auto-unlocks 3rd-level
    if (hasPurch('Divine Channeling', 'Spell Slots (Advanced Divine)') || divineDepth >= 50) {
      slots[0] = Math.max(slots[0], 3);
      slots[1] = Math.max(slots[1], 3);
      slots[2] = Math.max(slots[2], 2);
      slots[3] = Math.max(slots[3], 1);
    }
    if (hasPurch('Divine Channeling', '5th-Level Divine Spells') && char.level >= 10) {
      slots[4] = Math.max(slots[4], 1);
    }

    // ---- Medicine ----
    if (hasPurch('Medicine', 'Spell Slots (Medical)')) {
      slots[0] = Math.max(slots[0], 2);
      if (medDepth >= 30) {
        // Journeyman upgrades to 2nd-level
        slots[0] = Math.max(slots[0], 3);
        slots[1] = Math.max(slots[1], 2);
      }
    } else if (medDepth >= 30) {
      // Journeyman auto-unlock: 1st-level if Spell Slots (Medical) not purchased
      slots[0] = Math.max(slots[0], 2);
    }
    if (hasPurch('Medicine', 'Expanded Medical Casting')) {
      slots[2] = Math.max(slots[2], 2);
      slots[3] = Math.max(slots[3], 1);
    }
    if (medDepth >= 50) {
      // Master: auto-unlock 3rd-level
      slots[2] = Math.max(slots[2], 2);
    }
    if (hasPurch('Medicine', "Master Healer's Repertoire") && char.level >= 10) {
      slots[4] = Math.max(slots[4], 1);
    }

    var isCaster = slots.some(function(s) { return s > 0; });

    // Spellcasting attribute: Arcane → INT; Divine/Medicine → WIS.
    // If investing in Arcane AND divine/medicine, Arcane (INT) takes precedence.
    var spellAttr = 'INT';
    if (isCaster && arcaneDepth === 0 && (divineDepth > 0 || medDepth > 0)) {
      spellAttr = 'WIS';
    }

    // Total cantrips: class-granted (selectedCantrips) + CP-purchased
    var cantrips = char.selectedCantrips.length + char.cpCantripPurchases.length;

    return { slots: slots, isCaster: isCaster, spellAttr: spellAttr, cantrips: cantrips };
  }

  // Apply humanity reduction to tree-computed spell slots.
  function applyHumanityToTreeSlots(treeSlots) {
    var humSpent = getHumanitySpent();
    var slots = treeSlots.slots.slice();
    var cantrips = treeSlots.cantrips;
    for (var tier = slots.length - 1; tier >= 0 && humSpent > 0; tier--) {
      if (slots[tier] > 0) { slots[tier] = 0; humSpent--; }
    }
    if (humSpent > 0) cantrips = 0;
    return { slots: slots, cantrips: cantrips };
  }

  // ---- Step 3: Attributes ----
  function renderAttributes() {
    var method = char.method;
    if (method === 'standard') renderStandardArray();
    else if (method === 'pointbuy') renderPointBuy();
    else renderManualInput();
    updateDerived();
  }

  $$('.method-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      char.method = btn.getAttribute('data-method');
      $$('.method-btn').forEach(function(b) { b.classList.toggle('active', b === btn); });
      renderAttributes();
    });
  });

  var selectedValue = null;
  var usedValues = [];

  function renderStandardArray() {
    el('attr-desc').textContent = 'Click a value from the pool, then click an attribute to assign it.';
    var pool = el('attr-pool');
    var assignments = el('attr-assignments');

    function render() {
      // Track which array positions are used (preserves order and duplicates)
      var usedCopy = usedValues.slice();
      var poolItems = GAME.standard_array.map(function(v) {
        var idx = usedCopy.indexOf(v);
        if (idx > -1) {
          usedCopy.splice(idx, 1);
          return { value: v, used: true };
        }
        return { value: v, used: false };
      });

      pool.innerHTML = '<h4>Available Values</h4><div class="pool-values">' +
        poolItems.map(function(item) {
          if (item.used) {
            return '<span class="pool-btn used"></span>';
          }
          return '<button class="pool-btn' + (selectedValue === item.value ? ' selected' : '') + '" data-val="' + item.value + '">' + item.value + '</button>';
        }).join('') + '</div>';

      assignments.innerHTML = GAME.attributes.map(function(attr) {
        var score = char.attributes[attr] || 0;
        var mod = score ? getMod(score) : 0;
        var name = (GAME.attribute_names && GAME.attribute_names[attr]) || attr;
        var rowClass = 'attr-row';
        if (score) rowClass += ' filled';
        else if (selectedValue !== null) rowClass += ' assignable';
        return '<div class="' + rowClass + '" data-attr="' + attr + '">' +
          '<span class="attr-name">' + attr + '</span>' +
          '<span class="attr-full-name">' + name + '</span>' +
          '<span class="attr-score' + (score ? '' : ' empty') + '">' + (score || '\u2014') + '</span>' +
          '<span class="attr-mod">' + (score ? modStr(mod) : '') + '</span>' +
          '<span class="attr-actions">' + (score ? '<button class="attr-clear" data-attr="' + attr + '">x</button>' : '') + '</span>' +
          '</div>';
      }).join('');

      $$('.pool-btn', pool).forEach(function(btn) {
        btn.addEventListener('click', function() {
          selectedValue = Number(btn.getAttribute('data-val'));
          render();
        });
      });

      $$('.attr-row', assignments).forEach(function(row) {
        row.addEventListener('click', function(e) {
          if (e.target.classList.contains('attr-clear')) return;
          var attr = row.getAttribute('data-attr');
          if (selectedValue !== null && !char.attributes[attr]) {
            char.attributes[attr] = selectedValue;
            usedValues.push(selectedValue);
            selectedValue = null;
            render();
            updateDerived();
            updateNextBtn();
          }
        });
      });

      $$('.attr-clear', assignments).forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var attr = btn.getAttribute('data-attr');
          var val = char.attributes[attr];
          if (val) {
            var idx = usedValues.indexOf(val);
            if (idx > -1) usedValues.splice(idx, 1);
            char.attributes[attr] = 0;
            render();
            updateDerived();
            updateNextBtn();
          }
        });
      });
    }

    render();
  }

  function renderPointBuy() {
    el('attr-desc').textContent = 'You have ' + GAME.point_buy_points + ' points. Increase or decrease each attribute (min 8, max 15).';
    var pool = el('attr-pool');
    var assignments = el('attr-assignments');

    function getPointCost(score) {
      var entry = GAME.point_buy_costs.find(function(e) { return e.score === score; });
      return entry ? entry.cost : 0;
    }

    function totalSpent() {
      return GAME.attributes.reduce(function(sum, attr) {
        return sum + getPointCost(char.pointBuyScores[attr] || 8);
      }, 0);
    }

    function render() {
      var spent = totalSpent();
      var remaining = GAME.point_buy_points - spent;

      pool.innerHTML = '<h4>Points Remaining: <span class="points-count' + (remaining < 0 ? ' over' : '') + '">' + remaining + '</span> / ' + GAME.point_buy_points + '</h4>';

      assignments.innerHTML = GAME.attributes.map(function(attr) {
        var score = char.pointBuyScores[attr] || 8;
        var mod = getMod(score);
        var name = (GAME.attribute_names && GAME.attribute_names[attr]) || attr;
        var cost = getPointCost(score);
        return '<div class="attr-row pb-row" data-attr="' + attr + '">' +
          '<span class="attr-name">' + attr + '</span>' +
          '<span class="attr-full-name">' + name + '</span>' +
          '<button class="pb-btn" data-attr="' + attr + '" data-dir="-1"' + (score <= 8 ? ' disabled' : '') + '>-</button>' +
          '<span class="attr-score">' + score + '</span>' +
          '<button class="pb-btn" data-attr="' + attr + '" data-dir="1"' + (score >= 15 ? ' disabled' : '') + '>+</button>' +
          '<span class="attr-mod">' + modStr(mod) + '</span>' +
          '<span class="pb-cost">(' + cost + ' pts)</span>' +
          '</div>';
      }).join('');

      GAME.attributes.forEach(function(attr) {
        char.attributes[attr] = char.pointBuyScores[attr] || 8;
      });

      $$('.pb-btn', assignments).forEach(function(btn) {
        btn.addEventListener('click', function() {
          var attr = btn.getAttribute('data-attr');
          var dir = Number(btn.getAttribute('data-dir'));
          var current = char.pointBuyScores[attr] || 8;
          var next = current + dir;
          if (next >= 8 && next <= 15) {
            // Check budget before increasing
            if (dir > 0) {
              var newCost = getPointCost(next) - getPointCost(current);
              if (totalSpent() + newCost > GAME.point_buy_points) return;
            }
            char.pointBuyScores[attr] = next;
            render();
            updateDerived();
            updateNextBtn();
          }
        });
      });
    }

    render();
  }

  function renderManualInput() {
    el('attr-desc').textContent = 'Type a score (1\u201320) for each attribute. Use this for rolled stats or custom values.';
    var pool = el('attr-pool');
    var assignments = el('attr-assignments');

    pool.innerHTML = '<h4>Manual Entry</h4><p class="manual-hint">Enter any score from 1 to 20 per attribute.</p>';

    assignments.innerHTML = GAME.attributes.map(function(attr) {
      var score = char.attributes[attr] || '';
      var mod = score ? getMod(score) : 0;
      var name = (GAME.attribute_names && GAME.attribute_names[attr]) || attr;
      return '<div class="attr-row manual-row" data-attr="' + attr + '">' +
        '<span class="attr-name">' + attr + '</span>' +
        '<span class="attr-full-name">' + name + '</span>' +
        '<input type="number" class="manual-input" data-attr="' + attr + '" min="1" max="20" value="' + (score || '') + '" placeholder="\u2014" />' +
        '<span class="attr-mod">' + (score ? modStr(mod) : '') + '</span>' +
        '</div>';
    }).join('');

    $$('.manual-input', assignments).forEach(function(input) {
      input.addEventListener('input', function() {
        var attr = input.getAttribute('data-attr');
        var val = parseInt(input.value, 10);
        if (!isNaN(val) && val >= 1 && val <= 20) {
          char.attributes[attr] = val;
        } else if (input.value === '') {
          char.attributes[attr] = 0;
        }
        // Update just the mod display next to this input
        var modSpan = input.parentElement.querySelector('.attr-mod');
        if (char.attributes[attr]) {
          modSpan.textContent = modStr(getMod(char.attributes[attr]));
        } else {
          modSpan.textContent = '';
        }
        updateDerived();
        updateNextBtn();
      });
    });
  }

  function updateDerived() {
    var preview = el('derived-preview');
    var a = char.attributes;
    var cls = char.class;
    var frame = getFrame(); // chassis (primary) or class (fallback)

    var speciesNote = '';
    if (char.species) {
      speciesNote = '<p class="species-note">Species bonus: ' + char.species.attribute_bonus + ' (apply manually when assigning)</p>';
    }

    if (!a.MIG && !a.AGI && char.method === 'standard') {
      preview.innerHTML = speciesNote + '<p class="muted">Assign attributes to see derived stats.</p>';
      return;
    }

    var endMod = getMod(a.END || 10);
    var agiMod = getMod(a.AGI || 10);
    var migMod = getMod(a.MIG || 10);
    var wisMod = getMod(a.WIS || 10);
    var preMod = getMod(a.PRE || 10);
    var hp = frame ? frame.hp_base + endMod : '?';
    var dv = 10 + agiMod;
    var init = agiMod;
    var fort = Math.max(endMod, migMod);
    var ref = Math.max(agiMod, wisMod);
    var will = Math.max(wisMod, preMod);

    // Add proficiency bonus to trained saves (from chassis)
    var profBonus = getProfBonus(char.level || 1);
    var trainedSaves = {};
    if (frame) (frame.save_proficiencies || []).forEach(function(s) { trainedSaves[s] = true; });
    var fortTotal = fort + (trainedSaves.Fortitude ? profBonus : 0);
    var refTotal = ref + (trainedSaves.Reflex ? profBonus : 0);
    var willTotal = will + (trainedSaves.Will ? profBonus : 0);

    preview.innerHTML = speciesNote +
      '<div class="derived-grid">' +
      '<div class="derived-item"><span class="derived-label">HP</span><span class="derived-val">' + hp + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">DV</span><span class="derived-val">' + dv + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">Initiative</span><span class="derived-val">' + modStr(init) + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">FORT Save</span><span class="derived-val">' + modStr(fortTotal) + (trainedSaves.Fortitude ? '*' : '') + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">REF Save</span><span class="derived-val">' + modStr(refTotal) + (trainedSaves.Reflex ? '*' : '') + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">WILL Save</span><span class="derived-val">' + modStr(willTotal) + (trainedSaves.Will ? '*' : '') + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">Movement</span><span class="derived-val">' + GAME.base_movement + ' ft</span></div>' +
      '<div class="derived-item"><span class="derived-label">Humanity</span><span class="derived-val">' + (cls ? cls.starting_humanity : GAME.base_humanity) + '</span></div>' +
      '</div>' +
      (frame ? '<p class="save-note">* = proficiency-trained save (+' + profBonus + ' included)</p>' : '');
  }

  // ---- Step 4: Proficiencies ----
  function getAutoSkills() {
    var autoSkills = {};
    if (char.class) {
      (char.class.skill_bonuses || []).forEach(function(sb) { autoSkills[sb.skill] = true; });
    }
    if (char.background) {
      // Parse "Skill Name +2" — strip the trailing " +N" to get the skill name
      var bgSkill = char.background.skill_bonus.replace(/\s+\+\d+$/, '');
      autoSkills[bgSkill] = true;
    }
    return autoSkills;
  }

  function getMaxProfPicks() {
    var base = (char.chassis && char.chassis.starting_skills) || 2;
    if (char.species && char.species.name === 'Human') base += 1;
    return base;
  }

  // ---- Step 4: Class Configuration (unified) ----
  // Show/hide level slider and archetype section based on chassis/class state
  function renderClassStep() {
    var lvlSelector = el('class-level-selector');
    // Restore archetype section and level selector if chassis already chosen
    if (char.chassis) {
      var archetypeSection = el('archetype-section');
      if (archetypeSection) archetypeSection.style.display = '';
    }
    if (char.chassis && lvlSelector) {
      lvlSelector.style.display = '';
      var slider = el('level-slider');
      var display = el('level-display');
      slider.value = char.level;
      display.textContent = char.level;
      slider.oninput = function() {
        char.level = Number(slider.value);
        display.textContent = char.level;
        updateBreadcrumbs();
        // Update spell slot display in class detail if it's showing
        updateClassDetailSpellSlots();
      };
    }
  }

  // Lightweight update for spell slot display in class detail when level changes
  function updateClassDetailSpellSlots() {
    var cls = char.class;
    if (!cls || !cls.spell_slots || !cls.spell_slots.length) return;
    var detail = el('class-detail');
    if (!detail) return;
    var slotHeader = detail.querySelector('h4');
    // Find the spell slots header and its sibling display
    var headers = detail.querySelectorAll('h4');
    for (var i = 0; i < headers.length; i++) {
      if (headers[i].textContent.indexOf('Spell Slots') === 0) {
        var slotEntry = getSpellSlotEntry(cls);
        headers[i].innerHTML = 'Spell Slots (Level ' + char.level + ')';
        var display = headers[i].nextElementSibling;
        if (display && display.classList.contains('spell-slot-display')) {
          var html = '';
          (slotEntry.slots || []).forEach(function(count, si) {
            if (count > 0) html += '<span class="slot-badge">' + count + ' x ' + ordinal(si + 1) + '-level</span>';
          });
          var cantripsAtLevel = getCantripsForLevel(cls);
          if (cantripsAtLevel) html += '<span class="slot-badge cantrip-badge">' + cantripsAtLevel + ' Cantrips</span>';
          display.innerHTML = html;
        }
        break;
      }
    }
  }

  // Unified Build step: Attributes + Proficiencies + Abilities + Progression
  function renderBuild() {
    // Sync level slider (it lives on step 1 but we need the value here)
    renderAttributes();
    renderSkills();
    renderSkillTrees();
    renderProgression();
  }

  function isSkillProficient(skillName) {
    var autoSkills = getAutoSkills();
    return !!autoSkills[skillName] || char.chosenProficiencies.indexOf(skillName) > -1;
  }

  function renderSkills() {
    var container = el('skills-list');
    var autoSkills = getAutoSkills();
    var maxPicks = getMaxProfPicks();
    var picksUsed = char.chosenProficiencies.length;
    var picksLeft = maxPicks - picksUsed;

    // Update the pick count display
    var pickCountEl = el('prof-pick-count');
    if (pickCountEl) pickCountEl.textContent = maxPicks;

    var budgetEl = el('prof-picks-remaining');
    if (budgetEl) {
      budgetEl.innerHTML = '<div class="cp-bar"><span class="cp-label">Bonus Proficiency Picks</span>' +
        '<span class="cp-remaining' + (picksLeft === 0 ? ' over' : '') + '">' + picksLeft + '</span>' +
        '<span class="cp-total"> / ' + maxPicks + ' remaining</span></div>';
    }

    var categories = {};
    GAME.skills.forEach(function(sk) {
      if (!categories[sk.category]) categories[sk.category] = [];
      categories[sk.category].push(sk);
    });

    var html = '';
    Object.keys(categories).forEach(function(cat) {
      html += '<div class="skill-category"><h4>' + cat + '</h4>';
      categories[cat].forEach(function(sk) {
        var isAuto = !!autoSkills[sk.name];
        var isChosen = char.chosenProficiencies.indexOf(sk.name) > -1;
        var isProficient = isAuto || isChosen;
        var primaryAttr = sk.attribute.split('/')[0];
        var attrScore = char.attributes[primaryAttr] || 10;
        var mod = getMod(attrScore);
        var profBonus = isProficient ? getProfBonus(char.level || 1) : 0;
        var total = mod + profBonus;

        var rowClass = 'skill-row';
        if (isAuto) rowClass += ' auto-prof';
        else if (isChosen) rowClass += ' chosen-prof';
        var canPick = !isAuto && !isChosen && picksLeft > 0;

        html += '<button class="' + rowClass + '" data-skill="' + sk.name + '"' + (isAuto ? ' disabled' : '') + '>' +
          '<span class="skill-name">' + sk.name + '</span>' +
          '<span class="skill-attr">' + sk.attribute + '</span>' +
          '<span class="skill-mod">' + modStr(total) + '</span>';
        if (isAuto) {
          html += '<span class="skill-badge">Chassis/BG</span>';
        } else if (isChosen) {
          html += '<span class="skill-badge chosen">Chosen</span>';
        } else if (canPick) {
          html += '<span class="skill-badge pick">+ Pick</span>';
        }
        html += '</button>';
      });
      html += '</div>';
    });
    container.innerHTML = html;

    // Use event delegation for proficiency pick clicks (more robust than per-button binding)
    container.onclick = function(e) {
      var btn = e.target.closest('.skill-row');
      if (!btn || btn.disabled || btn.classList.contains('auto-prof')) return;
      var skillName = btn.getAttribute('data-skill');
      if (!skillName) return;
      var idx = char.chosenProficiencies.indexOf(skillName);
      if (idx > -1) {
        char.chosenProficiencies.splice(idx, 1);
      } else if (char.chosenProficiencies.length < maxPicks) {
        char.chosenProficiencies.push(skillName);
      }
      renderSkills();
    };
  }

  // ---- Step 5: Skill Trees (CP Spending) ----

  // CP cost system helpers (SITE-046)
  function computeCPSystem() {
    var trees = (GAME.shared_skill_trees && GAME.shared_skill_trees.length > 0) ? GAME.shared_skill_trees : [];

    // Base CP per tree (using raw YAML cp_cost — not effective)
    var baseCpPerTree = {};
    char.purchasedAbilities.forEach(function(ab) {
      baseCpPerTree[ab.treeName] = (baseCpPerTree[ab.treeName] || 0) + ab.cp_cost;
    });

    // Trees with any investment, in stable order (position in GAME.shared_skill_trees)
    var investedTrees = trees
      .filter(function(t) { return baseCpPerTree[t.name] > 0; })
      .map(function(t) { return t.name; });

    function getBreadthSurcharge(rank) {
      if (rank <= 2) return 0;
      if (rank === 3) return 1;
      if (rank === 4) return 2;
      return 3; // 5+
    }

    function getDepthDiscount(baseCpInTree) {
      if (baseCpInTree >= 60) return 3;
      if (baseCpInTree >= 40) return 2;
      if (baseCpInTree >= 20) return 1;
      return 0;
    }

    function getEffectiveCost(baseCost, treeName, tier) {
      var rank = investedTrees.indexOf(treeName) + 1;
      if (rank === 0) rank = investedTrees.length + 1; // would-be new tree
      // Signature (Tier 5) capstones are exempt from breadth surcharge (rules/character-points.md)
      var surcharge = (tier === 5) ? 0 : getBreadthSurcharge(rank);
      var cpInTree = baseCpPerTree[treeName] || 0;
      var discount = getDepthDiscount(cpInTree);
      var minCost = Math.ceil(baseCost / 2); // floor = half base cost, rounded up
      return Math.max(minCost, baseCost + surcharge - discount);
    }

    // Compute total effective spent
    var totalEffectiveSpent = char.purchasedAbilities.reduce(function(sum, ab) {
      return sum + getEffectiveCost(ab.cp_cost, ab.treeName, ab.tier);
    }, 0);

    // Add proficiency upgrade costs
    PROFICIENCY_UPGRADES.forEach(function(u) {
      if (char.purchasedProfUpgrades[u.name]) totalEffectiveSpent += u.cost;
    });

    // Add attribute boost costs (10 CP per +1)
    ATTR_NAMES.forEach(function(attr) {
      totalEffectiveSpent += (char.purchasedAttrBoosts[attr] || 0) * 10;
    });

    // Add CP skill purchase costs (SITE-073)
    var isSpecialist = char.chassis && char.chassis.name === 'Specialist';
    totalEffectiveSpent += char.cpSkillProficiency.length * (isSpecialist ? 1 : 2);
    totalEffectiveSpent += char.cpSkillExpertise.length * (isSpecialist ? 2 : 4);
    totalEffectiveSpent += char.cpAdvancedAccess.length * (isSpecialist ? 2 : 3);

    // Add CP cantrip purchase costs (SITE-074, cost logic updated SITE-108)
    totalEffectiveSpent += char.cpCantripPurchases.length * getCantripCPCost(baseCpPerTree);

    // Tier caps
    var treesWithT2 = {}, treesWithT3 = {}, treesWithT4 = {};
    char.purchasedAbilities.forEach(function(ab) {
      if (ab.tier === 2) treesWithT2[ab.treeName] = true;
      if (ab.tier === 3) treesWithT3[ab.treeName] = true;
      if (ab.tier >= 4) treesWithT4[ab.treeName] = true;
    });

    return {
      baseCpPerTree: baseCpPerTree,
      investedTrees: investedTrees,
      totalEffectiveSpent: totalEffectiveSpent,
      treesWithT2: treesWithT2,
      treesWithT3: treesWithT3,
      treesWithT4: treesWithT4,
      getBreadthSurcharge: getBreadthSurcharge,
      getDepthDiscount: getDepthDiscount,
      getEffectiveCost: getEffectiveCost
    };
  }

  // Cantrip CP cost based on tree milestone investment (SITE-108)
  // 10 CP if Divine Channeling or Medicine tree has Initiate+ (15+ CP invested)
  // 12 CP if Leadership & Social tree has Initiate+ (15+ CP invested)
  // 15 CP otherwise (default)
  // Accepts optional pre-computed baseCpPerTree to avoid recomputation inside computeCPSystem()
  function getCantripCPCost(baseCpPerTree) {
    if (!baseCpPerTree) {
      baseCpPerTree = {};
      char.purchasedAbilities.forEach(function(ab) {
        baseCpPerTree[ab.treeName] = (baseCpPerTree[ab.treeName] || 0) + ab.cp_cost;
      });
    }
    var divine = baseCpPerTree['Divine Channeling'] || 0;
    var medicine = baseCpPerTree['Medicine'] || 0;
    var social = baseCpPerTree['Leadership & Social'] || 0;
    if (divine >= 15 || medicine >= 15) return 10;
    if (social >= 15) return 12;
    return 15;
  }

  // Proficiency upgrades available via CP (SITE-053, costs corrected SITE-070)
  var PROFICIENCY_UPGRADES = [
    { name: 'Weapon Prof: Weapon Group', cost: 5, description: 'Gain proficiency with one non-martial weapon group (e.g. Sidearms, Improvised).' },
    { name: 'Weapon Prof: Martial Melee', cost: 8, description: 'Gain proficiency with martial melee weapons.' },
    { name: 'Weapon Prof: Martial Ranged', cost: 8, description: 'Gain proficiency with martial ranged weapons.' },
    { name: 'Armor Prof: Medium', cost: 10, description: 'Gain proficiency with medium armor.', requires: null },
    { name: 'Armor Prof: Heavy', cost: 15, description: 'Gain proficiency with heavy armor.', requires: 'Armor Prof: Medium' },
    { name: 'Shield Proficiency', cost: 5, description: 'Gain proficiency with shields.' },
    { name: 'Save Proficiency (3rd)', cost: 20, requires_level: 7, description: 'Gain proficiency in your third saving throw.' }
  ];

  // Recommended trees per archetype name
  var ARCHETYPE_RECOMMENDED_TREES = {
    'Warrior':    ['Martial Combat'],
    'Gunslinger': ['Ranged Combat'],
    'Mystic':     ['Arcane Arts'],
    'Technician': ['Technology'],
    'Medic':      ['Medicine'],
    'Operative':  ['Stealth & Subterfuge'],
    'Diplomat':   ['Leadership & Social'],
    'Channeler':  ['Divine Channeling'],
    'Scavenger':  ['Survival & Scavenging'],
    'Infiltrator':['Stealth & Subterfuge', 'Technology'],
    'Psion':      ['Psionic Disciplines'],
    'Mutant':     ['Mutation']
  };

  function renderSkillTrees() {
    var budget = el('cp-budget');
    var panel = el('skill-trees-panel');
    var cls = char.class;

    var cpSys = computeCPSystem();
    var totalCP = getTotalCP();
    var remainingCP = totalCP - cpSys.totalEffectiveSpent;

    // Per-tree breakdown for budget display
    var treeBreakdownHtml = '';
    if (cpSys.investedTrees.length > 0) {
      treeBreakdownHtml = '<div class="cp-tree-breakdown">';
      cpSys.investedTrees.forEach(function(tn, idx) {
        var rank = idx + 1;
        var surcharge = cpSys.getBreadthSurcharge(rank);
        var cpSpent = cpSys.baseCpPerTree[tn] || 0;
        var discount = cpSys.getDepthDiscount(cpSpent);
        treeBreakdownHtml += '<span class="cp-tree-stat">' + tn + ': ' + cpSpent + ' base CP' +
          (surcharge > 0 ? ' <span class="cp-surcharge">+' + surcharge + '/ability</span>' : '') +
          (discount > 0 ? ' <span class="cp-discount">-' + discount + '/ability</span>' : '') +
          '</span>';
      });
      treeBreakdownHtml += '</div>';
    }

    budget.innerHTML =
      '<div class="cp-bar">' +
      '<span class="cp-label">Character Points</span>' +
      '<span class="cp-remaining' + (remainingCP < 0 ? ' over' : '') + '">' + remainingCP + '</span>' +
      '<span class="cp-total"> / ' + totalCP + ' CP</span>' +
      '</div>' + treeBreakdownHtml;

    var recommendedTrees = (cls && ARCHETYPE_RECOMMENDED_TREES[cls.name]) || [];
    var trees = (GAME.shared_skill_trees && GAME.shared_skill_trees.length > 0)
      ? GAME.shared_skill_trees
      : (cls ? (cls.skill_trees || []) : []);

    if (trees.length === 0) {
      panel.innerHTML = '<p class="muted">No skill trees available.</p>';
      return;
    }

    var html = '';
    if (cls) {
      html += '<p class="cp-trees-note">You can spend CP in <strong>any</strong> tree regardless of build. ' +
        (recommendedTrees.length ? 'Recommended for ' + cls.name + ': <em>' + recommendedTrees.join(', ') + '</em>.' : '') +
        '</p>';
    } else {
      html += '<p class="cp-trees-note">Select a recommended build above to see suggested trees, or explore all 11 trees below. Any character can purchase from any tree.</p>';
    }

    // Tier cap counts
    var t2TreeCount = Object.keys(cpSys.treesWithT2).length;
    var t3TreeCount = Object.keys(cpSys.treesWithT3).length;
    var t4TreeCount = Object.keys(cpSys.treesWithT4).length;

    trees.forEach(function(tree) {
      var isRecommended = recommendedTrees.indexOf(tree.name) > -1;
      var treeRank = cpSys.investedTrees.indexOf(tree.name) + 1;
      if (treeRank === 0) treeRank = cpSys.investedTrees.length + 1;
      var surcharge = cpSys.getBreadthSurcharge(treeRank);
      var cpInTree = cpSys.baseCpPerTree[tree.name] || 0;
      var discount = cpSys.getDepthDiscount(cpInTree);

      // Tier cap flags for this tree
      var t2AtCap = t2TreeCount >= 4 && !cpSys.treesWithT2[tree.name];
      var t3AtCap = t3TreeCount >= 2 && !cpSys.treesWithT3[tree.name];
      var t4AtCap = t4TreeCount >= 1 && !cpSys.treesWithT4[tree.name];

      var costNote = '';
      if (surcharge > 0 && discount > 0) {
        costNote = ' <span class="tree-cost-note">(+' + surcharge + ' breadth, -' + discount + ' depth)</span>';
      } else if (surcharge > 0) {
        costNote = ' <span class="tree-cost-note">(+' + surcharge + ' breadth surcharge)</span>';
      } else if (discount > 0) {
        costNote = ' <span class="tree-cost-note">(-' + discount + ' depth discount)</span>';
      }

      html += '<div class="cp-tree' + (isRecommended ? ' cp-tree-recommended' : '') + '">';
      html += '<div class="cp-tree-header"><h4>' + tree.name +
        (isRecommended ? ' <span class="recommended-badge">Recommended</span>' : '') +
        costNote + '</h4><span class="tree-focus">(' + tree.focus + ')</span></div>';

      // Milestones (SITE-047)
      if (tree.milestones) {
        var ms = tree.milestones;
        var mList = [
          { label: 'Initiate', cp: ms.initiate.cp, bonus: ms.initiate.bonus },
          { label: 'Journeyman', cp: ms.journeyman.cp, bonus: ms.journeyman.bonus },
          { label: 'Master', cp: ms.master.cp, bonus: ms.master.bonus }
        ];
        var maxMsCp = mList[mList.length - 1].cp;
        var progressPct = Math.min(100, Math.round((cpInTree / maxMsCp) * 100));
        html += '<div class="tree-milestones">';
        html += '<div class="milestone-progress-bar"><div class="milestone-bar-fill" style="width:' + progressPct + '%"></div>';
        mList.forEach(function(m) {
          var pct = Math.round((m.cp / maxMsCp) * 100);
          var earned = cpInTree >= m.cp;
          html += '<span class="milestone-tick' + (earned ? ' earned' : '') + '" style="left:' + pct + '%" title="' + m.label + ' (' + m.cp + ' CP): ' + m.bonus + '">' + m.cp + '</span>';
        });
        html += '</div>';
        var earnedMilestones = mList.filter(function(m) { return cpInTree >= m.cp; });
        if (earnedMilestones.length > 0) {
          html += '<div class="milestones-earned">';
          earnedMilestones.forEach(function(m) {
            html += '<span class="milestone-badge">★ ' + m.label + ': ' + m.bonus + '</span>';
          });
          html += '</div>';
        } else {
          var nextMs = mList[0];
          html += '<div class="milestone-next">Next: ' + nextMs.label + ' at ' + nextMs.cp + ' CP — ' + nextMs.bonus + '</div>';
        }
        html += '</div>';
      }

      html += '<div class="cp-tree-abilities">';

      (tree.abilities || []).forEach(function(ability) {
        var purchased = char.purchasedAbilities.some(function(p) {
          return p.treeName === tree.name && p.abilityName === ability.name;
        });
        var effectiveCost = cpSys.getEffectiveCost(ability.cp_cost, tree.name, ability.tier);

        // Check prerequisites
        var canBuy = false;
        var lockReason = '';
        if (ability.tier === 1) {
          if (t2AtCap) { /* T1 is always buyable, no tier cap */ }
          canBuy = remainingCP >= effectiveCost || purchased;
        } else if (ability.tier === 2) {
          var hasTier1 = char.purchasedAbilities.some(function(p) {
            return p.treeName === tree.name && p.tier === 1;
          });
          if (t2AtCap) {
            lockReason = 'T2 cap reached (max 4 trees)';
          } else if (!hasTier1) {
            lockReason = 'Requires Tier 1 in ' + tree.name;
          } else if (remainingCP < effectiveCost && !purchased) {
            lockReason = 'Not enough CP';
          } else {
            canBuy = true;
          }
        } else if (ability.tier === 3) {
          var hasT2in = char.purchasedAbilities.some(function(p) {
            return p.treeName === tree.name && p.tier === 2;
          });
          if (t3AtCap) {
            lockReason = 'T3 cap reached (max 2 trees)';
          } else if (char.level < 5) {
            lockReason = 'Requires Level 5+';
          } else if (!hasT2in) {
            lockReason = 'Requires Tier 2 in ' + tree.name;
          } else if (remainingCP < effectiveCost && !purchased) {
            lockReason = 'Not enough CP';
          } else {
            canBuy = true;
          }
        } else if (ability.tier === 4) {
          var t3Count = char.purchasedAbilities.filter(function(p) {
            return p.treeName === tree.name && p.tier === 3;
          }).length;
          if (t4AtCap) {
            lockReason = 'Capstone cap reached (max 1 tree)';
          } else if (char.level < 10) {
            lockReason = 'Requires Level 10+';
          } else if (t3Count < 2) {
            lockReason = 'Requires 2+ Tier 3 abilities in ' + tree.name;
          } else if (remainingCP < effectiveCost && !purchased) {
            lockReason = 'Not enough CP';
          } else {
            canBuy = true;
          }
        } else if (ability.tier === 5) {
          var hasT4 = char.purchasedAbilities.some(function(p) {
            return p.treeName === tree.name && p.tier === 4;
          });
          if (char.level < 15) {
            lockReason = 'Requires Level 15+';
          } else if (!hasT4) {
            lockReason = 'Requires Capstone (Tier 4) in ' + tree.name;
          } else if (remainingCP < effectiveCost && !purchased) {
            lockReason = 'Not enough CP';
          } else {
            canBuy = true;
          }
        }

        var stateClass = purchased ? ' purchased' : (canBuy ? ' available' : ' locked');
        var costDisplay = effectiveCost + ' CP';
        var costBreakdown = '';
        var surchargeForAbility = (ability.tier === 5) ? 0 : cpSys.getBreadthSurcharge(treeRank);
        var discountForAbility = cpSys.getDepthDiscount(cpInTree);
        if (surchargeForAbility > 0 || discountForAbility > 0) {
          costBreakdown = ' <span class="cost-breakdown" title="Base: ' + ability.cp_cost + ' + surcharge: ' + surchargeForAbility + ' - discount: ' + discountForAbility + '">(base ' + ability.cp_cost + ')</span>';
        }

        html += '<button class="cp-ability' + stateClass + '" data-tree="' + tree.name + '" data-ability="' + ability.name + '" data-cost="' + ability.cp_cost + '" data-tier="' + ability.tier + '" data-effect="' + ability.effect.replace(/"/g, '&quot;') + '"' + (!canBuy && !purchased ? ' disabled' : '') + '>';
        html += '<div class="cp-ability-header">';
        html += '<span class="cp-ability-name">' + ability.name + '</span>';
        html += '<span class="cp-ability-cost">' + costDisplay + costBreakdown + '</span>';
        html += '</div>';
        html += '<div class="cp-ability-meta">';
        html += '<span class="cp-ability-tier">Tier ' + ability.tier + '</span>';
        html += '<span class="cp-ability-effect">' + ability.effect + '</span>';
        html += '</div>';
        if (lockReason) {
          html += '<div class="cp-lock-reason">' + lockReason + '</div>';
        }
        if (purchased) {
          html += '<div class="cp-purchased-badge">Purchased</div>';
        }
        html += '</button>';
      });

      html += '</div></div>';
    });

    // Proficiency upgrades section (SITE-053)
    var frame = getFrame();
    if (frame) {
      html += '<details class="config-section prof-upgrades-section">';
      html += '<summary class="config-section-header">Proficiency Upgrades <span class="step-desc">(CP purchase)</span></summary>';
      html += '<p class="step-desc">Spend CP to gain proficiencies beyond your chassis grants.</p>';
      html += '<div class="prof-upgrade-list">';
      PROFICIENCY_UPGRADES.forEach(function(u) {
        var alreadyHas = false;
        var name = u.name.toLowerCase();
        if (name.indexOf('medium') > -1 && (frame.armor_proficiency || []).some(function(p) { return p.toLowerCase().indexOf('medium') > -1; })) alreadyHas = true;
        if (name.indexOf('heavy') > -1 && (frame.armor_proficiency || []).some(function(p) { return p.toLowerCase().indexOf('heavy') > -1; })) alreadyHas = true;
        if (name.indexOf('shield') > -1 && (frame.armor_proficiency || []).some(function(p) { return p.toLowerCase().indexOf('shield') > -1; })) alreadyHas = true;
        var prereqMet = !u.requires || char.purchasedProfUpgrades[u.requires];
        var levelMet = !u.requires_level || (char.level || 1) >= u.requires_level;
        var purchased = char.purchasedProfUpgrades[u.name];
        if (alreadyHas) return; // skip what chassis already grants
        var canBuyProf = !purchased && prereqMet && levelMet && remainingCP >= u.cost;
        var profStateClass = purchased ? ' purchased' : (canBuyProf ? ' available' : ' locked');
        html += '<button class="cp-ability' + profStateClass + '" data-prof-upgrade="' + u.name + '" data-cost="' + u.cost + '"' + (!canBuyProf && !purchased ? ' disabled' : '') + '>';
        html += '<div class="cp-ability-header"><span class="cp-ability-name">' + u.name + '</span><span class="cp-ability-cost">' + u.cost + ' CP</span></div>';
        html += '<div class="cp-ability-meta"><span class="cp-ability-effect">' + u.description + '</span></div>';
        if (!prereqMet) html += '<div class="cp-lock-reason">Requires: ' + u.requires + '</div>';
        if (!levelMet) html += '<div class="cp-lock-reason">Requires Level ' + u.requires_level + '+</div>';
        if (purchased) html += '<div class="cp-purchased-badge">Purchased</div>';
        html += '</button>';
      });
      html += '</div></details>';
    }

    // Attribute Boosts section (SITE-072)
    {
      // Score before CP boosts (base attrs + ASI only) for cap enforcement
      var preBoostAttrs = {};
      ATTR_NAMES.forEach(function(at) { preBoostAttrs[at] = char.attributes[at] || 8; });
      Object.keys(char.selectedASIs).forEach(function(lv) {
        if (Number(lv) <= char.level) {
          var asi = char.selectedASIs[lv];
          if (asi.mode === '+2' && asi.attr1) preBoostAttrs[asi.attr1] = Math.min(20, preBoostAttrs[asi.attr1] + 2);
          if (asi.mode === '+1+1') {
            if (asi.attr1) preBoostAttrs[asi.attr1] = Math.min(20, preBoostAttrs[asi.attr1] + 1);
            if (asi.attr2) preBoostAttrs[asi.attr2] = Math.min(20, preBoostAttrs[asi.attr2] + 1);
          }
        }
      });

      html += '<details class="config-section attr-boosts-section">';
      html += '<summary class="config-section-header">Attribute Boosts <span class="step-desc">(CP purchase)</span></summary>';
      html += '<p class="step-desc">Spend 10 CP per +1 to any attribute. Maximum score: 20.</p>';
      html += '<div class="attr-boost-list">';
      ATTR_NAMES.forEach(function(attr) {
        var currentBoosts = char.purchasedAttrBoosts[attr] || 0;
        var baseScore = preBoostAttrs[attr];
        var totalScore = Math.min(20, baseScore + currentBoosts);
        var atCap = totalScore >= 20;
        var canAdd = !atCap && remainingCP >= 10;
        var canRemove = currentBoosts > 0;
        html += '<div class="attr-boost-row">';
        html += '<span class="attr-boost-name">' + attr + '</span>';
        html += '<span class="attr-boost-score">' + baseScore + (currentBoosts > 0 ? ' <span class="asi-delta">+' + currentBoosts + '</span> = ' + totalScore : '') + '</span>';
        html += '<button class="attr-boost-btn" data-attr-boost-minus="' + attr + '"' + (canRemove ? '' : ' disabled') + '>&minus;</button>';
        html += '<span class="attr-boost-count">' + currentBoosts + ' purchased</span>';
        html += '<button class="attr-boost-btn" data-attr-boost-plus="' + attr + '"' + (canAdd ? '' : ' disabled') + '>&plus; 10 CP</button>';
        if (atCap) html += '<span class="attr-boost-cap">At cap (20)</span>';
        html += '</div>';
      });
      html += '</div></details>';
    }

    // CP Skill Purchases section (SITE-073)
    {
      var isSpec = char.chassis && char.chassis.name === 'Specialist';
      var profCost = isSpec ? 1 : 2;
      var expertCost = isSpec ? 2 : 4;
      var advCost = isSpec ? 2 : 3;
      var maxAdv = isSpec ? 3 : 2;
      var profSkillsNow = getAllProficientSkills();
      var expertSkillsNow = getAllExpertiseSkills();

      html += '<details class="config-section cp-skill-section">';
      html += '<summary class="config-section-header">CP Skill Purchases <span class="step-desc">(CP purchase)</span></summary>';
      html += '<p class="step-desc">Buy additional skill proficiencies or upgrades with CP. Specialist chassis costs are in brackets.</p>';

      // Regular skill proficiencies and expertise
      html += '<div class="cp-skill-list">';
      GAME.skills.forEach(function(sk) {
        var isProf = !!profSkillsNow[sk.name];
        var isExpert = !!expertSkillsNow[sk.name];
        var cpProf = char.cpSkillProficiency.indexOf(sk.name) > -1;
        var cpExpert = char.cpSkillExpertise.indexOf(sk.name) > -1;

        if (!isExpert) {
          // Can buy expertise if already proficient (from any source)
          if (isProf) {
            var canBuyEx = !cpExpert && remainingCP >= expertCost;
            html += '<div class="cp-skill-row">';
            html += '<span class="cp-skill-name">' + sk.name + '</span>';
            if (cpExpert) {
              html += '<span class="cp-skill-purchased">Expertise purchased (' + expertCost + ' CP)</span>';
              html += '<button class="cp-skill-refund" data-cp-skill-expertise-refund="' + sk.name + '">Refund</button>';
            } else {
              html += '<button class="cp-skill-btn' + (canBuyEx ? '' : ' locked') + '" data-cp-skill-expertise="' + sk.name + '" data-cost="' + expertCost + '"' + (canBuyEx ? '' : ' disabled') + '>';
              html += 'Buy Expertise — ' + expertCost + ' CP [Spec: ' + (isSpec ? expertCost : 2) + ' CP]</button>';
            }
            html += '</div>';
          } else {
            // Not proficient — can buy proficiency
            var canBuyProf = !cpProf && remainingCP >= profCost;
            html += '<div class="cp-skill-row">';
            html += '<span class="cp-skill-name">' + sk.name + '</span>';
            if (cpProf) {
              html += '<span class="cp-skill-purchased">Proficiency purchased (' + profCost + ' CP)</span>';
              html += '<button class="cp-skill-refund" data-cp-skill-prof-refund="' + sk.name + '">Refund</button>';
              // Also offer expertise upgrade
              var canBuyExAfterProf = remainingCP >= expertCost;
              html += '<button class="cp-skill-btn' + (canBuyExAfterProf ? '' : ' locked') + '" data-cp-skill-expertise="' + sk.name + '" data-cost="' + expertCost + '"' + (canBuyExAfterProf ? '' : ' disabled') + '>';
              html += 'Also Buy Expertise — ' + expertCost + ' CP</button>';
            } else {
              html += '<button class="cp-skill-btn' + (canBuyProf ? '' : ' locked') + '" data-cp-skill-prof="' + sk.name + '" data-cost="' + profCost + '"' + (canBuyProf ? '' : ' disabled') + '>';
              html += 'Buy Proficiency — ' + profCost + ' CP [Spec: ' + (isSpec ? profCost : 1) + ' CP]</button>';
            }
            html += '</div>';
          }
        }
      });
      html += '</div>';

      // Advanced skill access (L3+)
      var ADVANCED_SKILLS = [
        { name: 'Hacking',       attr: 'INT',       prereq: 'Technology' },
        { name: 'Demolitions',   attr: 'INT',       prereq: 'Science' },
        { name: 'Forensics',     attr: 'INT',       prereq: 'Investigation' },
        { name: 'Xenology',      attr: 'INT or WIS', prereq: 'Arcana or Science' },
        { name: 'Pharmacology',  attr: 'WIS or INT', prereq: 'Medicine' },
        { name: 'Robotics',      attr: 'INT',       prereq: 'Technology' },
        { name: 'Tactics',       attr: 'INT or WIS', prereq: 'Perception or Survival' },
        { name: 'Scavenging',    attr: 'WIS',       prereq: 'Survival' },
        { name: 'Statecraft',    attr: 'PRE',       prereq: 'Persuasion or Deception' },
        { name: 'Tracking',      attr: 'WIS',       prereq: 'Survival' },
        { name: 'Interrogation', attr: 'PRE or WIS', prereq: 'Insight or Intimidation' },
      ];
      var advCount = char.cpAdvancedAccess.length;
      var levelMet = (char.level || 1) >= 3;
      html += '<h4 class="cp-skill-subheader">Advanced Skill Access (' + advCount + '/' + maxAdv + ', Level 3+)</h4>';
      html += '<div class="cp-skill-list">';
      ADVANCED_SKILLS.forEach(function(adv) {
        var already = char.cpAdvancedAccess.indexOf(adv.name) > -1;
        // Check prereq: any of the prereq skills must be proficient
        var prereqSkills = adv.prereq.split(' or ').map(function(s) { return s.trim(); });
        var prereqMet = prereqSkills.some(function(ps) { return !!profSkillsNow[ps]; });
        var atMax = advCount >= maxAdv && !already;
        var canBuy = levelMet && prereqMet && !already && !atMax && remainingCP >= advCost;
        html += '<div class="cp-skill-row">';
        html += '<span class="cp-skill-name">' + adv.name + ' <span class="cp-skill-attr">(' + adv.attr + ')</span></span>';
        if (already) {
          html += '<span class="cp-skill-purchased">Access purchased (' + advCost + ' CP)</span>';
          html += '<button class="cp-skill-refund" data-cp-adv-refund="' + adv.name + '">Refund</button>';
        } else {
          html += '<button class="cp-skill-btn' + (canBuy ? '' : ' locked') + '" data-cp-adv="' + adv.name + '" data-cost="' + advCost + '"' + (canBuy ? '' : ' disabled') + '>';
          html += 'Unlock — ' + advCost + ' CP';
          html += '</button>';
          if (!levelMet) html += '<span class="cp-lock-reason">Requires Level 3+</span>';
          else if (!prereqMet) html += '<span class="cp-lock-reason">Prereq: ' + adv.prereq + ' (proficient)</span>';
          else if (atMax) html += '<span class="cp-lock-reason">Max advanced skills reached (' + maxAdv + ')</span>';
        }
        html += '</div>';
      });
      html += '</div>';
      html += '</details>';
    }

    // CP Cantrip Purchase section (SITE-074)
    if (GAME.cantrips && GAME.cantrips.length > 0) {
      var cantripCost = getCantripCPCost();
      // All cantrips already known (from class or CP purchases)
      var knownCantrips = {};
      char.selectedCantrips.forEach(function(n) { knownCantrips[n] = true; });
      char.cpCantripPurchases.forEach(function(n) { knownCantrips[n] = true; });

      html += '<details class="config-section cantrip-cp-section">';
      html += '<summary class="config-section-header">Buy Cantrip <span class="step-desc">(CP purchase)</span></summary>';
      var cantripRateNote = cantripCost === 10 ? ' (reduced rate: Divine Channeling or Medicine Initiate+)' :
                             cantripCost === 12 ? ' (reduced rate: Leadership & Social Initiate+)' :
                             ' (default rate)';
      html += '<p class="step-desc">Any character can learn a cantrip for ' + cantripCost + ' CP' + cantripRateNote + '.</p>';
      html += '<div class="cp-skill-list">';
      GAME.cantrips.forEach(function(ct) {
        var alreadyKnown = !!knownCantrips[ct.name];
        var cpBought = char.cpCantripPurchases.indexOf(ct.name) > -1;
        var canBuy = !alreadyKnown && remainingCP >= cantripCost;
        html += '<div class="cp-skill-row">';
        html += '<span class="cp-skill-name">' + ct.name + '</span>';
        html += '<span class="cp-skill-attr" style="flex:1">' + (ct.effect || '') + (ct.range ? ' (' + ct.range + ')' : '') + '</span>';
        if (cpBought) {
          html += '<span class="cp-skill-purchased">Purchased (' + cantripCost + ' CP)</span>';
          html += '<button class="cp-skill-refund" data-cp-cantrip-refund="' + ct.name + '">Refund</button>';
        } else if (alreadyKnown) {
          html += '<span class="cp-skill-purchased">Already known</span>';
        } else {
          html += '<button class="cp-skill-btn' + (canBuy ? '' : ' locked') + '" data-cp-cantrip="' + ct.name + '" data-cost="' + cantripCost + '"' + (canBuy ? '' : ' disabled') + '>';
          html += 'Learn — ' + cantripCost + ' CP</button>';
        }
        html += '</div>';
      });
      html += '</div></details>';
    }

    panel.innerHTML = html;

    // Bind ability clicks
    $$('.cp-ability[data-tree]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var treeName = btn.getAttribute('data-tree');
        var abilityName = btn.getAttribute('data-ability');
        var cost = Number(btn.getAttribute('data-cost'));
        var tier = Number(btn.getAttribute('data-tier'));
        var effect = btn.getAttribute('data-effect');

        var existingIdx = -1;
        char.purchasedAbilities.forEach(function(p, i) {
          if (p.treeName === treeName && p.abilityName === abilityName) existingIdx = i;
        });

        if (existingIdx > -1) {
          // Check if higher tier in same tree depends on this
          var hasDependant = char.purchasedAbilities.some(function(p) {
            return p.treeName === treeName && p.tier > tier;
          });
          if (!hasDependant) {
            char.purchasedAbilities.splice(existingIdx, 1);
          }
        } else {
          // Use effective cost for budget check
          var cpSysNew = computeCPSystem();
          var effectiveCostNew = cpSysNew.getEffectiveCost(cost, treeName, tier);
          var remainingNew = getTotalCP() - cpSysNew.totalEffectiveSpent;
          if (remainingNew >= effectiveCostNew) {
            char.purchasedAbilities.push({
              treeName: treeName,
              abilityName: abilityName,
              cp_cost: cost,
              tier: tier,
              effect: effect
            });
          }
        }

        renderSkillTrees();
      });
    });

    // Bind proficiency upgrade clicks (SITE-053)
    $$('.cp-ability[data-prof-upgrade]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var upgradeName = btn.getAttribute('data-prof-upgrade');
        if (char.purchasedProfUpgrades[upgradeName]) {
          delete char.purchasedProfUpgrades[upgradeName];
        } else {
          var cpSysNew = computeCPSystem();
          var upgCost = Number(btn.getAttribute('data-cost'));
          var remainingNew = getTotalCP() - cpSysNew.totalEffectiveSpent;
          if (remainingNew >= upgCost) {
            char.purchasedProfUpgrades[upgradeName] = true;
          }
        }
        renderSkillTrees();
      });
    });

    // Bind attribute boost +/- clicks (SITE-072)
    $$('.attr-boost-btn[data-attr-boost-plus]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var attr = btn.getAttribute('data-attr-boost-plus');
        var cpSysNew = computeCPSystem();
        var remainingNew = getTotalCP() - cpSysNew.totalEffectiveSpent;
        var preBoost = (char.attributes[attr] || 8);
        // Apply ASI to get score before CP boosts
        Object.keys(char.selectedASIs).forEach(function(lv) {
          if (Number(lv) <= char.level) {
            var asi = char.selectedASIs[lv];
            if (asi.mode === '+2' && asi.attr1 === attr) preBoost = Math.min(20, preBoost + 2);
            if (asi.mode === '+1+1') {
              if (asi.attr1 === attr) preBoost = Math.min(20, preBoost + 1);
              if (asi.attr2 === attr) preBoost = Math.min(20, preBoost + 1);
            }
          }
        });
        var currentBoosts = char.purchasedAttrBoosts[attr] || 0;
        if (preBoost + currentBoosts < 20 && remainingNew >= 10) {
          char.purchasedAttrBoosts[attr] = currentBoosts + 1;
          renderSkillTrees();
        }
      });
    });

    $$('.attr-boost-btn[data-attr-boost-minus]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var attr = btn.getAttribute('data-attr-boost-minus');
        if ((char.purchasedAttrBoosts[attr] || 0) > 0) {
          char.purchasedAttrBoosts[attr]--;
          renderSkillTrees();
        }
      });
    });

    // Bind CP skill purchase clicks (SITE-073)
    $$('.cp-skill-btn[data-cp-skill-prof]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var skillName = btn.getAttribute('data-cp-skill-prof');
        var cost = Number(btn.getAttribute('data-cost'));
        var cpSysNew = computeCPSystem();
        var remNew = getTotalCP() - cpSysNew.totalEffectiveSpent;
        if (char.cpSkillProficiency.indexOf(skillName) === -1 && remNew >= cost) {
          char.cpSkillProficiency.push(skillName);
          renderSkillTrees();
        }
      });
    });

    $$('.cp-skill-refund[data-cp-skill-prof-refund]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var skillName = btn.getAttribute('data-cp-skill-prof-refund');
        var idx = char.cpSkillProficiency.indexOf(skillName);
        if (idx > -1) {
          char.cpSkillProficiency.splice(idx, 1);
          renderSkillTrees();
        }
      });
    });

    $$('.cp-skill-btn[data-cp-skill-expertise]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var skillName = btn.getAttribute('data-cp-skill-expertise');
        var cost = Number(btn.getAttribute('data-cost'));
        var cpSysNew = computeCPSystem();
        var remNew = getTotalCP() - cpSysNew.totalEffectiveSpent;
        if (char.cpSkillExpertise.indexOf(skillName) === -1 && remNew >= cost) {
          char.cpSkillExpertise.push(skillName);
          renderSkillTrees();
        }
      });
    });

    $$('.cp-skill-refund[data-cp-skill-expertise-refund]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var skillName = btn.getAttribute('data-cp-skill-expertise-refund');
        var idx = char.cpSkillExpertise.indexOf(skillName);
        if (idx > -1) {
          char.cpSkillExpertise.splice(idx, 1);
          renderSkillTrees();
        }
      });
    });

    $$('.cp-skill-btn[data-cp-adv]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var advName = btn.getAttribute('data-cp-adv');
        var cost = Number(btn.getAttribute('data-cost'));
        var cpSysNew = computeCPSystem();
        var remNew = getTotalCP() - cpSysNew.totalEffectiveSpent;
        var isSpecNow = char.chassis && char.chassis.name === 'Specialist';
        var maxAdvNow = isSpecNow ? 3 : 2;
        if (char.cpAdvancedAccess.indexOf(advName) === -1 && char.cpAdvancedAccess.length < maxAdvNow && remNew >= cost) {
          char.cpAdvancedAccess.push(advName);
          renderSkillTrees();
        }
      });
    });

    $$('.cp-skill-refund[data-cp-adv-refund]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var advName = btn.getAttribute('data-cp-adv-refund');
        var idx = char.cpAdvancedAccess.indexOf(advName);
        if (idx > -1) {
          char.cpAdvancedAccess.splice(idx, 1);
          renderSkillTrees();
        }
      });
    });

    // Bind CP cantrip purchase clicks (SITE-074)
    $$('.cp-skill-btn[data-cp-cantrip]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cantripName = btn.getAttribute('data-cp-cantrip');
        var cost = Number(btn.getAttribute('data-cost'));
        var cpSysNew = computeCPSystem();
        var remNew = getTotalCP() - cpSysNew.totalEffectiveSpent;
        if (char.cpCantripPurchases.indexOf(cantripName) === -1 && remNew >= cost) {
          char.cpCantripPurchases.push(cantripName);
          renderSkillTrees();
        }
      });
    });

    $$('.cp-skill-refund[data-cp-cantrip-refund]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var cantripName = btn.getAttribute('data-cp-cantrip-refund');
