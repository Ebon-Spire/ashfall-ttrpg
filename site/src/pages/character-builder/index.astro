---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { loadGameData } from '../../lib/loadGameData';

const gameData = loadGameData();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Character Builder">
  <main class="builder-page">
    <div class="builder-container">

      <!-- Progress breadcrumb -->
      <div class="progress-crumbs" id="progress-crumbs"></div>

      <!-- Step indicators -->
      <nav class="step-nav" id="step-nav">
        <button class="step-tab active" data-step="0">Identity</button>
        <button class="step-tab" data-step="1">Class</button>
        <button class="step-tab" data-step="2">Build</button>
        <button class="step-tab" data-step="3">Equipment</button>
        <button class="step-tab" data-step="4">Summary</button>
      </nav>

      <!-- Step panels -->
      <div id="builder-app">

        <!-- Step 0: Identity (Species + Background) -->
        <section class="step-panel active" data-panel="0">
          <h2>Who Are You?</h2>

          <details class="config-section" open>
            <summary class="config-section-header">Species</summary>
            <p class="step-desc">Each species provides unique attribute bonuses and traits that shape your survivor.</p>
            <div class="card-grid" id="species-grid"></div>
            <div id="species-detail" class="detail-box hidden"></div>
          </details>

          <details class="config-section" id="background-section">
            <summary class="config-section-header">Background</summary>
            <p class="step-desc">Your background determines the skills and experiences you bring from before your adventures.</p>
            <div class="card-grid" id="background-grid"></div>
            <div id="background-detail" class="detail-box hidden"></div>
          </details>
        </section>

        <!-- Step 1: Class + Level -->
        <section class="step-panel" data-panel="1">
          <h2>Choose Your Archetype</h2>
          <p class="step-desc">Your archetype defines your combat role, abilities, and skill trees.</p>
          <div class="card-grid" id="class-grid"></div>
          <div id="class-detail" class="detail-box hidden"></div>

          <div class="level-selector" id="class-level-selector" style="display:none">
            <label>Character Level</label>
            <div class="level-slider-row">
              <input type="range" id="level-slider" min="1" max="20" value="1" />
              <span class="level-display" id="level-display">1</span>
            </div>
          </div>
        </section>

        <!-- Step 2: Build (Attributes + Proficiencies + Abilities + Progression) -->
        <section class="step-panel" data-panel="2">
          <h2>Build Your Character</h2>

          <!-- Collapsible: Attributes -->
          <details class="config-section" open>
            <summary class="config-section-header">Attributes</summary>
            <div class="method-selector">
              <button class="method-btn active" data-method="standard">Standard Array</button>
              <button class="method-btn" data-method="pointbuy">Point Buy</button>
              <button class="method-btn" data-method="manual">Manual</button>
            </div>
            <p class="step-desc" id="attr-desc">Drag values from the pool to assign them to attributes.</p>
            <div class="attr-layout">
              <div class="attr-pool" id="attr-pool"></div>
              <div class="attr-assignments" id="attr-assignments"></div>
            </div>
            <div class="derived-preview" id="derived-preview"></div>
          </details>

          <!-- Collapsible: Proficiencies -->
          <details class="config-section">
            <summary class="config-section-header">Skill Proficiencies</summary>
            <p class="step-desc">Your class and background grant fixed proficiencies. Choose <strong id="prof-pick-count">2</strong> additional skills.</p>
            <div id="prof-picks-remaining" class="ap-budget"></div>
            <div id="skills-list" class="skills-grid"></div>
          </details>

          <!-- Collapsible: Abilities -->
          <details class="config-section">
            <summary class="config-section-header">Advancement Points</summary>
            <p class="step-desc">Spend AP on class abilities. Tier 2 requires Tier 1 in the same tree. Tier 3 requires Level 5+.</p>
            <div id="ap-budget" class="ap-budget"></div>
            <div id="skill-trees-panel" class="skill-trees-panel"></div>
          </details>

          <!-- Collapsible: Progression -->
          <details class="config-section">
            <summary class="config-section-header">Level Progression</summary>
            <p class="step-desc">Milestone choices at each level. Every level grants 10 AP.</p>
            <div id="progression-timeline" class="progression-timeline"></div>
          </details>
        </section>

        <!-- Step 3: Equipment -->
        <section class="step-panel" data-panel="3">
          <h2>Starting Equipment</h2>
          <p class="step-desc">Your archetype provides a free starting package. Review your gear below.</p>
          <div id="equipment-panel" class="equipment-layout"></div>
        </section>

        <!-- Step 4: Summary -->
        <section class="step-panel" data-panel="4">
          <h2>Character Summary</h2>
          <div id="summary-sheet" class="summary-sheet"></div>
          <div class="summary-actions">
            <button class="btn-primary" id="export-text-btn">Copy as Text</button>
            <button class="btn-primary" id="export-pdf-btn">Download PDF</button>
          </div>
        </section>

      </div>

      <!-- Navigation buttons -->
      <div class="step-buttons">
        <button class="btn-secondary" id="prev-btn" disabled>Back</button>
        <button class="btn-primary" id="next-btn">Next</button>
      </div>

    </div>
  </main>
</BaseLayout>

<!-- Inject game data -->
<script type="application/json" id="game-data" set:html={JSON.stringify(gameData)} />

<script>
  // ========================================
  // Ashfall Character Builder — Client Logic
  // ========================================

  const GAME = JSON.parse(document.getElementById('game-data').textContent);
  const STEPS = 5;
  let currentStep = 0;

  // Proficiency bonus by level
  function getProfBonus(level) {
    if (level <= 4) return 2;
    if (level <= 8) return 3;
    if (level <= 12) return 4;
    if (level <= 16) return 5;
    return 6;
  }

  // Character state
  const char = {
    species: null,
    speciesChoices: {},
    background: null,
    class: null,
    method: 'standard',
    attributes: { MIG: 0, AGI: 0, END: 0, INT: 0, WIS: 0, PRE: 0 },
    assignedPool: [],
    pointBuyScores: { MIG: 8, AGI: 8, END: 8, INT: 8, WIS: 8, PRE: 8 },
    skills: [],
    chosenProficiencies: [], // player-chosen skill proficiency names
    expertiseSkills: [],     // skill names upgraded to Expert tier
    purchasedAbilities: [],  // [{treeName, abilityName, ap_cost, tier, effect}]
    featureChoices: {},      // {featureName: choiceName}
    selectedSpecialization: null, // specialization name string
    startingCredits: 70,     // 2d6 x 10 credits (default to average)
    selectedWeapons: [],     // weapon objects from equipment catalog
    selectedArmor: null,     // armor object
    selectedShield: null,    // shield object
    selectedAugments: [],    // augment objects from equipment catalog
    selectedCantrips: [],    // cantrip names for caster classes
    selectedDoctrine: null,  // {name, effect} from L1 doctrines
    name: '',
    // Progression (levels 2-20)
    level: 1,                    // current character level
    selectedDoctrine2: null,     // L6 doctrine {name, effect}
    selectedTalents: {},         // {level: {name, effect, enhances?, ...}}
    selectedASIs: {},            // {level: {attr1: name, attr2: name|null, mode: '+2'/'+1+1'}}
    selectedMasteryPath: null,   // mastery path object from GAME.mastery_paths
    multiclassLevels: {},        // {level: className} for even-level multiclass picks
    progressionProfPicks: {},    // {level: skillName} for free proficiency picks at L3/8/15 (and L5/10 for Operatives)
    progressionExpertise: {},    // {level: skillName} for free expertise at L6/12 (Operative only)
  };

  // ---- Utility ----
  function getMod(score) {
    return Math.floor((score - 10) / 2);
  }

  function modStr(m) {
    return m >= 0 ? '+' + m : '' + m;
  }

  function el(id) {
    return document.getElementById(id);
  }

  function $$(sel, parent) {
    return Array.from((parent || document).querySelectorAll(sel));
  }

  // ---- Step navigation ----
  const tabs = $$('.step-tab');
  const panels = $$('.step-panel');
  const prevBtn = el('prev-btn');
  const nextBtn = el('next-btn');

  function isStepValid(step) {
    if (step === 0) return !!char.species && !!char.background;
    if (step === 1) return !!char.class;
    return true;
  }

  function updateNextBtn() {
    var valid = isStepValid(currentStep);
    if (currentStep === STEPS - 1) {
      nextBtn.textContent = 'Done';
      nextBtn.disabled = false;
    } else {
      nextBtn.textContent = 'Next';
      nextBtn.disabled = !valid;
    }
  }

  function updateBreadcrumbs() {
    var crumbs = [];
    if (char.species) crumbs.push(char.species.name);
    if (char.background) crumbs.push(char.background.name);
    if (char.class) crumbs.push(char.class.name + ' L' + char.level);
    var crumbEl = el('progress-crumbs');
    if (crumbs.length === 0) {
      crumbEl.classList.add('hidden');
    } else {
      crumbEl.classList.remove('hidden');
      crumbEl.innerHTML = crumbs.map(function(c) { return '<span class="crumb">' + c + '</span>'; }).join('<span class="crumb-sep">/</span>');
    }
  }

  function goToStep(step) {
    if (step < 0 || step >= STEPS) return;
    var oldStep = currentStep;
    currentStep = step;
    tabs.forEach(function(t, i) {
      t.classList.toggle('active', i === step);
      t.classList.toggle('completed', i < step);
    });

    // Animate panel transition
    panels.forEach(function(p, i) {
      if (i === step) {
        p.classList.add('active');
        p.style.animation = 'panelFadeIn 0.25s ease-out';
      } else {
        p.classList.remove('active');
        p.style.animation = '';
      }
    });

    prevBtn.disabled = step === 0;
    updateNextBtn();
    updateBreadcrumbs();

    // Scroll to top of builder
    el('step-nav').scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    // Render current step
    if (step === 1) renderClassStep();
    if (step === 2) renderBuild();
    if (step === 3) renderEquipment();
    if (step === 4) renderSummary();
  }

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = Number(tab.getAttribute('data-step'));
      // Validate all prior steps before allowing forward jumps
      if (target > currentStep) {
        for (var s = 0; s < target; s++) {
          if (!isStepValid(s)) return;
        }
      }
      goToStep(target);
    });
  });

  prevBtn.addEventListener('click', function() { goToStep(currentStep - 1); });
  nextBtn.addEventListener('click', function() {
    if (currentStep === STEPS - 1) {
      // Finish: scroll to export buttons
      var actions = document.querySelector('.summary-actions');
      if (actions) actions.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    if (isStepValid(currentStep)) goToStep(currentStep + 1);
  });

  // ---- Step 0: Species ----
  function renderSpecies() {
    var grid = el('species-grid');
    grid.innerHTML = '';
    GAME.species.forEach(function(sp, i) {
      var card = document.createElement('button');
      card.className = 'select-card';
      card.innerHTML = '<h3>' + sp.name + '</h3><span class="card-sub">' + sp.attribute_bonus + '</span>';
      card.addEventListener('click', function() { selectSpecies(i); });
      grid.appendChild(card);
    });
  }

  function selectSpecies(idx) {
    char.species = GAME.species[idx];
    char.speciesChoices = {};
    $$('.select-card', el('species-grid')).forEach(function(c, i) {
      c.classList.toggle('selected', i === idx);
    });
    updateNextBtn();
    updateBreadcrumbs();
    var sp = char.species;
    var detail = el('species-detail');
    detail.classList.remove('hidden');
    // Smooth scroll to detail
    setTimeout(function() { detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 50);
    var html = '<h3>' + sp.name + '</h3><p class="detail-bonus">' + sp.attribute_bonus + '</p><ul>';
    sp.traits.forEach(function(t) {
      html += '<li><strong>' + t.name + ':</strong> ' + t.effect;
      if (t.choices && t.choices.length) {
        html += '<div class="choice-row" data-trait="' + t.name + '">';
        t.choices.forEach(function(c) {
          html += '<button class="choice-btn" data-choice="' + c + '">' + c + '</button>';
        });
        html += '</div>';
      }
      html += '</li>';
    });
    html += '</ul>';
    detail.innerHTML = html;

    $$('.choice-btn', detail).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var trait = btn.parentElement.getAttribute('data-trait');
        char.speciesChoices[trait] = btn.getAttribute('data-choice');
        $$('.choice-btn', btn.parentElement).forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');
      });
    });

    // Auto-open Background section and scroll to it
    var bgSection = el('background-section');
    if (bgSection) {
      bgSection.open = true;
      setTimeout(function() { bgSection.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 100);
    }
  }

  // ---- Background ----
  function renderBackgrounds() {
    var grid = el('background-grid');
    grid.innerHTML = '';
    GAME.backgrounds.forEach(function(bg, i) {
      var card = document.createElement('button');
      card.className = 'select-card';
      card.innerHTML = '<h3>' + bg.name + '</h3><span class="card-sub">' + bg.skill_bonus + '</span>';
      card.addEventListener('click', function() { selectBackground(i); });
      grid.appendChild(card);
    });
  }

  function selectBackground(idx) {
    char.background = GAME.backgrounds[idx];
    $$('.select-card', el('background-grid')).forEach(function(c, i) {
      c.classList.toggle('selected', i === idx);
    });
    updateNextBtn();
    updateBreadcrumbs();
    var bg = char.background;
    var detail = el('background-detail');
    detail.classList.remove('hidden');
    detail.innerHTML = '<h3>' + bg.name + '</h3>' +
      '<p class="detail-bonus">' + bg.skill_bonus + '</p>' +
      '<p class="detail-feature"><strong>Feature:</strong> ' + bg.feature + '</p>';
    setTimeout(function() { detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 50);
  }

  // ---- Step 2: Class ----
  function renderClasses() {
    var grid = el('class-grid');
    grid.innerHTML = '';
    GAME.classes.forEach(function(cls, i) {
      var card = document.createElement('button');
      card.className = 'select-card';
      card.innerHTML = '<h3>' + cls.name + '</h3>' +
        '<span class="card-sub">' + cls.role + '</span>' +
        '<span class="card-tag">' + cls.hit_die + '</span>';
      card.addEventListener('click', function() { selectClass(i); });
      grid.appendChild(card);
    });
  }

  function selectClass(idx) {
    char.class = GAME.classes[idx];
    // Reset purchased abilities and feature choices when class changes
    char.purchasedAbilities = [];
    char.featureChoices = {};
    char.selectedSpecialization = null;
    char.selectedAugments = [];
    char.selectedCantrips = [];
    char.selectedDoctrine = null;
    char.selectedDoctrine2 = null;
    char.selectedTalents = {};
    char.selectedASIs = {};
    char.selectedMasteryPath = null;
    char.multiclassLevels = {};
    char.progressionProfPicks = {};
    char.progressionExpertise = {};
    $$('.select-card', el('class-grid')).forEach(function(c, i) {
      c.classList.toggle('selected', i === idx);
    });
    updateNextBtn();
    updateBreadcrumbs();
    var cls = char.class;
    var detail = el('class-detail');
    detail.classList.remove('hidden');
    var html = '<h3>' + cls.name + ' <span class="tag">' + cls.hit_die + '</span></h3>' +
      '<div class="class-stats">' +
      '<div class="stat-row"><span class="stat-label">Role</span><span>' + cls.role + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Primary</span><span>' + (cls.primary_stats || []).join(', ') + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">HP at L1</span><span>' + cls.hp_base + ' + END mod</span></div>' +
      '<div class="stat-row"><span class="stat-label">Saves</span><span>' + (cls.save_proficiencies || []).join(', ') + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Armor</span><span>' + (cls.armor_proficiency || []).join(', ') + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Weapons</span><span>' + (cls.weapon_proficiency || []).join(', ') + '</span></div>' +
      '<div class="stat-row"><span class="stat-label">Magic</span><span>' + cls.magic_type + '</span></div>' +
      '</div>';

    // Full feature descriptions (sorted by level)
    html += '<h4>Class Features</h4>';
    (cls.features || []).slice().sort(function(a, b) { return (a.level || 0) - (b.level || 0); }).forEach(function(f) {
      var levelLabel = f.level <= 1 ? '' : ' <span class="feature-level">L' + f.level + '</span>';
      html += '<div class="feature-block">' +
        '<div class="feature-header">' +
        '<span class="feature-name">' + f.name + levelLabel + '</span>' +
        '<span class="feature-meta">' + f.action + ' | ' + f.frequency + '</span>' +
        '</div>' +
        '<p class="feature-desc">' + f.description + '</p>';
      if (f.choices && f.choices.length) {
        html += '<div class="feature-choices" data-feature="' + f.name + '">';
        f.choices.forEach(function(c) {
          var isSelected = char.featureChoices[f.name] === c.name;
          html += '<button class="feature-choice-btn' + (isSelected ? ' selected' : '') + '" data-feature="' + f.name + '" data-choice="' + c.name + '">' +
            '<strong>' + c.name + '</strong><span>' + c.effect + '</span></button>';
        });
        html += '</div>';
      }
      html += '</div>';
    });

    // Spell slots for casters
    if (cls.spell_slots && cls.spell_slots.length) {
      var slotEntry = getSpellSlotEntry(cls);
      html += '<h4>Spell Slots (Level ' + char.level + ')</h4><div class="spell-slot-display">';
      (slotEntry.slots || []).forEach(function(count, i) {
        if (count > 0) {
          html += '<span class="slot-badge">' + count + ' x ' + ordinal(i + 1) + '-level</span>';
        }
      });
      var cantripsAtLevel = getCantripsForLevel(cls);
      if (cantripsAtLevel) {
        html += '<span class="slot-badge cantrip-badge">' + cantripsAtLevel + ' Cantrips</span>';
      }
      html += '</div>';
    }

    // Doctrine selection (L1)
    var doctrineData = GAME.doctrines && GAME.doctrines[cls.name];
    if (doctrineData && doctrineData.level_1 && doctrineData.level_1.length) {
      html += '<h4>Level 1 Doctrine <span class="feature-meta">Choose one combat orientation</span></h4>';
      html += '<div class="doctrine-grid">';
      doctrineData.level_1.forEach(function(d) {
        var isSelected = char.selectedDoctrine && char.selectedDoctrine.name === d.name;
        html += '<button class="doctrine-btn' + (isSelected ? ' selected' : '') + '" data-doctrine="' + d.name + '">' +
          '<strong>' + d.name + '</strong><span>' + d.effect + '</span></button>';
      });
      html += '</div>';
    }

    // Talent preview (L2, 4, 7, 9, 12, 14)
    var classTalents = GAME.class_talents && GAME.class_talents[cls.name];
    if (classTalents && classTalents.length) {
      html += '<details class="ref-panel"><summary><h4>Class Talents <span class="feature-meta">Available at L2, 4, 7, 9, 12, 14</span></h4></summary>';
      html += '<div class="talent-list">';
      classTalents.forEach(function(t) {
        html += '<div class="talent-item"><strong>' + t.name + '</strong>' +
          '<span class="talent-enhances">Enhances: ' + t.enhances + '</span>' +
          '<span class="talent-effect">' + t.effect + '</span>' +
          (t.requires ? '<span class="talent-requires">Requires: ' + t.requires + '</span>' : '') +
          '</div>';
      });
      html += '</div></details>';
    }

    // Specialization previews (L6+)
    html += '<h4>Specializations (L6+)</h4>';
    (cls.specialization_details || []).forEach(function(spec) {
      html += '<div class="spec-preview">' +
        '<div class="spec-header"><strong>' + spec.name + '</strong><span class="spec-role">' + spec.role + '</span></div>' +
        '<div class="spec-features">' +
        (spec.features || []).map(function(sf) {
          return '<span class="spec-feature-tag">L' + sf.level + ': ' + sf.name + '</span>';
        }).join('') +
        '</div></div>';
    });

    // Level 6 Doctrine preview
    if (doctrineData && doctrineData.level_6 && doctrineData.level_6.length) {
      html += '<h4>Level 6 Doctrines <span class="feature-meta">Preview — chosen at L6</span></h4>';
      html += '<div class="doctrine-preview">';
      doctrineData.level_6.forEach(function(d) {
        html += '<div class="preview-item"><strong>' + d.name + '</strong><span>' + d.effect + '</span></div>';
      });
      html += '</div>';
    }

    // Universal Talents preview
    if (GAME.universal_talents) {
      html += '<details class="ref-panel"><summary><h4>Universal Talents <span class="feature-meta">Available to all classes</span></h4></summary>';
      html += '<div class="talent-list">';
      ['combat', 'exploration', 'skill'].forEach(function(cat) {
        var talents = GAME.universal_talents[cat] || [];
        if (talents.length) {
          html += '<h5>' + cat.charAt(0).toUpperCase() + cat.slice(1) + '</h5>';
          talents.forEach(function(t) {
            html += '<div class="talent-item"><strong>' + t.name + '</strong>' +
              '<span class="talent-effect">' + t.effect + '</span></div>';
          });
        }
      });
      html += '</div></details>';
    }

    // Mastery Paths preview
    if (GAME.mastery_paths && GAME.mastery_paths.length) {
      html += '<details class="ref-panel"><summary><h4>Mastery Paths <span class="feature-meta">Available at L11+ — 12 cross-archetype paths</span></h4></summary>';
      html += '<div class="mastery-list">';
      GAME.mastery_paths.forEach(function(mp) {
        html += '<div class="mastery-item">' +
          '<div class="mastery-header"><strong>' + mp.name + '</strong><span class="mastery-stats">' + mp.stats + '</span></div>' +
          '<span class="mastery-narrative">' + mp.narrative + '</span>' +
          '<div class="mastery-features">' +
          '<span class="mastery-feature-tag">L11: ' + (mp.features_11 || []).join(', ') + '</span>' +
          '<span class="mastery-feature-tag">L13: ' + (mp.features_13 || []).join(', ') + '</span>' +
          '<span class="mastery-feature-tag">L15: ' + mp.capstone_15 + '</span>' +
          '</div></div>';
      });
      html += '</div></details>';
    }

    // Multiclassing reference
    if (GAME.multiclass_requirements && GAME.multiclass_requirements.length) {
      html += '<details class="ref-panel"><summary><h4>Multiclassing <span class="feature-meta">Requirements for each archetype</span></h4></summary>';
      html += '<div class="multiclass-list">';
      html += '<p class="ref-note">Multiclass at even levels (2, 4, 8, 10, ...). Max 3 archetypes total. Must have 13+ in primary attribute of both current and target class.</p>';
      GAME.multiclass_requirements.forEach(function(mc) {
        var isCurrent = mc.archetype === cls.name;
        html += '<div class="multiclass-item' + (isCurrent ? ' current' : '') + '">' +
          '<strong>' + mc.archetype + '</strong><span>' + mc.stat + '</span></div>';
      });
      html += '</div></details>';
    }

    // Cross-Training reference
    if (GAME.cross_training) {
      var ct = GAME.cross_training;
      html += '<details class="ref-panel"><summary><h4>Cross-Training <span class="feature-meta">Learn abilities from other archetypes at 1.5x AP cost</span></h4></summary>';
      html += '<div class="cross-training-info">';
      html += '<p class="ref-note">Max ' + ct.max_other_archetypes + ' other archetypes. Must buy ' + ct.lock_in_threshold + ' abilities before opening a second.</p>';
      html += '<table class="ref-table"><thead><tr><th>Tier</th><th>Normal AP</th><th>Cross-Training AP</th></tr></thead><tbody>';
      (ct.tier_costs || []).forEach(function(tc) {
        html += '<tr><td>Tier ' + tc.tier + '</td><td>' + tc.normal + ' AP</td><td>' + tc.cross + ' AP</td></tr>';
      });
      html += '</tbody></table>';
      html += '</div></details>';
    }

    detail.innerHTML = html;

    // Bind feature choice buttons
    $$('.feature-choice-btn', detail).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var featureName = btn.getAttribute('data-feature');
        var choiceName = btn.getAttribute('data-choice');
        char.featureChoices[featureName] = choiceName;
        $$('.feature-choice-btn[data-feature="' + featureName + '"]', detail).forEach(function(b) {
          b.classList.toggle('selected', b.getAttribute('data-choice') === choiceName);
        });
      });
    });

    // Bind doctrine buttons
    $$('.doctrine-btn', detail).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var dName = btn.getAttribute('data-doctrine');
        var docData = doctrineData.level_1.find(function(d) { return d.name === dName; });
        char.selectedDoctrine = docData || null;
        $$('.doctrine-btn', detail).forEach(function(b) {
          b.classList.toggle('selected', b.getAttribute('data-doctrine') === dName);
        });
      });
    });

    renderClassStep();
    setTimeout(function() { detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }, 50);
  }

  function ordinal(n) {
    var s = ['th', 'st', 'nd', 'rd'];
    var v = n % 100;
    return n + (s[(v - 20) % 10] || s[v] || s[0]);
  }

  // Determine armor type and AGI cap for DV calculation
  function getArmorAgiCap(armor) {
    if (!armor) return 99; // no cap without armor
    var eq = GAME.equipment;
    if ((eq.light_armor || []).some(function(a) { return a.name === armor.name; })) return 5;
    if ((eq.medium_armor || []).some(function(a) { return a.name === armor.name; })) return 3;
    if ((eq.heavy_armor || []).some(function(a) { return a.name === armor.name; })) return 1;
    return 99;
  }

  function calcDV(agiMod, armor, shield) {
    var cap = getArmorAgiCap(armor);
    var effectiveAgi = Math.min(agiMod, cap);
    return 10 + effectiveAgi + (armor ? armor.dv_bonus : 0) + (shield ? shield.dv_bonus : 0);
  }

  function calcHumanity(cls) {
    var base = cls ? cls.starting_humanity : GAME.base_humanity;
    var augCost = char.selectedAugments.reduce(function(sum, a) { return sum + a.humanity_cost; }, 0);
    return Math.max(0, base - augCost);
  }

  function getHumanitySpent() {
    return char.selectedAugments.reduce(function(sum, a) { return sum + a.humanity_cost; }, 0);
  }

  // Look up the spell slot entry for the character's current level.
  // Returns the highest-level entry whose level <= char.level, or the first entry.
  function getSpellSlotEntry(cls) {
    if (!cls || !cls.spell_slots || !cls.spell_slots.length) return null;
    var entry = cls.spell_slots[0];
    for (var i = 0; i < cls.spell_slots.length; i++) {
      if (cls.spell_slots[i].level <= char.level) entry = cls.spell_slots[i];
    }
    return entry;
  }

  // Get the starting cantrip count for the character's current level.
  // Cantrip count scales with level for casters (encoded in the spell_slots data).
  function getCantripsForLevel(cls) {
    if (!cls || !cls.starting_cantrips) return 0;
    // If the class data has a cantrips_by_level array, use it; otherwise use starting_cantrips
    if (cls.cantrips_by_level) {
      var cantrips = cls.starting_cantrips;
      for (var i = 0; i < cls.cantrips_by_level.length; i++) {
        if (cls.cantrips_by_level[i].level <= char.level) cantrips = cls.cantrips_by_level[i].count;
      }
      return cantrips;
    }
    return cls.starting_cantrips;
  }

  // Spell slot tiers lost due to humanity spent on augmentations.
  // Each point of humanity spent removes the highest remaining spell tier (from 9th down).
  // The 10th point spent (humanity reaches 0) also removes cantrips.
  function getSpellSlotsAfterHumanity(cls) {
    var entry = getSpellSlotEntry(cls);
    if (!entry) return { slots: [], cantrips: 0 };
    var humSpent = getHumanitySpent();
    var baseSlots = (entry.slots || []).slice(); // clone array
    var cantrips = getCantripsForLevel(cls);

    // Remove spell tiers from highest (index 8 = 9th-level) down
    // Each humanity point spent removes one tier from the top
    var tiersToRemove = humSpent;
    for (var tier = baseSlots.length - 1; tier >= 0 && tiersToRemove > 0; tier--) {
      if (baseSlots[tier] > 0) {
        baseSlots[tier] = 0;
        tiersToRemove--;
      }
    }

    // If all spell tiers are removed and there are still points to "spend",
    // the last point removes cantrips
    if (tiersToRemove > 0) {
      cantrips = 0;
    }

    return { slots: baseSlots, cantrips: cantrips };
  }

  // ---- Step 3: Attributes ----
  function renderAttributes() {
    var method = char.method;
    if (method === 'standard') renderStandardArray();
    else if (method === 'pointbuy') renderPointBuy();
    else renderManualInput();
    updateDerived();
  }

  $$('.method-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      char.method = btn.getAttribute('data-method');
      $$('.method-btn').forEach(function(b) { b.classList.toggle('active', b === btn); });
      renderAttributes();
    });
  });

  var selectedValue = null;
  var usedValues = [];

  function renderStandardArray() {
    el('attr-desc').textContent = 'Click a value from the pool, then click an attribute to assign it.';
    var pool = el('attr-pool');
    var assignments = el('attr-assignments');

    function render() {
      // Track which array positions are used (preserves order and duplicates)
      var usedCopy = usedValues.slice();
      var poolItems = GAME.standard_array.map(function(v) {
        var idx = usedCopy.indexOf(v);
        if (idx > -1) {
          usedCopy.splice(idx, 1);
          return { value: v, used: true };
        }
        return { value: v, used: false };
      });

      pool.innerHTML = '<h4>Available Values</h4><div class="pool-values">' +
        poolItems.map(function(item) {
          if (item.used) {
            return '<span class="pool-btn used"></span>';
          }
          return '<button class="pool-btn' + (selectedValue === item.value ? ' selected' : '') + '" data-val="' + item.value + '">' + item.value + '</button>';
        }).join('') + '</div>';

      assignments.innerHTML = GAME.attributes.map(function(attr) {
        var score = char.attributes[attr] || 0;
        var mod = score ? getMod(score) : 0;
        var name = (GAME.attribute_names && GAME.attribute_names[attr]) || attr;
        var rowClass = 'attr-row';
        if (score) rowClass += ' filled';
        else if (selectedValue !== null) rowClass += ' assignable';
        return '<div class="' + rowClass + '" data-attr="' + attr + '">' +
          '<span class="attr-name">' + attr + '</span>' +
          '<span class="attr-full-name">' + name + '</span>' +
          '<span class="attr-score' + (score ? '' : ' empty') + '">' + (score || '\u2014') + '</span>' +
          '<span class="attr-mod">' + (score ? modStr(mod) : '') + '</span>' +
          '<span class="attr-actions">' + (score ? '<button class="attr-clear" data-attr="' + attr + '">x</button>' : '') + '</span>' +
          '</div>';
      }).join('');

      $$('.pool-btn', pool).forEach(function(btn) {
        btn.addEventListener('click', function() {
          selectedValue = Number(btn.getAttribute('data-val'));
          render();
        });
      });

      $$('.attr-row', assignments).forEach(function(row) {
        row.addEventListener('click', function(e) {
          if (e.target.classList.contains('attr-clear')) return;
          var attr = row.getAttribute('data-attr');
          if (selectedValue !== null && !char.attributes[attr]) {
            char.attributes[attr] = selectedValue;
            usedValues.push(selectedValue);
            selectedValue = null;
            render();
            updateDerived();
            updateNextBtn();
          }
        });
      });

      $$('.attr-clear', assignments).forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var attr = btn.getAttribute('data-attr');
          var val = char.attributes[attr];
          if (val) {
            var idx = usedValues.indexOf(val);
            if (idx > -1) usedValues.splice(idx, 1);
            char.attributes[attr] = 0;
            render();
            updateDerived();
            updateNextBtn();
          }
        });
      });
    }

    render();
  }

  function renderPointBuy() {
    el('attr-desc').textContent = 'You have ' + GAME.point_buy_points + ' points. Increase or decrease each attribute (min 8, max 15).';
    var pool = el('attr-pool');
    var assignments = el('attr-assignments');

    function getPointCost(score) {
      var entry = GAME.point_buy_costs.find(function(e) { return e.score === score; });
      return entry ? entry.cost : 0;
    }

    function totalSpent() {
      return GAME.attributes.reduce(function(sum, attr) {
        return sum + getPointCost(char.pointBuyScores[attr] || 8);
      }, 0);
    }

    function render() {
      var spent = totalSpent();
      var remaining = GAME.point_buy_points - spent;

      pool.innerHTML = '<h4>Points Remaining: <span class="points-count' + (remaining < 0 ? ' over' : '') + '">' + remaining + '</span> / ' + GAME.point_buy_points + '</h4>';

      assignments.innerHTML = GAME.attributes.map(function(attr) {
        var score = char.pointBuyScores[attr] || 8;
        var mod = getMod(score);
        var name = (GAME.attribute_names && GAME.attribute_names[attr]) || attr;
        var cost = getPointCost(score);
        return '<div class="attr-row pb-row" data-attr="' + attr + '">' +
          '<span class="attr-name">' + attr + '</span>' +
          '<span class="attr-full-name">' + name + '</span>' +
          '<button class="pb-btn" data-attr="' + attr + '" data-dir="-1"' + (score <= 8 ? ' disabled' : '') + '>-</button>' +
          '<span class="attr-score">' + score + '</span>' +
          '<button class="pb-btn" data-attr="' + attr + '" data-dir="1"' + (score >= 15 ? ' disabled' : '') + '>+</button>' +
          '<span class="attr-mod">' + modStr(mod) + '</span>' +
          '<span class="pb-cost">(' + cost + ' pts)</span>' +
          '</div>';
      }).join('');

      GAME.attributes.forEach(function(attr) {
        char.attributes[attr] = char.pointBuyScores[attr] || 8;
      });

      $$('.pb-btn', assignments).forEach(function(btn) {
        btn.addEventListener('click', function() {
          var attr = btn.getAttribute('data-attr');
          var dir = Number(btn.getAttribute('data-dir'));
          var current = char.pointBuyScores[attr] || 8;
          var next = current + dir;
          if (next >= 8 && next <= 15) {
            // Check budget before increasing
            if (dir > 0) {
              var newCost = getPointCost(next) - getPointCost(current);
              if (totalSpent() + newCost > GAME.point_buy_points) return;
            }
            char.pointBuyScores[attr] = next;
            render();
            updateDerived();
            updateNextBtn();
          }
        });
      });
    }

    render();
  }

  function renderManualInput() {
    el('attr-desc').textContent = 'Type a score (1\u201320) for each attribute. Use this for rolled stats or custom values.';
    var pool = el('attr-pool');
    var assignments = el('attr-assignments');

    pool.innerHTML = '<h4>Manual Entry</h4><p class="manual-hint">Enter any score from 1 to 20 per attribute.</p>';

    assignments.innerHTML = GAME.attributes.map(function(attr) {
      var score = char.attributes[attr] || '';
      var mod = score ? getMod(score) : 0;
      var name = (GAME.attribute_names && GAME.attribute_names[attr]) || attr;
      return '<div class="attr-row manual-row" data-attr="' + attr + '">' +
        '<span class="attr-name">' + attr + '</span>' +
        '<span class="attr-full-name">' + name + '</span>' +
        '<input type="number" class="manual-input" data-attr="' + attr + '" min="1" max="20" value="' + (score || '') + '" placeholder="\u2014" />' +
        '<span class="attr-mod">' + (score ? modStr(mod) : '') + '</span>' +
        '</div>';
    }).join('');

    $$('.manual-input', assignments).forEach(function(input) {
      input.addEventListener('input', function() {
        var attr = input.getAttribute('data-attr');
        var val = parseInt(input.value, 10);
        if (!isNaN(val) && val >= 1 && val <= 20) {
          char.attributes[attr] = val;
        } else if (input.value === '') {
          char.attributes[attr] = 0;
        }
        // Update just the mod display next to this input
        var modSpan = input.parentElement.querySelector('.attr-mod');
        if (char.attributes[attr]) {
          modSpan.textContent = modStr(getMod(char.attributes[attr]));
        } else {
          modSpan.textContent = '';
        }
        updateDerived();
        updateNextBtn();
      });
    });
  }

  function updateDerived() {
    var preview = el('derived-preview');
    var a = char.attributes;
    var cls = char.class;

    var speciesNote = '';
    if (char.species) {
      speciesNote = '<p class="species-note">Species bonus: ' + char.species.attribute_bonus + ' (apply manually when assigning)</p>';
    }

    if (!a.MIG && !a.AGI && char.method === 'standard') {
      preview.innerHTML = speciesNote + '<p class="muted">Assign attributes to see derived stats.</p>';
      return;
    }

    var endMod = getMod(a.END || 10);
    var agiMod = getMod(a.AGI || 10);
    var migMod = getMod(a.MIG || 10);
    var wisMod = getMod(a.WIS || 10);
    var preMod = getMod(a.PRE || 10);
    var hp = cls ? cls.hp_base + endMod : '?';
    var dv = 10 + agiMod;
    var init = agiMod;
    var fort = Math.max(endMod, migMod);
    var ref = Math.max(agiMod, wisMod);
    var will = Math.max(wisMod, preMod);

    // Add proficiency bonus to trained saves
    var profBonus = getProfBonus(char.level || 1);
    var trainedSaves = {};
    if (cls) (cls.save_proficiencies || []).forEach(function(s) { trainedSaves[s] = true; });
    var fortTotal = fort + (trainedSaves.Fortitude ? profBonus : 0);
    var refTotal = ref + (trainedSaves.Reflex ? profBonus : 0);
    var willTotal = will + (trainedSaves.Will ? profBonus : 0);

    preview.innerHTML = speciesNote +
      '<div class="derived-grid">' +
      '<div class="derived-item"><span class="derived-label">HP</span><span class="derived-val">' + hp + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">DV</span><span class="derived-val">' + dv + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">Initiative</span><span class="derived-val">' + modStr(init) + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">FORT Save</span><span class="derived-val">' + modStr(fortTotal) + (trainedSaves.Fortitude ? '*' : '') + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">REF Save</span><span class="derived-val">' + modStr(refTotal) + (trainedSaves.Reflex ? '*' : '') + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">WILL Save</span><span class="derived-val">' + modStr(willTotal) + (trainedSaves.Will ? '*' : '') + '</span></div>' +
      '<div class="derived-item"><span class="derived-label">Movement</span><span class="derived-val">' + GAME.base_movement + ' ft</span></div>' +
      '<div class="derived-item"><span class="derived-label">Humanity</span><span class="derived-val">' + (cls ? cls.starting_humanity : GAME.base_humanity) + '</span></div>' +
      '</div>' +
      (cls ? '<p class="save-note">* = proficiency-trained save (+' + profBonus + ' included)</p>' : '');
  }

  // ---- Step 4: Proficiencies ----
  function getAutoSkills() {
    var autoSkills = {};
    if (char.class) {
      (char.class.skill_bonuses || []).forEach(function(sb) { autoSkills[sb.skill] = true; });
    }
    if (char.background) {
      // Parse "Skill Name +2" — strip the trailing " +N" to get the skill name
      var bgSkill = char.background.skill_bonus.replace(/\s+\+\d+$/, '');
      autoSkills[bgSkill] = true;
    }
    return autoSkills;
  }

  function getMaxProfPicks() {
    var base = 2;
    if (char.species && char.species.name === 'Human') base = 3;
    return base;
  }

  // ---- Step 4: Class Configuration (unified) ----
  // Show/hide level slider on Class step when a class is selected
  function renderClassStep() {
    var lvlSelector = el('class-level-selector');
    if (char.class && lvlSelector) {
      lvlSelector.style.display = '';
      var slider = el('level-slider');
      var display = el('level-display');
      slider.value = char.level;
      display.textContent = char.level;
      slider.oninput = function() {
        char.level = Number(slider.value);
        display.textContent = char.level;
        updateBreadcrumbs();
        // Update spell slot display in class detail if it's showing
        updateClassDetailSpellSlots();
      };
    }
  }

  // Lightweight update for spell slot display in class detail when level changes
  function updateClassDetailSpellSlots() {
    var cls = char.class;
    if (!cls || !cls.spell_slots || !cls.spell_slots.length) return;
    var detail = el('class-detail');
    if (!detail) return;
    var slotHeader = detail.querySelector('h4');
    // Find the spell slots header and its sibling display
    var headers = detail.querySelectorAll('h4');
    for (var i = 0; i < headers.length; i++) {
      if (headers[i].textContent.indexOf('Spell Slots') === 0) {
        var slotEntry = getSpellSlotEntry(cls);
        headers[i].innerHTML = 'Spell Slots (Level ' + char.level + ')';
        var display = headers[i].nextElementSibling;
        if (display && display.classList.contains('spell-slot-display')) {
          var html = '';
          (slotEntry.slots || []).forEach(function(count, si) {
            if (count > 0) html += '<span class="slot-badge">' + count + ' x ' + ordinal(si + 1) + '-level</span>';
          });
          var cantripsAtLevel = getCantripsForLevel(cls);
          if (cantripsAtLevel) html += '<span class="slot-badge cantrip-badge">' + cantripsAtLevel + ' Cantrips</span>';
          display.innerHTML = html;
        }
        break;
      }
    }
  }

  // Unified Build step: Attributes + Proficiencies + Abilities + Progression
  function renderBuild() {
    // Sync level slider (it lives on step 1 but we need the value here)
    renderAttributes();
    renderSkills();
    renderSkillTrees();
    renderProgression();
  }

  function isSkillProficient(skillName) {
    var autoSkills = getAutoSkills();
    return !!autoSkills[skillName] || char.chosenProficiencies.indexOf(skillName) > -1;
  }

  function renderSkills() {
    var container = el('skills-list');
    var autoSkills = getAutoSkills();
    var maxPicks = getMaxProfPicks();
    var picksUsed = char.chosenProficiencies.length;
    var picksLeft = maxPicks - picksUsed;

    // Update the pick count display
    var pickCountEl = el('prof-pick-count');
    if (pickCountEl) pickCountEl.textContent = maxPicks;

    var budgetEl = el('prof-picks-remaining');
    if (budgetEl) {
      budgetEl.innerHTML = '<div class="ap-bar"><span class="ap-label">Bonus Proficiency Picks</span>' +
        '<span class="ap-remaining' + (picksLeft === 0 ? ' over' : '') + '">' + picksLeft + '</span>' +
        '<span class="ap-total"> / ' + maxPicks + ' remaining</span></div>';
    }

    var categories = {};
    GAME.skills.forEach(function(sk) {
      if (!categories[sk.category]) categories[sk.category] = [];
      categories[sk.category].push(sk);
    });

    var html = '';
    Object.keys(categories).forEach(function(cat) {
      html += '<div class="skill-category"><h4>' + cat + '</h4>';
      categories[cat].forEach(function(sk) {
        var isAuto = !!autoSkills[sk.name];
        var isChosen = char.chosenProficiencies.indexOf(sk.name) > -1;
        var isProficient = isAuto || isChosen;
        var primaryAttr = sk.attribute.split('/')[0];
        var attrScore = char.attributes[primaryAttr] || 10;
        var mod = getMod(attrScore);
        var profBonus = isProficient ? getProfBonus(char.level || 1) : 0;
        var total = mod + profBonus;

        var rowClass = 'skill-row';
        if (isAuto) rowClass += ' auto-prof';
        else if (isChosen) rowClass += ' chosen-prof';
        var canPick = !isAuto && !isChosen && picksLeft > 0;

        html += '<button class="' + rowClass + '" data-skill="' + sk.name + '"' + (isAuto ? ' disabled' : '') + '>' +
          '<span class="skill-name">' + sk.name + '</span>' +
          '<span class="skill-attr">' + sk.attribute + '</span>' +
          '<span class="skill-mod">' + modStr(total) + '</span>';
        if (isAuto) {
          html += '<span class="skill-badge">Class/BG</span>';
        } else if (isChosen) {
          html += '<span class="skill-badge chosen">Chosen</span>';
        } else if (canPick) {
          html += '<span class="skill-badge pick">+ Pick</span>';
        }
        html += '</button>';
      });
      html += '</div>';
    });
    container.innerHTML = html;

    // Use event delegation for proficiency pick clicks (more robust than per-button binding)
    container.onclick = function(e) {
      var btn = e.target.closest('.skill-row');
      if (!btn || btn.disabled || btn.classList.contains('auto-prof')) return;
      var skillName = btn.getAttribute('data-skill');
      if (!skillName) return;
      var idx = char.chosenProficiencies.indexOf(skillName);
      if (idx > -1) {
        char.chosenProficiencies.splice(idx, 1);
      } else if (char.chosenProficiencies.length < maxPicks) {
        char.chosenProficiencies.push(skillName);
      }
      renderSkills();
    };
  }

  // ---- Step 5: Skill Trees (AP Spending) ----
  function renderSkillTrees() {
    var budget = el('ap-budget');
    var panel = el('skill-trees-panel');
    var cls = char.class;
    var sp = char.species;

    if (!cls) {
      budget.innerHTML = '';
      panel.innerHTML = '<p class="muted">Select a class first to spend AP.</p>';
      return;
    }

    var totalAP = getTotalAP();
    var spentAP = char.purchasedAbilities.reduce(function(sum, a) { return sum + a.ap_cost; }, 0);
    var remainingAP = totalAP - spentAP;

    budget.innerHTML =
      '<div class="ap-bar">' +
      '<span class="ap-label">Advancement Points</span>' +
      '<span class="ap-remaining' + (remainingAP < 0 ? ' over' : '') + '">' + remainingAP + '</span>' +
      '<span class="ap-total"> / ' + totalAP + ' AP</span>' +
      '</div>';

    var html = '';
    (cls.skill_trees || []).forEach(function(tree) {
      html += '<div class="ap-tree">';
      html += '<div class="ap-tree-header"><h4>' + tree.name + '</h4><span class="tree-focus">(' + tree.focus + ')</span></div>';
      html += '<div class="ap-tree-abilities">';

      (tree.abilities || []).forEach(function(ability) {
        var purchased = char.purchasedAbilities.some(function(p) {
          return p.treeName === tree.name && p.abilityName === ability.name;
        });

        // Check prerequisites
        var canBuy = false;
        var lockReason = '';
        if (ability.tier === 1) {
          canBuy = remainingAP >= ability.ap_cost || purchased;
        } else if (ability.tier === 2) {
          var hasTier1 = char.purchasedAbilities.some(function(p) {
            return p.treeName === tree.name && p.tier === 1;
          });
          if (!hasTier1) {
            lockReason = 'Requires Tier 1 in ' + tree.name;
          } else if (remainingAP < ability.ap_cost && !purchased) {
            lockReason = 'Not enough AP';
          } else {
            canBuy = true;
          }
        } else if (ability.tier === 3) {
          var hasT2 = char.purchasedAbilities.some(function(p) {
            return p.treeName === tree.name && p.tier === 2;
          });
          if (char.level < 5) {
            lockReason = 'Requires Level 5+';
          } else if (!hasT2) {
            lockReason = 'Requires Tier 2 in ' + tree.name;
          } else if (remainingAP < ability.ap_cost && !purchased) {
            lockReason = 'Not enough AP';
          } else {
            canBuy = true;
          }
        }

        var stateClass = purchased ? ' purchased' : (canBuy ? ' available' : ' locked');

        html += '<button class="ap-ability' + stateClass + '" data-tree="' + tree.name + '" data-ability="' + ability.name + '" data-cost="' + ability.ap_cost + '" data-tier="' + ability.tier + '" data-effect="' + ability.effect + '"' + (!canBuy && !purchased ? ' disabled' : '') + '>';
        html += '<div class="ap-ability-header">';
        html += '<span class="ap-ability-name">' + ability.name + '</span>';
        html += '<span class="ap-ability-cost">' + ability.ap_cost + ' AP</span>';
        html += '</div>';
        html += '<div class="ap-ability-meta">';
        html += '<span class="ap-ability-tier">Tier ' + ability.tier + '</span>';
        html += '<span class="ap-ability-effect">' + ability.effect + '</span>';
        html += '</div>';
        if (lockReason) {
          html += '<div class="ap-lock-reason">' + lockReason + '</div>';
        }
        if (purchased) {
          html += '<div class="ap-purchased-badge">Purchased</div>';
        }
        html += '</button>';
      });

      html += '</div></div>';
    });

    panel.innerHTML = html;

    // Bind ability clicks
    $$('.ap-ability', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var treeName = btn.getAttribute('data-tree');
        var abilityName = btn.getAttribute('data-ability');
        var cost = Number(btn.getAttribute('data-cost'));
        var tier = Number(btn.getAttribute('data-tier'));
        var effect = btn.getAttribute('data-effect');

        var existingIdx = -1;
        char.purchasedAbilities.forEach(function(p, i) {
          if (p.treeName === treeName && p.abilityName === abilityName) existingIdx = i;
        });

        if (existingIdx > -1) {
          // Check if higher tier in same tree depends on this
          var hasDependant = char.purchasedAbilities.some(function(p) {
            return p.treeName === treeName && p.tier > tier;
          });
          if (!hasDependant) {
            char.purchasedAbilities.splice(existingIdx, 1);
          }
        } else if (remainingAP >= cost) {
          char.purchasedAbilities.push({
            treeName: treeName,
            abilityName: abilityName,
            ap_cost: cost,
            tier: tier,
            effect: effect
          });
        }

        renderSkillTrees();
      });
    });
  }

  // ---- Step 6: Progression ----

  // What happens at each level
  var LEVEL_EVENTS = {
    1: { label: 'Core Class Features + Doctrine #1', type: 'class' },
    2: { label: 'Class Feature + Talent', type: 'talent', feature: true },
    3: { label: 'Class Feature + Free Proficiency', type: 'class', feature: true, profPick: true },
    4: { label: 'Class Feature + Talent + ASI', type: 'talent_asi', feature: true },
    5: { label: 'Capstone Feature', type: 'class', feature: true }, // Operative also gets bonus prof here
    6: { label: 'Specialization + Doctrine #2', type: 'spec' },
    7: { label: 'Talent + Skill Mastery', type: 'talent' },
    8: { label: 'Specialization Feature + Free Proficiency', type: 'class', profPick: true },
    9: { label: 'Talent + ASI', type: 'talent_asi' },
    10: { label: 'Specialization Capstone', type: 'class' },
    11: { label: 'Mastery Path', type: 'mastery' },
    12: { label: 'Talent + ASI', type: 'talent_asi' },
    13: { label: 'Mastery Feature', type: 'class' },
    14: { label: 'Talent', type: 'talent' },
    15: { label: 'Mastery Capstone + Free Proficiency', type: 'class', profPick: true },
    16: { label: 'Archetype Ultimate', type: 'class' },
    17: { label: 'Specialization Evolution', type: 'class' },
    18: { label: 'Legendary Talent + ASI', type: 'legendary_asi' },
    19: { label: 'Legendary Talent', type: 'legendary' },
    20: { label: 'Apex Ability', type: 'class' }
  };

  // Operative bonus proficiency levels
  var OPERATIVE_PROF_LEVELS = [5, 10];
  // Operative free expertise levels
  var OPERATIVE_EXPERTISE_LEVELS = [6, 12];

  var TALENT_LEVELS = [2, 4, 7, 9, 12, 14];
  var ASI_LEVELS = [4, 9, 12, 18];
  var ATTR_NAMES = ['MIG', 'AGI', 'END', 'INT', 'WIS', 'PRE'];

  function getTotalAP() {
    var base = (char.species && char.species.name === 'Human') ? 20 : 15;
    return base + (char.level - 1) * 10;
  }

  function renderProgression() {
    var timeline = el('progression-timeline');
    var cls = char.class;
    if (!cls) {
      timeline.innerHTML = '<p class="muted">Select a class first.</p>';
      return;
    }

    var html = '';
    var totalAP = getTotalAP();
    var spent = char.purchasedAbilities.reduce(function(s, a) { return s + a.ap_cost; }, 0);
    var profBonus = getProfBonus(char.level);
    var endMod = getMod(char.attributes.END || 10);
    var hpPerLevel = cls.hp_per_level || Math.floor(parseInt(cls.hit_die.replace('d','')) / 2) + 1;
    var totalHP = cls.hp_base + endMod + (char.level - 1) * (hpPerLevel + endMod);

    // Apply ASI attribute bonuses
    var asiAttrs = {};
    ATTR_NAMES.forEach(function(a) { asiAttrs[a] = 0; });
    Object.keys(char.selectedASIs).forEach(function(lv) {
      if (Number(lv) <= char.level) {
        var asi = char.selectedASIs[lv];
        if (asi.mode === '+2' && asi.attr1) asiAttrs[asi.attr1] += 2;
        if (asi.mode === '+1+1') {
          if (asi.attr1) asiAttrs[asi.attr1] += 1;
          if (asi.attr2) asiAttrs[asi.attr2] += 1;
        }
      }
    });

    // Stats bar
    html += '<div class="prog-stats-bar">' +
      '<span class="prog-stat"><strong>Level ' + char.level + '</strong></span>' +
      '<span class="prog-stat">HP <strong>' + totalHP + '</strong></span>' +
      '<span class="prog-stat">Prof <strong>+' + profBonus + '</strong></span>' +
      '<span class="prog-stat">AP <strong>' + totalAP + '</strong> (' + (totalAP - spent) + ' unspent)</span>' +
      '</div>';

    // ASI summary if any
    var hasASIs = Object.keys(char.selectedASIs).some(function(lv) { return Number(lv) <= char.level; });
    if (hasASIs) {
      html += '<div class="asi-summary">';
      ATTR_NAMES.forEach(function(a) {
        if (asiAttrs[a] > 0) html += '<span class="asi-badge">' + a + ' +' + asiAttrs[a] + '</span>';
      });
      html += '</div>';
    }

    // Timeline
    html += '<div class="timeline">';
    for (var lv = 1; lv <= char.level; lv++) {
      var ev = LEVEL_EVENTS[lv];
      var isMilestone = (ev.type !== 'ap' && ev.type !== 'class');

      html += '<div class="timeline-item' + (isMilestone ? ' milestone' : '') + (lv === char.level ? ' current' : '') + '">';
      html += '<div class="timeline-marker"><span>' + lv + '</span></div>';
      html += '<div class="timeline-content">';
      var startingAP = (char.species && char.species.name === 'Human') ? 20 : 15;
      var apLabel = lv === 1 ? '(' + startingAP + ' starting AP)' : '(+10 AP)';
      html += '<div class="timeline-header"><strong>Level ' + lv + '</strong><span class="timeline-label">' + ev.label + ' ' + apLabel + '</span></div>';

      // Class features at this level
      var levelFeatures = (cls.features || []).filter(function(f) { return f.level === lv; });
      if (levelFeatures.length > 0) {
        html += '<div class="timeline-features">';
        levelFeatures.forEach(function(f) {
          html += '<span class="feature-tag-sm">' + f.name + '</span>';
        });
        html += '</div>';
      }

      // Specialization selection at L6
      if (lv === 6 && cls.specialization_details && cls.specialization_details.length) {
        html += '<div class="timeline-choice">';
        html += '<label>Specialization</label>';
        html += '<div class="choice-buttons">';
        (cls.specialization_details || []).forEach(function(spec) {
          var isSel = char.selectedSpecialization === spec.name;
          html += '<button class="choice-btn' + (isSel ? ' selected' : '') + '" data-action="spec" data-val="' + spec.name + '">' +
            '<strong>' + spec.name + '</strong><span>' + spec.role + '</span></button>';
        });
        html += '</div>';
        // Show spec features
        if (char.selectedSpecialization) {
          var selSpec = cls.specialization_details.find(function(s) { return s.name === char.selectedSpecialization; });
          if (selSpec) {
            html += '<div class="spec-features-list">';
            (selSpec.features || []).filter(function(f) { return f.level <= char.level; }).forEach(function(f) {
              html += '<div class="spec-feature-item"><strong>L' + f.level + ': ' + f.name + '</strong> <span>' + f.description + '</span></div>';
            });
            html += '</div>';
          }
        }
        html += '</div>';

        // Doctrine #2
        var docData = GAME.doctrines && GAME.doctrines[cls.name];
        if (docData && docData.level_6) {
          html += '<div class="timeline-choice">';
          html += '<label>Doctrine #2</label>';
          html += '<div class="choice-buttons">';
          docData.level_6.forEach(function(d) {
            var isSel = char.selectedDoctrine2 && char.selectedDoctrine2.name === d.name;
            html += '<button class="choice-btn' + (isSel ? ' selected' : '') + '" data-action="doctrine2" data-val="' + d.name + '">' +
              '<strong>' + d.name + '</strong><span>' + d.effect + '</span></button>';
          });
          html += '</div></div>';
        }
      }

      // Talent selection
      if (TALENT_LEVELS.indexOf(lv) > -1) {
        html += renderTalentChoice(lv, cls);
      }

      // Legendary talent at L18 and L19
      if (lv === 18 || lv === 19) {
        html += renderLegendaryTalentChoice(lv);
      }

      // ASI selection
      if (ASI_LEVELS.indexOf(lv) > -1) {
        html += renderASIChoice(lv);
      }

      // Mastery Path at L11
      if (lv === 11) {
        html += renderMasteryPathChoice();
      }

      // Multiclass option at even levels >= 2 (rules: 2,4,6,8...; skip L6 = specialization)
      if (lv >= 2 && lv % 2 === 0 && lv !== 6) {
        html += renderMulticlassOption(lv);
      }

      // Free proficiency pick at L3, L8, L15 (all classes)
      if (ev.profPick) {
        html += renderProgressionProfPick(lv, 'Free Proficiency');
      }

      // Operative bonus proficiency picks at L5, L10
      if (cls.name === 'Operative' && OPERATIVE_PROF_LEVELS.indexOf(lv) > -1) {
        html += renderProgressionProfPick(lv, 'Operative Bonus Proficiency');
      }

      // Operative free expertise at L6, L12
      if (cls.name === 'Operative' && OPERATIVE_EXPERTISE_LEVELS.indexOf(lv) > -1) {
        html += renderProgressionExpertise(lv);
      }

      html += '</div></div>'; // close timeline-content, timeline-item
    }
    html += '</div>'; // close timeline

    timeline.innerHTML = html;

    // Bind all choice buttons (exclude selects — they have their own change handler below)
    $$('[data-action]:not(select)', timeline).forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (btn.disabled || btn.classList.contains('disabled')) return;
        var action = btn.getAttribute('data-action');
        var val = btn.getAttribute('data-val');
        var lvl = btn.getAttribute('data-level');

        if (action === 'spec') {
          char.selectedSpecialization = val;
        } else if (action === 'doctrine2') {
          var docData = GAME.doctrines && GAME.doctrines[char.class.name];
          char.selectedDoctrine2 = (docData && docData.level_6 || []).find(function(d) { return d.name === val; }) || null;
        } else if (action === 'talent') {
          if (!val) {
            delete char.selectedTalents[lvl];
          } else {
            var talentPool = getAllTalents(char.class.name);
            var chosen = talentPool.find(function(t) { return t.name === val; });
            if (chosen) char.selectedTalents[lvl] = chosen;
          }
        } else if (action === 'legendary-talent') {
          var lt = (GAME.legendary_talents || []).find(function(t) { return t.name === val; });
          if (lt) char.selectedTalents[lvl] = lt;
        } else if (action === 'asi-mode') {
          if (!char.selectedASIs[lvl]) char.selectedASIs[lvl] = { mode: '+2', attr1: null, attr2: null };
          char.selectedASIs[lvl].mode = val;
          char.selectedASIs[lvl].attr1 = null;
          char.selectedASIs[lvl].attr2 = null;
        } else if (action === 'asi-attr1') {
          if (!char.selectedASIs[lvl]) char.selectedASIs[lvl] = { mode: '+2', attr1: null, attr2: null };
          char.selectedASIs[lvl].attr1 = val;
        } else if (action === 'asi-attr2') {
          if (!char.selectedASIs[lvl]) char.selectedASIs[lvl] = { mode: '+1+1', attr1: null, attr2: null };
          char.selectedASIs[lvl].attr2 = val;
        } else if (action === 'mastery') {
          char.selectedMasteryPath = (GAME.mastery_paths || []).find(function(mp) { return mp.name === val; }) || null;
        } else if (action === 'multiclass') {
          if (val === 'none') {
            delete char.multiclassLevels[lvl];
          } else {
            char.multiclassLevels[lvl] = val;
          }
        } else if (action === 'prog-prof') {
          if (val === '') {
            delete char.progressionProfPicks[lvl];
          } else {
            char.progressionProfPicks[lvl] = val;
          }
        } else if (action === 'prog-expertise') {
          if (val === '') {
            delete char.progressionExpertise[lvl];
          } else {
            char.progressionExpertise[lvl] = val;
          }
        }
        renderProgression();
      });
    });

    // Bind select elements (for proficiency picks and expertise)
    $$('select[data-action]', timeline).forEach(function(sel) {
      sel.addEventListener('change', function() {
        var action = sel.getAttribute('data-action');
        var val = sel.value;
        var lvl = sel.getAttribute('data-level');

        if (action === 'prog-prof') {
          if (val === '') {
            delete char.progressionProfPicks[lvl];
          } else {
            char.progressionProfPicks[lvl] = val;
          }
        } else if (action === 'prog-expertise') {
          if (val === '') {
            delete char.progressionExpertise[lvl];
          } else {
            char.progressionExpertise[lvl] = val;
          }
        }
        renderProgression();
      });
    });
  }

  function getAllTalents(className) {
    var list = [];
    // Universal talents
    if (GAME.universal_talents) {
      ['combat', 'exploration', 'skill'].forEach(function(cat) {
        (GAME.universal_talents[cat] || []).forEach(function(t) {
          list.push({ name: t.name, effect: t.effect, category: 'Universal (' + cat + ')', repeatable: t.repeatable });
        });
      });
    }
    // Class talents
    if (GAME.class_talents && GAME.class_talents[className]) {
      GAME.class_talents[className].forEach(function(t) {
        list.push({ name: t.name, effect: t.effect, enhances: t.enhances, requires: t.requires, category: className });
      });
    }
    return list;
  }

  function getSelectedTalentNames() {
    var names = {};
    Object.keys(char.selectedTalents).forEach(function(lv) {
      var t = char.selectedTalents[lv];
      if (t && !t.repeatable) names[t.name] = true;
    });
    return names;
  }

  function renderTalentChoice(lv, cls) {
    var talentPool = getAllTalents(cls.name);
    var usedNames = getSelectedTalentNames();
    var current = char.selectedTalents[lv] || null;

    var html = '<div class="timeline-choice">';
    html += '<label>Talent (L' + lv + ')</label>';
    html += '<div class="talent-select">';

    // Show current selection or picker
    if (current) {
      html += '<div class="talent-selected">';
      html += '<strong>' + current.name + '</strong>';
      if (current.enhances) html += '<span class="talent-enhances-sm">(' + current.enhances + ')</span>';
      html += '<span class="talent-effect-sm">' + current.effect + '</span>';
      html += '<button class="choice-btn-sm" data-action="talent" data-val="" data-level="' + lv + '">Change</button>';
      html += '</div>';
    }

    html += '<details class="talent-picker' + (current ? '' : ' open') + '"' + (current ? '' : ' open') + '>';
    html += '<summary>' + (current ? 'Change talent' : 'Choose a talent') + '</summary>';
    html += '<div class="talent-options">';

    var lastCat = '';
    talentPool.forEach(function(t) {
      var isUsed = usedNames[t.name] && !(current && current.name === t.name);
      if (isUsed && !t.repeatable) return;
      if (t.category !== lastCat) {
        html += '<div class="talent-cat">' + t.category + '</div>';
        lastCat = t.category;
      }
      var isSel = current && current.name === t.name;
      html += '<button class="talent-option' + (isSel ? ' selected' : '') + '" data-action="talent" data-val="' + t.name + '" data-level="' + lv + '">' +
        '<strong>' + t.name + '</strong>' +
        (t.enhances ? '<em>' + t.enhances + '</em>' : '') +
        '<span>' + t.effect + '</span></button>';
    });
    html += '</div></details></div></div>';
    return html;
  }

  function renderLegendaryTalentChoice(lv) {
    var legendaryTalents = GAME.legendary_talents || [];
    var current = char.selectedTalents[lv] || null;

    // Exclude legendary talents already picked at the other legendary level
    var otherLv = lv === 18 ? 19 : 18;
    var otherPick = char.selectedTalents[otherLv] || null;

    var html = '<div class="timeline-choice">';
    html += '<label>Legendary Talent (L' + lv + ')</label>';

    if (current) {
      html += '<div class="talent-selected legendary">';
      html += '<strong>' + current.name + '</strong>';
      html += '<span class="talent-effect-sm">' + current.effect + '</span>';
      html += '</div>';
    }

    html += '<details class="talent-picker"' + (current ? '' : ' open') + '>';
    html += '<summary>' + (current ? 'Change legendary talent' : 'Choose a legendary talent') + '</summary>';
    html += '<div class="talent-options">';
    legendaryTalents.forEach(function(t) {
      // Don't show talents already chosen at the other legendary level
      if (otherPick && otherPick.name === t.name) return;
      var isSel = current && current.name === t.name;
      html += '<button class="talent-option legendary' + (isSel ? ' selected' : '') + '" data-action="legendary-talent" data-val="' + t.name + '" data-level="' + lv + '">' +
        '<strong>' + t.name + '</strong>' +
        (t.requires ? '<em>Req: ' + t.requires + '</em>' : '') +
        '<span>' + t.effect + '</span></button>';
    });
    html += '</div></details></div>';
    return html;
  }

  function renderASIChoice(lv) {
    var asi = char.selectedASIs[lv] || { mode: '+2', attr1: null, attr2: null };
    var html = '<div class="timeline-choice">';
    html += '<label>Attribute Improvement (L' + lv + ')</label>';
    html += '<div class="asi-mode-toggle">';
    html += '<button class="choice-btn-sm' + (asi.mode === '+2' ? ' selected' : '') + '" data-action="asi-mode" data-val="+2" data-level="' + lv + '">+2 to one</button>';
    html += '<button class="choice-btn-sm' + (asi.mode === '+1+1' ? ' selected' : '') + '" data-action="asi-mode" data-val="+1+1" data-level="' + lv + '">+1 to two</button>';
    html += '</div>';

    if (asi.mode === '+2') {
      html += '<div class="asi-attrs">';
      ATTR_NAMES.forEach(function(a) {
        var base = char.attributes[a] || 8;
        var isSel = asi.attr1 === a;
        html += '<button class="attr-btn' + (isSel ? ' selected' : '') + '" data-action="asi-attr1" data-val="' + a + '" data-level="' + lv + '">' + a + ' (' + base + '→' + (base + 2) + ')</button>';
      });
      html += '</div>';
    } else {
      html += '<div class="asi-attrs"><span class="asi-label">First:</span>';
      ATTR_NAMES.forEach(function(a) {
        var base = char.attributes[a] || 8;
        var isSel = asi.attr1 === a;
        html += '<button class="attr-btn' + (isSel ? ' selected' : '') + '" data-action="asi-attr1" data-val="' + a + '" data-level="' + lv + '">' + a + ' +1</button>';
      });
      html += '</div><div class="asi-attrs"><span class="asi-label">Second:</span>';
      ATTR_NAMES.forEach(function(a) {
        var base = char.attributes[a] || 8;
        var isSel = asi.attr2 === a;
        var disabled = asi.attr1 === a;
        html += '<button class="attr-btn' + (isSel ? ' selected' : '') + (disabled ? ' disabled' : '') + '" data-action="asi-attr2" data-val="' + a + '" data-level="' + lv + '"' + (disabled ? ' disabled' : '') + '>' + a + ' +1</button>';
      });
      html += '</div>';
    }
    html += '</div>';
    return html;
  }

  function renderMasteryPathChoice() {
    var paths = GAME.mastery_paths || [];
    var current = char.selectedMasteryPath;

    var html = '<div class="timeline-choice">';
    html += '<label>Mastery Path</label>';

    if (current) {
      html += '<div class="mastery-selected">';
      html += '<strong>' + current.name + '</strong>';
      html += '<span class="mastery-stats">' + current.stats + '</span>';
      html += '<div class="mastery-features-inline">';
      html += '<span>L11: ' + (current.features_11 || []).join(', ') + '</span>';
      if (char.level >= 13) html += '<span>L13: ' + (current.features_13 || []).join(', ') + '</span>';
      if (char.level >= 15) html += '<span>L15: ' + current.capstone_15 + '</span>';
      html += '</div></div>';
    }

    html += '<details class="talent-picker"' + (current ? '' : ' open') + '>';
    html += '<summary>' + (current ? 'Change mastery path' : 'Choose a mastery path') + '</summary>';
    html += '<div class="mastery-options">';
    paths.forEach(function(mp) {
      var isSel = current && current.name === mp.name;
      html += '<button class="mastery-option' + (isSel ? ' selected' : '') + '" data-action="mastery" data-val="' + mp.name + '">' +
        '<div class="mastery-opt-header"><strong>' + mp.name + '</strong><span>' + mp.stats + '</span></div>' +
        '<em>' + mp.narrative + '</em>' +
        '<span class="mastery-opt-features">L11: ' + (mp.features_11 || []).join(', ') + ' | L13: ' + (mp.features_13 || []).join(', ') + ' | L15: ' + mp.capstone_15 + '</span>' +
        '</button>';
    });
    html += '</div></details></div>';
    return html;
  }

  function getDistinctMulticlasses() {
    // Collect distinct class names chosen via multiclass — only count levels at or below current level
    var classes = {};
    if (char.class) classes[char.class.name] = true;
    Object.keys(char.multiclassLevels).forEach(function(lvKey) {
      if (Number(lvKey) <= char.level && char.multiclassLevels[lvKey]) {
        classes[char.multiclassLevels[lvKey]] = true;
      }
    });
    return classes;
  }

  // Map full attribute names to abbreviations for multiclass requirement checking
  var ATTR_FULL_TO_ABBR = { Might: 'MIG', Agility: 'AGI', Endurance: 'END', Intellect: 'INT', Wisdom: 'WIS', Presence: 'PRE' };

  function getEffectiveAttributes() {
    // Base attributes + species bonuses + ASI bonuses
    var ea = {};
    ATTR_NAMES.forEach(function(a) { ea[a] = char.attributes[a] || 0; });
    Object.keys(char.selectedASIs).forEach(function(lv) {
      if (Number(lv) <= char.level) {
        var asi = char.selectedASIs[lv];
        if (asi.mode === '+2' && asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 2);
        if (asi.mode === '+1+1') {
          if (asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 1);
          if (asi.attr2) ea[asi.attr2] = Math.min(20, ea[asi.attr2] + 1);
        }
      }
    });
    return ea;
  }

  function meetsMulticlassRequirement(statString) {
    // Parse requirement strings like "Might 13 or Endurance 13" or "Agility 13"
    var ea = getEffectiveAttributes();
    var parts = statString.split(' or ');
    for (var i = 0; i < parts.length; i++) {
      var match = parts[i].trim().match(/^(\w+)\s+(\d+)$/);
      if (match) {
        var abbr = ATTR_FULL_TO_ABBR[match[1]];
        var threshold = Number(match[2]);
        if (abbr && ea[abbr] >= threshold) return true;
      }
    }
    // If no attributes assigned yet, don't block — let them plan
    var hasAnyAttr = ATTR_NAMES.some(function(a) { return ea[a] > 0; });
    if (!hasAnyAttr) return true;
    return false;
  }

  function getMulticlassClassData(archetype) {
    // Find class data for a multiclass archetype
    return GAME.classes.find(function(c) { return c.name === archetype; }) || null;
  }

  function renderMulticlassOption(lv) {
    var current = char.multiclassLevels[lv] || null;
    var requirements = GAME.multiclass_requirements || [];
    var currentClassName = char.class ? char.class.name : '';

    // Determine which classes are already in use (for max 3 enforcement)
    var distinctClasses = getDistinctMulticlasses();
    var classCount = Object.keys(distinctClasses).length;

    // Check if current primary class meets its own requirement (needed for multiclass)
    var primaryReq = requirements.find(function(r) { return r.archetype === currentClassName; });
    var meetsPrimaryReq = primaryReq ? meetsMulticlassRequirement(primaryReq.stat) : true;

    var html = '<div class="timeline-choice multiclass-choice">';
    html += '<details>';
    html += '<summary class="multiclass-summary">Multiclass' + (current ? ': <strong>' + current + '</strong>' : ' (optional)') + '</summary>';
    html += '<div class="multiclass-options">';
    if (!meetsPrimaryReq) {
      html += '<p class="multiclass-limit-note">Your primary class (' + currentClassName + ') requires ' + primaryReq.stat + ' to multiclass.</p>';
    }
    html += '<button class="choice-btn-sm' + (!current ? ' selected' : '') + '" data-action="multiclass" data-val="none" data-level="' + lv + '">No multiclass</button>';
    requirements.forEach(function(mc) {
      if (mc.archetype === currentClassName) return;
      var isSel = current === mc.archetype;
      // Enforce max 3 classes: disable options for new classes if at the limit
      var isNewClass = !distinctClasses[mc.archetype];
      var atLimit = classCount >= 3 && isNewClass && !isSel;
      // Check attribute requirements for both primary and target class
      var meetsReq = meetsPrimaryReq && meetsMulticlassRequirement(mc.stat);
      var isDisabled = atLimit || (!meetsReq && !isSel);
      var disableReason = atLimit ? 'Maximum 3 classes total' : (!meetsReq ? 'Does not meet attribute requirement' : '');
      var mcClass = getMulticlassClassData(mc.archetype);
      html += '<button class="choice-btn' + (isSel ? ' selected' : '') + (isDisabled ? ' disabled' : '') + '" data-action="multiclass" data-val="' + mc.archetype + '" data-level="' + lv + '"' + (isDisabled ? ' disabled title="' + disableReason + '"' : '') + '>' +
        '<strong>' + mc.archetype + '</strong><span>Requires: ' + mc.stat + (meetsReq ? ' ✓' : '') + '</span>' +
        (mcClass ? '<span class="multiclass-gains">Gain: ' + mcClass.hit_die + ' HD, ' + (mcClass.weapon_proficiency || []).join(', ') + '</span>' : '') +
        '</button>';
    });
    if (classCount >= 3) {
      html += '<p class="multiclass-limit-note">Maximum 3 archetypes reached</p>';
    }
    html += '</div></details></div>';
    return html;
  }

  // ---- Progression: Proficiency Pick Rendering ----
  function getAllProficientSkills() {
    // Gather all skills this character is proficient in from all sources
    var profSkills = {};
    var autoSkills = getAutoSkills();
    Object.keys(autoSkills).forEach(function(s) { profSkills[s] = true; });
    char.chosenProficiencies.forEach(function(s) { profSkills[s] = true; });
    Object.keys(char.progressionProfPicks).forEach(function(lv) {
      if (Number(lv) <= char.level && char.progressionProfPicks[lv]) {
        profSkills[char.progressionProfPicks[lv]] = true;
      }
    });
    return profSkills;
  }

  function getAllExpertiseSkills() {
    var expertSkills = {};
    char.expertiseSkills.forEach(function(s) { expertSkills[s] = true; });
    Object.keys(char.progressionExpertise).forEach(function(lv) {
      if (Number(lv) <= char.level && char.progressionExpertise[lv]) {
        expertSkills[char.progressionExpertise[lv]] = true;
      }
    });
    return expertSkills;
  }

  function renderProgressionProfPick(lv, label) {
    var current = char.progressionProfPicks[lv] || null;
    var profSkills = getAllProficientSkills();
    // Available = any skill not already proficient (except the one currently selected for this level)
    var available = GAME.skills.filter(function(sk) {
      if (current === sk.name) return true;
      return !profSkills[sk.name];
    });

    var html = '<div class="timeline-choice">';
    html += '<label>' + label + '</label>';
    html += '<select class="prog-select" data-action="prog-prof" data-level="' + lv + '">';
    html += '<option value="">— Choose a skill —</option>';
    available.forEach(function(sk) {
      var isSel = current === sk.name;
      html += '<option value="' + sk.name + '"' + (isSel ? ' selected' : '') + '>' + sk.name + ' (' + sk.attribute + ')</option>';
    });
    html += '</select></div>';
    return html;
  }

  function renderProgressionExpertise(lv) {
    var current = char.progressionExpertise[lv] || null;
    var profSkills = getAllProficientSkills();
    var expertSkills = getAllExpertiseSkills();
    // Available = any proficient skill not already expert (except the one currently selected for this level)
    var available = GAME.skills.filter(function(sk) {
      if (current === sk.name) return true;
      return profSkills[sk.name] && !expertSkills[sk.name];
    });

    var html = '<div class="timeline-choice">';
    html += '<label>Operative Free Expertise (L' + lv + ')</label>';
    html += '<select class="prog-select" data-action="prog-expertise" data-level="' + lv + '">';
    html += '<option value="">— Choose a skill —</option>';
    available.forEach(function(sk) {
      var isSel = current === sk.name;
      html += '<option value="' + sk.name + '"' + (isSel ? ' selected' : '') + '>' + sk.name + '</option>';
    });
    html += '</select></div>';
    return html;
  }

  // ---- Credit Budget ----
  function getCreditsSpent() {
    var spent = 0;
    // Weapons cost credits only if NOT part of starting package (for simplicity, all selected weapons cost credits)
    char.selectedWeapons.forEach(function(w) { spent += (w.cost || 0); });
    if (char.selectedArmor) spent += (char.selectedArmor.cost || 0);
    if (char.selectedShield) spent += (char.selectedShield.cost || 0);
    char.selectedAugments.forEach(function(a) { spent += (a.cost || 0); });
    return spent;
  }

  function getRemainingCredits() {
    return char.startingCredits - getCreditsSpent();
  }

  // ---- Step 7: Equipment ----
  function renderEquipment() {
    var panel = el('equipment-panel');
    var cls = char.class;
    if (!cls) {
      panel.innerHTML = '<p class="muted">Select a class first to see starting equipment.</p>';
      return;
    }

    var eq = GAME.equipment;
    var agiMod = getMod(char.attributes.AGI || 10);
    var currentDV = calcDV(agiMod, char.selectedArmor, char.selectedShield);
    var creditsSpent = getCreditsSpent();
    var creditsLeft = char.startingCredits - creditsSpent;

    var html = '<div class="equip-section wide">' +
      '<h3>' + cls.name + ' Starting Package</h3>' +
      '<ul class="equip-list">' +
      (cls.starting_equipment || []).map(function(item) { return '<li>' + item + '</li>'; }).join('') +
      '</ul>' +
      '<div class="equip-dv-preview"><span class="equip-dv-label">Current DV</span><span class="equip-dv-value">' + currentDV + '</span></div>' +
      '</div>';

    // Credit budget bar
    html += '<div class="credit-budget">' +
      '<div class="credit-bar' + (creditsLeft < 0 ? ' over-budget' : '') + '">' +
      '<span class="ap-label">Starting Credits</span>' +
      '<input type="number" id="credits-input" class="credits-input" min="20" max="120" value="' + char.startingCredits + '" title="2d6 × 10 credits (20-120)" />' +
      '<span class="ap-label">Spent</span>' +
      '<span class="credit-remaining">' + creditsSpent + ' cr</span>' +
      '<span class="ap-label">Remaining</span>' +
      '<span class="credit-remaining' + (creditsLeft < 0 ? ' negative' : '') + '">' + creditsLeft + ' cr</span>' +
      '</div></div>';

    // Weapon selection (Tier 1-2 for Level 1 characters)
    var allWeapons = (eq.melee_weapons || []).concat(eq.ranged_weapons || []).filter(function(w) { return w.tier <= 2; });
    var weaponSlots = char.selectedWeapons.length;

    html += '<div class="equip-section"><h3>Choose Weapons</h3>' +
      '<p class="step-desc">Select up to 2 starting weapons (Tier 1-2). First selection is Main Hand, second is Off-Hand. You may select the same weapon twice for dual-wielding.</p>';

    // Current weapon selections summary
    if (weaponSlots > 0) {
      html += '<div class="weapon-summary">';
      char.selectedWeapons.forEach(function(w, idx) {
        var handLabel = idx === 0 ? 'Main Hand' : 'Off-Hand';
        var penalty = '';
        if (idx === 1) {
          var isLight = w.properties && w.properties.indexOf('light') > -1;
          penalty = isLight ? ' <span class="equip-note-inline">(no penalty)</span>' : ' <span class="equip-warning-inline">(-2 attack)</span>';
        }
        html += '<div class="weapon-slot">' +
          '<span class="weapon-slot-label">' + handLabel + ':</span> ' +
          '<strong>' + w.name + '</strong> — ' + w.damage + (w.cost ? ' — ' + w.cost + ' cr' : '') + penalty +
          ' <button class="weapon-remove-btn" data-remove-weapon="' + idx + '" title="Remove">×</button>' +
          '</div>';
      });
      html += '</div>';
    }

    html += '<div class="equip-catalog">';
    allWeapons.forEach(function(w) {
      var selectCount = char.selectedWeapons.filter(function(sw) { return sw.name === w.name; }).length;
      var isSelected = selectCount > 0;
      var statLabel = w.stat || (w.range ? 'AGI' : 'MIG');
      var costStr = w.cost ? ' — ' + w.cost + ' cr' : '';
      // Can add another if there are open slots and player can afford it
      var canAdd = weaponSlots < 2 && (w.cost || 0) <= creditsLeft;
      var cantAfford = !canAdd && !isSelected;
      html += '<div class="equip-item-wrap">' +
        '<button class="equip-item' + (isSelected ? ' selected' : '') + ((!canAdd && !isSelected) ? ' disabled-aug' : '') + '" data-type="weapon" data-name="' + w.name + '"' + ((!canAdd && !isSelected) ? ' disabled title="' + (weaponSlots >= 2 ? 'Both weapon slots full' : 'Not enough credits') + '"' : '') + '>' +
        '<span class="equip-name">' + w.name + (selectCount > 0 ? ' <span class="weapon-qty">×' + selectCount + '</span>' : '') + '</span>' +
        '<span class="equip-stat">' + w.damage + ' (' + statLabel + ')' + costStr + '</span>' +
        (w.range ? '<span class="equip-range">Range: ' + w.range + '</span>' : '') +
        (w.properties && w.properties.length ? '<span class="equip-props">' + w.properties.join(', ') + '</span>' : '') +
        '</button>';
      // Show +/- controls for selected weapons
      if (isSelected) {
        html += '<div class="weapon-qty-controls">' +
          '<button class="qty-btn qty-minus" data-weapon-minus="' + w.name + '" title="Remove one">−</button>' +
          '<span class="qty-display">' + selectCount + '</span>' +
          '<button class="qty-btn qty-plus' + (!canAdd ? ' disabled-aug' : '') + '" data-weapon-plus="' + w.name + '"' + (!canAdd ? ' disabled title="' + (weaponSlots >= 2 ? 'Both weapon slots full' : 'Not enough credits') + '"' : '') + ' title="Add another">+</button>' +
          '</div>';
      }
      html += '</div>';
    });
    html += '</div></div>';

    // Armor selection
    var profMap = {};
    (cls.armor_proficiency || []).forEach(function(p) { profMap[p.toLowerCase()] = true; });
    var armorGroups = [];
    var tierFilter = function(items) { return (items || []).filter(function(i) { return i.tier <= 2; }); };
    if (profMap.light) armorGroups.push({label: 'Light Armor (max AGI +5)', items: tierFilter(eq.light_armor)});
    if (profMap.medium) armorGroups.push({label: 'Medium Armor (max AGI +3)', items: tierFilter(eq.medium_armor)});
    if (profMap.heavy) armorGroups.push({label: 'Heavy Armor (max AGI +1)', items: tierFilter(eq.heavy_armor)});

    if (armorGroups.length) {
      html += '<div class="equip-section"><h3>Choose Armor</h3>';
      armorGroups.forEach(function(group) {
        html += '<h5>' + group.label + '</h5><div class="equip-catalog">';
        group.items.forEach(function(a) {
          var isSelected = char.selectedArmor && char.selectedArmor.name === a.name;
          var aCostStr = a.cost ? ' — ' + a.cost + ' cr' : '';
          // Can afford: if selecting new armor, need to afford the difference (refund current if switching)
          var switchCost = (a.cost || 0) - (char.selectedArmor && !isSelected ? (char.selectedArmor.cost || 0) : 0);
          var cantAffordArmor = !isSelected && switchCost > creditsLeft;
          html += '<button class="equip-item' + (isSelected ? ' selected' : '') + (cantAffordArmor ? ' disabled-aug' : '') + '" data-type="armor" data-name="' + a.name + '"' + (cantAffordArmor ? ' disabled title="Not enough credits"' : '') + '>' +
            '<span class="equip-name">' + a.name + '</span>' +
            '<span class="equip-stat">+' + a.dv_bonus + ' DV' + aCostStr + '</span>' +
            (a.special ? '<span class="equip-props">' + a.special + '</span>' : '') +
            '</button>';
        });
        html += '</div>';
      });
      html += '</div>';
    }

    // Shield selection
    var startingShields = (eq.shields || []).filter(function(s) { return s.tier <= 2; });
    if (profMap.shields && startingShields.length) {
      html += '<div class="equip-section"><h3>Choose Shield (Optional)</h3><div class="equip-catalog">';
      html += '<button class="equip-item' + (!char.selectedShield ? ' selected' : '') + '" data-type="shield" data-name="none"><span class="equip-name">No Shield</span></button>';
      startingShields.forEach(function(s) {
        var isSelected = char.selectedShield && char.selectedShield.name === s.name;
        var sCostStr = s.cost ? ' — ' + s.cost + ' cr' : '';
        var switchCostS = (s.cost || 0) - (char.selectedShield && !isSelected ? (char.selectedShield.cost || 0) : 0);
        var cantAffordShield = !isSelected && switchCostS > creditsLeft;
        html += '<button class="equip-item' + (isSelected ? ' selected' : '') + (cantAffordShield ? ' disabled-aug' : '') + '" data-type="shield" data-name="' + s.name + '"' + (cantAffordShield ? ' disabled title="Not enough credits"' : '') + '>' +
          '<span class="equip-name">' + s.name + '</span>' +
          '<span class="equip-stat">+' + s.dv_bonus + ' DV' + (s.special ? ' | ' + s.special : '') + sCostStr + '</span></button>';
      });
      html += '</div></div>';
    }

    // Augmentations
    if (eq.augmentations && eq.augmentations.length) {
      var augHumanity = getHumanitySpent();
      var baseHum = cls.starting_humanity;
      var currentHum = Math.max(0, baseHum - augHumanity);
      var spellInfo = getSpellSlotsAfterHumanity(cls);

      html += '<div class="equip-section wide"><h3>Augmentations (Optional)</h3>' +
        '<p class="step-desc">Each augmentation reduces your Humanity. Humanity cannot go below 0. ' +
        'Current: <strong class="' + (currentHum <= 3 ? 'aug-warning' : '') + '">' + currentHum + '</strong> / ' + baseHum + ' Humanity</p>';

      // Show spell slot loss warning for casters
      if (cls.spell_slots && cls.spell_slots.length && augHumanity > 0) {
        html += '<div class="aug-spell-warning"><strong>Spell Slots Lost:</strong> ';
        var slotEntryForWarning = getSpellSlotEntry(cls);
        var baseSlots = (slotEntryForWarning ? slotEntryForWarning.slots : []) || [];
        var lostTiers = [];
        for (var si = baseSlots.length - 1; si >= 0; si--) {
          if (baseSlots[si] > 0 && spellInfo.slots[si] === 0) {
            lostTiers.push(ordinal(si + 1) + '-level');
          }
        }
        if (lostTiers.length) html += lostTiers.join(', ');
        if ((cls.starting_cantrips || 0) > 0 && spellInfo.cantrips === 0) {
          html += (lostTiers.length ? ', ' : '') + 'Cantrips';
        }
        if (!lostTiers.length && spellInfo.cantrips > 0) html += 'None yet';
        html += '</div>';
      }

      [1, 2, 3].forEach(function(tier) {
        var tierAugs = eq.augmentations.filter(function(a) { return a.tier === tier; });
        if (tierAugs.length) {
          html += '<h5>Tier ' + tier + ' (Cost: ' + tier + ' Humanity)</h5><div class="equip-catalog">';
          tierAugs.forEach(function(aug) {
            var isSelected = char.selectedAugments.some(function(sa) { return sa.name === aug.name; });
            var wouldExceedHum = !isSelected && (currentHum - aug.humanity_cost < 0);
            var wouldExceedCr = !isSelected && (aug.cost || 0) > creditsLeft;
            var augDisabled = wouldExceedHum || wouldExceedCr;
            var augDisabledReason = wouldExceedHum ? 'Not enough Humanity' : (wouldExceedCr ? 'Not enough credits' : '');
            var augCostStr = aug.cost ? ' | ' + aug.cost + ' cr' : '';
            html += '<button class="equip-item' + (isSelected ? ' selected' : '') + (augDisabled ? ' disabled-aug' : '') + '" data-type="augment" data-name="' + aug.name + '"' + (augDisabled ? ' disabled title="' + augDisabledReason + '"' : '') + '>' +
              '<span class="equip-name">' + aug.name + '</span>' +
              '<span class="equip-stat">-' + aug.humanity_cost + ' HUM' + augCostStr + '</span>' +
              '<span class="equip-props">' + aug.effect + '</span></button>';
          });
          html += '</div>';
        }
      });
      html += '</div>';
    }

    // Cantrip selection for caster classes
    var cantripMax = getCantripsForLevel(cls);
    if (cantripMax > 0 && GAME.cantrips && GAME.cantrips.length) {
      html += '<div class="equip-section wide"><h3>Choose Cantrips (' + cantripMax + ')</h3>' +
        '<p class="step-desc">Select ' + cantripMax + ' cantrips to learn.</p>' +
        '<div class="equip-catalog">';
      GAME.cantrips.forEach(function(ct) {
        var isSelected = char.selectedCantrips.indexOf(ct.name) > -1;
        html += '<button class="equip-item cantrip-item' + (isSelected ? ' selected' : '') + '" data-type="cantrip" data-name="' + ct.name + '">' +
          '<span class="equip-name">' + ct.name + '</span>' +
          '<span class="equip-stat">' + ct.type + '</span>' +
          '<span class="equip-range">' + ct.range + '</span>' +
          '<span class="equip-props">' + ct.effect + '</span></button>';
      });
      html += '</div></div>';
    }

    panel.innerHTML = html;

    // Bind weapon card clicks — add weapon if slots available
    $$('.equip-item[data-type="weapon"]:not([disabled])', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (char.selectedWeapons.length >= 2) return;
        var wName = btn.getAttribute('data-name');
        var weapon = allWeapons.find(function(w) { return w.name === wName; });
        if (weapon && getRemainingCredits() >= (weapon.cost || 0)) {
          char.selectedWeapons.push(weapon);
        }
        renderEquipment();
      });
    });

    // Bind +/- quantity controls for weapons
    $$('[data-weapon-plus]:not([disabled])', panel).forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        if (char.selectedWeapons.length >= 2) return;
        var wName = btn.getAttribute('data-weapon-plus');
        var weapon = allWeapons.find(function(w) { return w.name === wName; });
        if (weapon && getRemainingCredits() >= (weapon.cost || 0)) {
          char.selectedWeapons.push(weapon);
        }
        renderEquipment();
      });
    });

    $$('[data-weapon-minus]', panel).forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var wName = btn.getAttribute('data-weapon-minus');
        // Remove last instance of this weapon
        for (var i = char.selectedWeapons.length - 1; i >= 0; i--) {
          if (char.selectedWeapons[i].name === wName) {
            char.selectedWeapons.splice(i, 1);
            break;
          }
        }
        renderEquipment();
      });
    });

    // Bind remove buttons in weapon summary
    $$('[data-remove-weapon]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = Number(btn.getAttribute('data-remove-weapon'));
        if (idx >= 0 && idx < char.selectedWeapons.length) {
          char.selectedWeapons.splice(idx, 1);
        }
        renderEquipment();
      });
    });

    // Bind armor clicks
    $$('.equip-item[data-type="armor"]:not([disabled])', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var aName = btn.getAttribute('data-name');
        var allArmor = (eq.light_armor || []).concat(eq.medium_armor || []).concat(eq.heavy_armor || []);
        var armor = allArmor.find(function(a) { return a.name === aName; });
        if (char.selectedArmor && char.selectedArmor.name === aName) {
          char.selectedArmor = null; // Deselect (refunds credits)
        } else if (armor) {
          // Check if we can afford: credits remaining + refund from current armor
          var refund = char.selectedArmor ? (char.selectedArmor.cost || 0) : 0;
          if (getRemainingCredits() + refund >= (armor.cost || 0)) {
            char.selectedArmor = armor;
          }
        }
        renderEquipment();
      });
    });

    // Bind shield clicks
    $$('.equip-item[data-type="shield"]:not([disabled])', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var sName = btn.getAttribute('data-name');
        if (sName === 'none') {
          char.selectedShield = null;
        } else {
          var shield = (eq.shields || []).find(function(s) { return s.name === sName; });
          if (char.selectedShield && char.selectedShield.name === sName) {
            char.selectedShield = null;
          } else if (shield) {
            var refund = char.selectedShield ? (char.selectedShield.cost || 0) : 0;
            if (getRemainingCredits() + refund >= (shield.cost || 0)) {
              char.selectedShield = shield;
            }
          }
        }
        renderEquipment();
      });
    });

    // Bind augment clicks
    $$('.equip-item[data-type="augment"]:not([disabled])', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var augName = btn.getAttribute('data-name');
        var existing = -1;
        char.selectedAugments.forEach(function(sa, i) { if (sa.name === augName) existing = i; });
        if (existing > -1) {
          char.selectedAugments.splice(existing, 1);
        } else {
          var aug = (eq.augmentations || []).find(function(a) { return a.name === augName; });
          if (aug) {
            var currentHum = calcHumanity(cls);
            if (currentHum - aug.humanity_cost < 0) return; // Can't go below 0
            if (getRemainingCredits() < (aug.cost || 0)) return; // Can't afford
            char.selectedAugments.push(aug);
          }
        }
        renderEquipment();
      });
    });

    // Bind cantrip clicks
    $$('.equip-item[data-type="cantrip"]', panel).forEach(function(btn) {
      btn.addEventListener('click', function() {
        var ctName = btn.getAttribute('data-name');
        var idx = char.selectedCantrips.indexOf(ctName);
        if (idx > -1) {
          char.selectedCantrips.splice(idx, 1);
        } else if (char.selectedCantrips.length < getCantripsForLevel(cls)) {
          char.selectedCantrips.push(ctName);
        }
        renderEquipment();
      });
    });

    // Bind credits input
    var creditsInput = el('credits-input');
    if (creditsInput) {
      creditsInput.addEventListener('change', function() {
        var val = Math.max(20, Math.min(120, Number(creditsInput.value) || 70));
        char.startingCredits = val;
        // If over budget, unselect items until balanced
        while (getRemainingCredits() < 0) {
          // Remove most expensive augment first, then shield, then armor, then last weapon
          if (char.selectedAugments.length > 0) {
            char.selectedAugments.pop();
          } else if (char.selectedShield) {
            char.selectedShield = null;
          } else if (char.selectedArmor) {
            char.selectedArmor = null;
          } else if (char.selectedWeapons.length > 0) {
            char.selectedWeapons.pop();
          } else {
            break; // Safety: shouldn't happen
          }
        }
        renderEquipment();
      });
    }
  }

  // ---- Step 7: Summary ----
  // Helper: compute effective attributes with ASIs applied
  function getEffectiveAttrs() {
    var ea = {};
    ATTR_NAMES.forEach(function(at) { ea[at] = char.attributes[at] || 8; });
    Object.keys(char.selectedASIs).forEach(function(lv) {
      if (Number(lv) <= char.level) {
        var asi = char.selectedASIs[lv];
        if (asi.mode === '+2' && asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 2);
        if (asi.mode === '+1+1') {
          if (asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 1);
          if (asi.attr2) ea[asi.attr2] = Math.min(20, ea[asi.attr2] + 1);
        }
      }
    });
    return ea;
  }

  // Helper: determine if a weapon is melee or ranged
  function isRangedWeapon(w) {
    var eq = GAME.equipment;
    return (eq.ranged_weapons || []).some(function(rw) { return rw.name === w.name; });
  }

  // Helper: compute weapon attack bonus and damage string
  function getWeaponAttackInfo(w, idx, effectiveAttrs, profBonus) {
    var isRanged = isRangedWeapon(w);
    var attrMod = isRanged ? getMod(effectiveAttrs.AGI) : getMod(effectiveAttrs.MIG);
    var attackBonus = attrMod + profBonus;
    var offHandPenalty = 0;
    if (idx === 1) {
      var isLight = w.properties && w.properties.indexOf('light') > -1;
      offHandPenalty = isLight ? 0 : -2;
    }
    var totalAttack = attackBonus + offHandPenalty;
    // Damage: melee adds MIG mod, ranged does not (unless special)
    var damageStr = w.damage;
    if (!isRanged && getMod(effectiveAttrs.MIG) !== 0) {
      damageStr += (getMod(effectiveAttrs.MIG) >= 0 ? '+' : '') + getMod(effectiveAttrs.MIG);
    }
    return {
      attackBonus: totalAttack,
      damageStr: damageStr,
      isRanged: isRanged,
      attrUsed: isRanged ? 'AGI' : 'MIG'
    };
  }

  function renderSummary() {
    var sheet = el('summary-sheet');
    var cls = char.class;
    var sp = char.species;
    var bg = char.background;

    if (!cls || !sp || !bg) {
      sheet.innerHTML = '<p class="muted">Complete all steps to see your character summary.</p>';
      return;
    }

    var effectiveAttrs = getEffectiveAttrs();
    var endMod = getMod(effectiveAttrs.END);
    var agiMod = getMod(effectiveAttrs.AGI);
    var migMod = getMod(effectiveAttrs.MIG);
    var intMod = getMod(effectiveAttrs.INT);
    var wisMod = getMod(effectiveAttrs.WIS);
    var preMod = getMod(effectiveAttrs.PRE);
    var hpPerLevel = cls.hp_per_level || Math.floor(parseInt(cls.hit_die.replace('d','')) / 2) + 1;
    var hp = cls.hp_base + endMod + (char.level - 1) * (hpPerLevel + endMod);
    var dv = calcDV(agiMod, char.selectedArmor, char.selectedShield);
    var humanity = calcHumanity(cls);
    var profBonus = getProfBonus(char.level);
    var totalAP = getTotalAP();
    var spentAP = char.purchasedAbilities.reduce(function(s, ab) { return s + ab.ap_cost; }, 0);
    var hitDiceCount = Math.max(1, Math.floor(char.level / 2));

    var trainedSaves = {};
    (cls.save_proficiencies || []).forEach(function(s) { trainedSaves[s] = true; });
    var fortTotal = Math.max(endMod, migMod) + (trainedSaves.Fortitude ? profBonus : 0);
    var refTotal = Math.max(agiMod, wisMod) + (trainedSaves.Reflex ? profBonus : 0);
    var willTotal = Math.max(wisMod, preMod) + (trainedSaves.Will ? profBonus : 0);

    // Spell save DC and attack modifier for casters
    var isCaster = cls.spell_slots && cls.spell_slots.length > 0;
    var spellAttr = cls.magic_type && cls.magic_type.indexOf('WIS') > -1 ? 'WIS' : 'INT';
    // Channeler and Medic use WIS, Mystic uses INT
    if (cls.name === 'Channeler' || cls.name === 'Medic') spellAttr = 'WIS';
    if (cls.name === 'Mystic') spellAttr = 'INT';
    var spellMod = getMod(effectiveAttrs[spellAttr]);
    var spellSaveDC = 8 + profBonus + spellMod;
    var spellAttackMod = profBonus + spellMod;

    var choiceNotes = [];
    Object.keys(char.speciesChoices).forEach(function(trait) {
      choiceNotes.push(trait + ': ' + char.speciesChoices[trait]);
    });

    // ========== BUILD HTML ==========
    var html = '';

    // ---- HEADER ----
    html += '<div class="sheet-header">' +
      '<div class="sheet-name"><label>Character Name</label>' +
      '<input type="text" id="char-name" class="name-input" placeholder="Enter name..." value="' + (char.name || '') + '" /></div>' +
      '<div class="sheet-meta">' +
      '<span class="meta-item">' + sp.name + '</span>' +
      '<span class="meta-item">' + bg.name + '</span>' +
      '<span class="meta-item">' + cls.name + '</span>' +
      '<span class="meta-item">Level ' + char.level + '</span>' +
      '</div></div>';

    html += '<div class="sheet-grid">';

    // ---- ATTRIBUTES (modifier-first layout) ----
    html += '<div class="sheet-section"><h3>Attributes</h3><div class="sheet-attrs">' +
      GAME.attributes.map(function(attr) {
        var eff = effectiveAttrs[attr];
        var m = getMod(eff);
        var base = char.attributes[attr] || 8;
        var asiDelta = eff - base;
        return '<div class="sheet-attr">' +
          '<span class="sheet-attr-name">' + (GAME.attribute_names[attr] || attr) + '</span>' +
          '<span class="sheet-attr-mod">' + modStr(m) + '</span>' +
          '<span class="sheet-attr-score">' + eff + (asiDelta > 0 ? '<span class="asi-delta">+' + asiDelta + '</span>' : '') + '</span>' +
          '</div>';
      }).join('') +
      '</div></div>';

    // ---- COMBAT STATS ----
    html += '<div class="sheet-section"><h3>Combat Stats</h3>' +
      '<div class="combat-stats-prominent">' +
      '<div class="combat-stat-big"><span class="stat-value">' + hp + '</span><span class="stat-label">HP</span></div>' +
      '<div class="combat-stat-big"><span class="stat-value">' + dv + '</span><span class="stat-label">DV</span></div>' +
      '<div class="combat-stat-big"><span class="stat-value">' + modStr(agiMod + profBonus) + '</span><span class="stat-label">Initiative</span></div>' +
      '<div class="combat-stat-big"><span class="stat-value">' + GAME.base_movement + '</span><span class="stat-label">Speed (ft)</span></div>' +
      '</div>' +
      '<div class="combat-stats">' +
      '<div class="combat-stat"><span>Hit Die</span><strong>' + cls.hit_die + '</strong></div>' +
      '<div class="combat-stat"><span>Humanity</span><strong>' + humanity + '</strong></div>' +
      '<div class="combat-stat"><span>Prof. Bonus</span><strong>+' + profBonus + '</strong></div>' +
      '<div class="combat-stat"><span>AP</span><strong>' + totalAP + ' (' + (totalAP - spentAP) + ' left)</strong></div>' +
      '</div></div>';

    // ---- SAVING THROWS ----
    html += '<div class="sheet-section"><h3>Saving Throws</h3><div class="save-list">' +
      '<div class="save-row' + (trainedSaves.Fortitude ? ' trained' : '') + '"><span>FORT</span><strong>' + modStr(fortTotal) + '</strong></div>' +
      '<div class="save-row' + (trainedSaves.Reflex ? ' trained' : '') + '"><span>REF</span><strong>' + modStr(refTotal) + '</strong></div>' +
      '<div class="save-row' + (trainedSaves.Will ? ' trained' : '') + '"><span>WILL</span><strong>' + modStr(willTotal) + '</strong></div>' +
      '</div></div>';

    // ---- ATTACKS (pre-calculated) ----
    html += '<div class="sheet-section wide"><h3>Attacks</h3>';
    if (char.selectedWeapons.length > 0) {
      html += '<div class="attacks-grid">';
      char.selectedWeapons.forEach(function(w, idx) {
        var info = getWeaponAttackInfo(w, idx, effectiveAttrs, profBonus);
        var handLabel = idx === 0 ? 'Main Hand' : 'Off-Hand';
        html += '<div class="attack-card">' +
          '<div class="attack-header"><strong>' + w.name + '</strong><span class="attack-hand">' + handLabel + '</span></div>' +
          '<div class="attack-numbers">' +
          '<div class="attack-roll"><span class="attack-roll-label">Attack</span><span class="attack-roll-value">' + modStr(info.attackBonus) + '</span></div>' +
          '<div class="attack-damage"><span class="attack-damage-label">Damage</span><span class="attack-damage-value">' + info.damageStr + '</span></div>' +
          '</div>' +
          '<div class="attack-details">' +
          '<span>' + info.attrUsed + ' + Prof</span>' +
          (w.range ? '<span>' + w.range + '</span>' : '<span>Melee</span>') +
          (w.properties && w.properties.length ? '<span>' + w.properties.join(', ') + '</span>' : '') +
          '</div></div>';
      });
      html += '</div>';
    } else {
      // Unarmed strike
      var unarmedAtk = migMod + profBonus;
      html += '<div class="attacks-grid"><div class="attack-card">' +
        '<div class="attack-header"><strong>Unarmed Strike</strong></div>' +
        '<div class="attack-numbers">' +
        '<div class="attack-roll"><span class="attack-roll-label">Attack</span><span class="attack-roll-value">' + modStr(unarmedAtk) + '</span></div>' +
        '<div class="attack-damage"><span class="attack-damage-label">Damage</span><span class="attack-damage-value">1' + (migMod !== 0 ? (migMod > 0 ? '+' : '') + migMod : '') + '</span></div>' +
        '</div><div class="attack-details"><span>MIG + Prof</span><span>Melee</span></div></div></div>';
    }
    // Spell attack if caster
    if (isCaster) {
      html += '<div class="spell-combat-stats">' +
        '<div class="spell-stat"><span>Spell Save DC</span><strong>' + spellSaveDC + '</strong></div>' +
        '<div class="spell-stat"><span>Spell Attack</span><strong>' + modStr(spellAttackMod) + '</strong></div>' +
        '<div class="spell-stat"><span>Spellcasting Attr</span><strong>' + spellAttr + ' (' + modStr(spellMod) + ')</strong></div>' +
        '</div>';
    }
    html += '</div>';

    // ---- TRACKING SECTION ----
    html += '<div class="sheet-section wide"><h3>Session Tracker</h3>' +
      '<div class="tracker-grid">' +
      // HP tracker
      '<div class="tracker-block">' +
      '<h4>Hit Points</h4>' +
      '<div class="tracker-hp">' +
      '<div class="hp-current"><label>Current</label><input type="number" class="hp-input" id="hp-current" value="' + hp + '" min="0" max="' + hp + '" /></div>' +
      '<div class="hp-max"><label>Max</label><span>' + hp + '</span></div>' +
      '<div class="hp-temp"><label>Temp</label><input type="number" class="hp-input" id="hp-temp" value="0" min="0" /></div>' +
      '</div></div>' +
      // Hit Dice
      '<div class="tracker-block">' +
      '<h4>Hit Dice (' + hitDiceCount + cls.hit_die + ')</h4>' +
      '<p class="tracker-hint">Short rest: recover ' + hitDiceCount + ' HD, spend to heal (roll + END mod)</p>' +
      '<div class="tracker-checkboxes" id="hd-tracker">';
    for (var hdi = 0; hdi < char.level; hdi++) {
      html += '<label class="tracker-check"><input type="checkbox" /><span>' + cls.hit_die + '</span></label>';
    }
    html += '</div></div>';
    // Spell slot tracker (for casters)
    if (isCaster) {
      var adjSpells = getSpellSlotsAfterHumanity(cls);
      html += '<div class="tracker-block">' +
        '<h4>Spell Slots</h4>' +
        '<p class="tracker-hint">Short rest: recover 1 slot (3rd level or lower)</p>';
      adjSpells.slots.forEach(function(count, i) {
        if (count > 0) {
          html += '<div class="spell-slot-tracker"><span class="slot-level">' + ordinal(i + 1) + '</span>';
          for (var si = 0; si < count; si++) {
            html += '<label class="tracker-check slot"><input type="checkbox" /><span></span></label>';
          }
          html += '</div>';
        }
      });
      html += '</div>';
    }
    // Exhaustion tracker
    html += '<div class="tracker-block">' +
      '<h4>Exhaustion</h4>' +
      '<div class="exhaustion-track">' +
      '<label class="exhaust-level"><input type="radio" name="exhaustion" value="0" checked /><span>None</span></label>' +
      '<label class="exhaust-level"><input type="radio" name="exhaustion" value="1" /><span>1: Disadv. checks, -5 speed</span></label>' +
      '<label class="exhaust-level"><input type="radio" name="exhaustion" value="2" /><span>2: +Disadv. attacks, half carry</span></label>' +
      '<label class="exhaust-level"><input type="radio" name="exhaustion" value="3" /><span>3: +Disadv. saves, -25% max HP</span></label>' +
      '<label class="exhaust-level"><input type="radio" name="exhaustion" value="4" /><span>4: +Half speed, -50% max HP</span></label>' +
      '<label class="exhaust-level"><input type="radio" name="exhaustion" value="5" /><span>5: +5ft speed, -75% max HP</span></label>' +
      '<label class="exhaust-level"><input type="radio" name="exhaustion" value="6" /><span>6: Death</span></label>' +
      '</div></div>' +
      // Notes
      '<div class="tracker-block">' +
      '<h4>Session Notes</h4>' +
      '<textarea class="session-notes" placeholder="Track conditions, consumables, stims used (max 2/day), injuries..."></textarea>' +
      '</div>' +
      '</div></div>';

    // ---- ACTION ECONOMY REFERENCE ----
    html += '<div class="sheet-section wide"><h3>Action Economy</h3>' +
      '<div class="action-ref">' +
      '<div class="action-ref-header">' +
      '<div class="action-budget"><span class="action-count">3</span> Actions</div>' +
      '<div class="action-budget reaction"><span class="action-count">1</span> Reaction</div>' +
      '<div class="action-budget free"><span class="action-count">\u221E</span> Free Actions</div>' +
      '</div>' +
      '<div class="action-columns">' +
      '<div class="action-col">' +
      '<h4>1-Action</h4>' +
      '<ul>' +
      '<li><strong>Strike:</strong> Attack with weapon</li>' +
      '<li><strong>Stride:</strong> Move up to ' + GAME.base_movement + ' ft</li>' +
      '<li><strong>Step:</strong> Move 5 ft (no reactions)</li>' +
      '<li><strong>Aim:</strong> +2 next ranged attack</li>' +
      '<li><strong>Reload:</strong> Reload weapon</li>' +
      '<li><strong>Draw/Stow:</strong> Ready or put away item</li>' +
      '<li><strong>Cast Spell:</strong> Cast a 1-action spell</li>' +
      '<li><strong>Use Item:</strong> Potion, stim, device</li>' +
      '<li><strong>Grapple/Shove:</strong> Contested MIG check</li>' +
      '</ul></div>' +
      '<div class="action-col">' +
      '<h4>2-Action</h4>' +
      '<ul>' +
      '<li><strong>Full Auto Burst:</strong> 3 targets in 10ft, -2</li>' +
      '<li><strong>Power Strike:</strong> +4 dmg, -2 to hit</li>' +
      '<li><strong>Field Medicine:</strong> 2d6+WIS HP (DC 15)</li>' +
      '<li><strong>Ready Action:</strong> Set trigger (uses reaction)</li>' +
      '</ul>' +
      '<h4>3-Action</h4>' +
      '<ul>' +
      '<li><strong>All-Out Attack:</strong> 3 strikes (0/-3/-6)</li>' +
      '<li><strong>Sprint:</strong> Triple speed, straight line</li>' +
      '</ul></div>' +
      '<div class="action-col">' +
      '<h4>Reactions</h4>' +
      '<ul>' +
      '<li><strong>Attack of Opportunity:</strong> Strike leaving reach</li>' +
      '<li><strong>Deflect:</strong> 1d10+AGI vs ranged (free hand)</li>' +
      '<li><strong>Dive for Cover:</strong> Move 10ft from AoE</li>' +
      '<li><strong>Counterspell:</strong> Disrupt spell (caster)</li>' +
      '<li><strong>Return Fire:</strong> Shoot back (loaded wpn)</li>' +
      '</ul></div>' +
      '</div></div></div>';

    // ---- COMBAT QUICK REFERENCE ----
    html += '<div class="sheet-section wide"><h3>Combat Reference</h3>' +
      '<div class="combat-ref-grid">' +
      '<div class="ref-block">' +
      '<h4>Multiple Attack Penalty</h4>' +
      '<div class="map-table">' +
      '<div class="map-row"><span>1st Strike</span><strong>+0</strong></div>' +
      '<div class="map-row"><span>2nd Strike</span><strong>-3</strong></div>' +
      '<div class="map-row"><span>3rd Strike</span><strong>-6</strong></div>' +
      '</div>' +
      '<p class="ref-note">Extra Attack feature: no MAP on bonus attack</p>' +
      '</div>' +
      '<div class="ref-block">' +
      '<h4>Attack Modifiers</h4>' +
      '<ul>' +
      '<li><strong>Flanking:</strong> +2 melee (you + ally opposite)</li>' +
      '<li><strong>High Ground:</strong> +2 ranged</li>' +
      '<li><strong>Cover:</strong> +2 DV (partial) / +5 DV (heavy)</li>' +
      '<li><strong>Prone Target:</strong> Adv. melee, disadv. ranged</li>' +
      '<li><strong>Ranged in Melee:</strong> Disadv. on ranged attacks</li>' +
      '</ul></div>' +
      '<div class="ref-block">' +
      '<h4>Critical Hits &amp; Misses</h4>' +
      '<ul>' +
      '<li><strong>Nat 20:</strong> Auto-hit, double weapon dice</li>' +
      '<li><strong>Nat 1:</strong> Auto-miss</li>' +
      '</ul>' +
      '<h4>Advantage / Disadvantage</h4>' +
      '<ul><li>Roll 2d20, take highest / lowest</li></ul>' +
      '</div>' +
      '</div></div>';

    // ---- SKILL PROFICIENCIES ----
    html += '<div class="sheet-section wide"><h3>Skill Proficiencies</h3>' +
      (function() {
        var profSkills = getAllProficientSkills();
        var expertSkills = getAllExpertiseSkills();
        var autoSkills = getAutoSkills();
        var h = '<div class="prof-summary-grid">';
        GAME.skills.forEach(function(sk) {
          var isProficient = !!profSkills[sk.name];
          var isExpert = !!expertSkills[sk.name];
          if (!isProficient && !isExpert) return;
          var primaryAttr = sk.attribute.split('/')[0];
          var attrScore = effectiveAttrs[primaryAttr] || 10;
          var mod = getMod(attrScore);
          var bonus = isExpert ? mod + (profBonus * 2) : mod + profBonus;
          var source = autoSkills[sk.name] ? 'Class/BG' :
            char.chosenProficiencies.indexOf(sk.name) > -1 ? 'Chosen' : 'Leveled';
          h += '<div class="prof-row' + (isExpert ? ' expert' : '') + '">' +
            '<span class="prof-name">' + sk.name + '</span>' +
            '<span class="prof-bonus">' + modStr(bonus) + '</span>' +
            '<span class="prof-tier">' + (isExpert ? 'Expert' : 'Prof') + '</span>' +
            '<span class="prof-source">' + source + '</span></div>';
        });
        h += '</div>';
        return h;
      })() + '</div>';

    // ---- SPECIES ----
    html += '<div class="sheet-section"><h3>Species: ' + sp.name + '</h3>' +
      '<p class="detail-bonus">' + sp.attribute_bonus + '</p>' +
      '<ul>' + sp.traits.map(function(t) { return '<li><strong>' + t.name + ':</strong> ' + t.effect + '</li>'; }).join('') + '</ul>' +
      (choiceNotes.length ? '<p class="choice-notes">' + choiceNotes.join(', ') + '</p>' : '') +
      '</div>';

    // ---- BACKGROUND ----
    html += '<div class="sheet-section"><h3>Background: ' + bg.name + '</h3>' +
      '<p>' + bg.skill_bonus + '</p>' +
      '<p><strong>Feature:</strong> ' + bg.feature + '</p></div>';

    // ---- CLASS FEATURES ----
    html += '<div class="sheet-section wide"><h3>' + cls.name + ' Features</h3>' +
      '<div class="feature-tags">' + (cls.level_1_features || []).map(function(f) { return '<span class="feature-tag">' + f + '</span>'; }).join('') + '</div>' +
      (char.selectedDoctrine ?
        '<h4>Doctrine</h4><div class="tree-summary"><strong>' + char.selectedDoctrine.name + '</strong> &mdash; ' + char.selectedDoctrine.effect + '</div>' : '') +
      (function() {
        var keys = Object.keys(char.featureChoices);
        if (!keys.length) return '';
        return '<h4>Feature Choices</h4>' +
          keys.map(function(feat) {
            var choiceName = char.featureChoices[feat];
            var choiceEffect = '';
            (cls.features || []).forEach(function(f) {
              if (f.name === feat && f.choices) {
                f.choices.forEach(function(c) {
                  if (c.name === choiceName) choiceEffect = c.effect;
                });
              }
            });
            return '<div class="tree-summary"><strong>' + feat + ':</strong> ' + choiceName +
              (choiceEffect ? ' <span style="color:var(--text-muted);font-size:0.8rem">\u2014 ' + choiceEffect + '</span>' : '') + '</div>';
          }).join('');
      })() +
      (char.purchasedAbilities.length > 0 ?
        '<h4>Purchased Abilities</h4>' +
        (function() {
          var byTree = {};
          char.purchasedAbilities.forEach(function(p) {
            if (!byTree[p.treeName]) byTree[p.treeName] = [];
            byTree[p.treeName].push(p);
          });
          return Object.keys(byTree).map(function(treeName) {
            return '<div class="tree-summary"><strong>' + treeName + '</strong>' +
              '<ul>' + byTree[treeName].map(function(ab) { return '<li>' + ab.abilityName + ' \u2014 ' + ab.ap_cost + ' AP (T' + ab.tier + ')</li>'; }).join('') + '</ul></div>';
          }).join('');
        })() : '<p class="muted">No abilities purchased yet.</p>') +
      '</div>';

    // ---- SPELL SLOTS ----
    if (isCaster) {
      html += '<div class="sheet-section"><h3>Spell Slots' + (getHumanitySpent() > 0 ? ' <span class="aug-warning-sm">(reduced by augmentations)</span>' : '') + '</h3>' +
        '<div class="spell-slot-display">';
      var adjSpellsDisplay = getSpellSlotsAfterHumanity(cls);
      adjSpellsDisplay.slots.forEach(function(count, i) {
        if (count > 0) html += '<span class="slot-badge">' + count + ' x ' + ordinal(i + 1) + '-level</span>';
      });
      if (adjSpellsDisplay.cantrips > 0) html += '<span class="slot-badge cantrip-badge">' + adjSpellsDisplay.cantrips + ' Cantrips</span>';
      if (adjSpellsDisplay.cantrips === 0 && (cls.starting_cantrips || 0) > 0) html += '<span class="slot-badge lost-badge">Cantrips Lost</span>';
      html += '</div></div>';
    }

    // ---- EQUIPMENT ----
    html += '<div class="sheet-section"><h3>Equipment</h3>';
    if (char.selectedWeapons.length > 0) {
      html += '<h4>Weapons</h4><ul>' + char.selectedWeapons.map(function(w, idx) {
        var handLabel = idx === 0 ? '[Main Hand]' : '[Off-Hand]';
        var penalty = '';
        if (idx === 1) {
          var isLight = w.properties && w.properties.indexOf('light') > -1;
          penalty = isLight ? ' (no penalty)' : ' (-2 attack)';
        }
        return '<li><strong>' + w.name + '</strong> ' + handLabel + ' \u2014 ' + w.damage + (w.range ? ', ' + w.range : '') +
          (w.properties && w.properties.length ? ' (' + w.properties.join(', ') + ')' : '') +
          (w.cost ? ' \u2014 ' + w.cost + ' cr' : '') + penalty + '</li>';
      }).join('') + '</ul>';
    }
    if (char.selectedArmor) {
      html += '<h4>Armor</h4><ul><li><strong>' + char.selectedArmor.name + '</strong> \u2014 +' + char.selectedArmor.dv_bonus + ' DV' +
        (char.selectedArmor.special ? ' (' + char.selectedArmor.special + ')' : '') + '</li></ul>';
    }
    if (char.selectedShield) {
      html += '<h4>Shield</h4><ul><li><strong>' + char.selectedShield.name + '</strong> \u2014 +' + char.selectedShield.dv_bonus + ' DV' +
        (char.selectedShield.special ? ' (' + char.selectedShield.special + ')' : '') + '</li></ul>';
    }
    if (char.selectedAugments.length > 0) {
      html += '<h4>Augmentations</h4><ul>' + char.selectedAugments.map(function(aug) {
        return '<li><strong>' + aug.name + '</strong> \u2014 ' + aug.effect + ' (-' + aug.humanity_cost + ' HUM' + (aug.cost ? ', ' + aug.cost + ' cr' : '') + ')</li>';
      }).join('') + '</ul>';
    }
    html += '<h4>Starting Package</h4>' +
      '<ul>' + (cls.starting_equipment || []).map(function(item) { return '<li>' + item + '</li>'; }).join('') + '</ul>' +
      '<p class="muted">Starting Credits: ' + char.startingCredits + ' cr (Spent: ' + getCreditsSpent() + ' cr, Remaining: ' + getRemainingCredits() + ' cr)</p></div>';

    // ---- CANTRIPS ----
    if (char.selectedCantrips.length > 0) {
      html += '<div class="sheet-section"><h3>Known Cantrips</h3><ul>' +
        char.selectedCantrips.map(function(name) {
          var ct = (GAME.cantrips || []).find(function(c) { return c.name === name; });
          return '<li><strong>' + name + '</strong>' + (ct ? ' \u2014 ' + ct.effect + (ct.range ? ' (' + ct.range + ')' : '') : '') + '</li>';
        }).join('') + '</ul></div>';
    }

    // ---- SPECIALIZATION ----
    if (char.selectedSpecialization && char.level >= 6) {
      html += '<div class="sheet-section"><h3>Specialization: ' + char.selectedSpecialization + '</h3>' +
        (function() {
          var spec = (cls.specialization_details || []).find(function(s) { return s.name === char.selectedSpecialization; });
          if (!spec) return '';
          return '<ul>' + (spec.features || []).filter(function(f) { return f.level <= char.level; }).map(function(f) {
            return '<li><strong>L' + f.level + ': ' + f.name + '</strong> \u2014 ' + f.description + '</li>';
          }).join('') + '</ul>';
        })() + '</div>';
    }

    // ---- DOCTRINE #2 ----
    if (char.selectedDoctrine2 && char.level >= 6) {
      html += '<div class="sheet-section"><h3>Doctrine #2</h3><p><strong>' + char.selectedDoctrine2.name + '</strong> &mdash; ' + char.selectedDoctrine2.effect + '</p></div>';
    }

    // ---- TALENTS ----
    var talentKeys = Object.keys(char.selectedTalents).filter(function(lv) { return Number(lv) <= char.level && char.selectedTalents[lv]; });
    if (talentKeys.length) {
      html += '<div class="sheet-section wide"><h3>Talents</h3><ul>' +
        talentKeys.map(function(lv) {
          var t = char.selectedTalents[lv];
          return '<li><strong>L' + lv + ': ' + t.name + '</strong>' +
            (t.enhances ? ' <em>(enhances ' + t.enhances + ')</em>' : '') +
            ' \u2014 ' + t.effect + '</li>';
        }).join('') + '</ul></div>';
    }

    // ---- MASTERY PATH ----
    if (char.selectedMasteryPath && char.level >= 11) {
      html += '<div class="sheet-section"><h3>Mastery Path: ' + char.selectedMasteryPath.name + '</h3>' +
        '<p class="mastery-stats">' + char.selectedMasteryPath.stats + '</p>' +
        '<ul>' +
        '<li><strong>L11:</strong> ' + (char.selectedMasteryPath.features_11 || []).join(', ') + '</li>' +
        (char.level >= 13 ? '<li><strong>L13:</strong> ' + (char.selectedMasteryPath.features_13 || []).join(', ') + '</li>' : '') +
        (char.level >= 15 ? '<li><strong>L15:</strong> ' + char.selectedMasteryPath.capstone_15 + '</li>' : '') +
        '</ul></div>';
    }

    // ---- MULTICLASS ----
    (function() {
      var mcKeys = Object.keys(char.multiclassLevels).filter(function(lv) { return Number(lv) <= char.level && char.multiclassLevels[lv]; });
      if (!mcKeys.length) return;
      html += '<div class="sheet-section"><h3>Multiclass</h3><ul>';
      mcKeys.forEach(function(lv) {
        var archName = char.multiclassLevels[lv];
        var mcClass = GAME.classes.find(function(c) { return c.name === archName; });
        html += '<li><strong>L' + lv + ':</strong> ' + archName;
        if (mcClass) {
          html += ' <span class="muted">(' + mcClass.hit_die + ' HD';
          if (mcClass.weapon_proficiency && mcClass.weapon_proficiency.length) {
            html += ', weapons: ' + mcClass.weapon_proficiency.join(', ');
          }
          html += ')</span>';
        }
        html += '</li>';
      });
      var hasCaster = mcKeys.some(function(lv) {
        var mcClass = GAME.classes.find(function(c) { return c.name === char.multiclassLevels[lv]; });
        return mcClass && mcClass.spell_slots && mcClass.spell_slots.length > 0;
      });
      var primaryIsCaster = cls.spell_slots && cls.spell_slots.length > 0;
      if (hasCaster || primaryIsCaster) {
        var mcLevelCount = mcKeys.length;
        var primaryLevels = char.level - mcLevelCount;
        var effectiveCasterLevel = 0;
        if (cls.magic_type === 'Full caster') effectiveCasterLevel += primaryLevels;
        else if (cls.magic_type && cls.magic_type.indexOf('Half') > -1) effectiveCasterLevel += Math.floor(primaryLevels / 2);
        mcKeys.forEach(function(lv) {
          var mcClass = GAME.classes.find(function(c) { return c.name === char.multiclassLevels[lv]; });
          if (mcClass) {
            if (mcClass.magic_type === 'Full caster') effectiveCasterLevel += 1;
            else if (mcClass.magic_type && mcClass.magic_type.indexOf('Half') > -1) effectiveCasterLevel += 0.5;
          }
        });
        effectiveCasterLevel = Math.floor(effectiveCasterLevel);
        if (effectiveCasterLevel > 0) {
          html += '</ul><p class="muted">Effective caster level: ' + effectiveCasterLevel + ' (use full caster spell slot table)</p>';
        } else {
          html += '</ul>';
        }
      } else {
        html += '</ul>';
      }
      html += '<p class="muted">Note: Multiclass does not grant save proficiencies, armor proficiencies, or starting equipment.</p></div>';
    })();

    // ---- REST & RECOVERY REFERENCE ----
    html += '<div class="sheet-section wide"><h3>Rest &amp; Recovery</h3>' +
      '<div class="rest-ref-grid">' +
      '<div class="rest-block">' +
      '<h4>Short Rest (8 Hours)</h4>' +
      '<ul>' +
      '<li>Recover ' + hitDiceCount + ' Hit Dice, spend to heal (roll + END mod)</li>' +
      '<li>Regain all "per short rest" abilities</li>' +
      '<li>Recover 1 spell slot (3rd level or lower)</li>' +
      '<li>Remove 1 Burnout Point</li>' +
      '<li>Remove Exhaustion 1-2 only</li>' +
      '<li>Max 1 short rest per 24 hours</li>' +
      '</ul></div>' +
      '<div class="rest-block">' +
      '<h4>Long Rest (7 Days)</h4>' +
      '<ul>' +
      '<li>Full HP recovery</li>' +
      '<li>All Hit Dice recovered</li>' +
      '<li>All spell slots recovered</li>' +
      '<li>All limited-use abilities recovered</li>' +
      '<li>Remove all Burnout &amp; Exhaustion</li>' +
      '<li>Heal one Lingering Injury (with treatment)</li>' +
      '</ul></div>' +
      '</div></div>';

    // ---- CONDITIONS QUICK REFERENCE ----
    html += '<div class="sheet-section wide">' +
      '<details class="ref-panel-inline"><summary>Conditions Quick Reference</summary>' +
      '<div class="conditions-grid">' +
      '<div><strong>Blinded:</strong> Disadv. attacks, adv. against you</div>' +
      '<div><strong>Bleeding:</strong> 1d4 dmg/turn, Medicine DC 12 to stop</div>' +
      '<div><strong>Charmed:</strong> Can\'t attack charmer, adv. social vs you</div>' +
      '<div><strong>Dazed:</strong> Actions OR movement (not both), disadv. attacks</div>' +
      '<div><strong>Flat-Footed:</strong> Lose AGI to DV, no reactions</div>' +
      '<div><strong>Frightened:</strong> Disadv. checks/attacks, -2 DV, can\'t approach</div>' +
      '<div><strong>Grappled:</strong> Speed 0, 1 action to escape (contested)</div>' +
      '<div><strong>Incapacitated:</strong> No actions or reactions</div>' +
      '<div><strong>Invisible:</strong> Adv. attacks, disadv. against you</div>' +
      '<div><strong>Paralyzed:</strong> Incapacitated, auto-fail MIG/AGI, melee crits</div>' +
      '<div><strong>Poisoned:</strong> Disadv. attacks and ability checks</div>' +
      '<div><strong>Prone:</strong> Disadv. attacks, adv. melee vs you, disadv. ranged vs you</div>' +
      '<div><strong>Restrained:</strong> Speed 0, disadv. attacks, adv. against you</div>' +
      '<div><strong>Stunned:</strong> Incapacitated, auto-fail MIG/AGI, adv. against you</div>' +
      '<div><strong>Unconscious:</strong> Drop prone, auto-fail saves, melee crits</div>' +
      '<div><strong>Weakened:</strong> Disadv. attacks and MIG checks, half carry</div>' +
      '</div></details></div>';

    // ---- PROGRESSION REFERENCE ----
    html += '<div class="sheet-section wide"><h3>Progression Reference</h3>' +
      '<p class="muted">Key milestones for ' + cls.name + ' advancement:</p>' +
      '<div class="progression-ref">' +
      '<span class="prog-tag">L2: Talent</span>' +
      '<span class="prog-tag">L4: Talent + ASI</span>' +
      '<span class="prog-tag">L6: Specialization + Doctrine</span>' +
      '<span class="prog-tag">L7: Talent + Skill Mastery</span>' +
      '<span class="prog-tag">L9: Talent + ASI</span>' +
      '<span class="prog-tag">L11: Mastery Path</span>' +
      '<span class="prog-tag">L18: Legendary Talent + ASI</span>' +
      '<span class="prog-tag">L19: Legendary Talent</span>' +
      '</div>' +
      (GAME.class_talents && GAME.class_talents[cls.name] ?
        '<details class="ref-panel-inline"><summary>Available Class Talents</summary><ul>' +
        GAME.class_talents[cls.name].map(function(t) {
          return '<li><strong>' + t.name + '</strong> (enhances ' + t.enhances + ') &mdash; ' + t.effect + '</li>';
        }).join('') + '</ul></details>' : '') +
      (GAME.mastery_paths && GAME.mastery_paths.length ?
        '<details class="ref-panel-inline"><summary>Mastery Paths (L11+)</summary><ul>' +
        GAME.mastery_paths.map(function(mp) {
          return '<li><strong>' + mp.name + '</strong> (' + mp.stats + ') &mdash; ' + mp.narrative + '</li>';
        }).join('') + '</ul></details>' : '') +
      (GAME.multiclass_requirements && GAME.multiclass_requirements.length ?
        '<details class="ref-panel-inline"><summary>Multiclassing Requirements</summary><ul>' +
        GAME.multiclass_requirements.map(function(mc) {
          return '<li><strong>' + mc.archetype + '</strong>: ' + mc.stat + '</li>';
        }).join('') + '</ul></details>' : '') +
      '</div>';

    html += '</div>'; // close sheet-grid

    sheet.innerHTML = html;

    var nameInput = el('char-name');
    if (nameInput) {
      nameInput.addEventListener('input', function(e) {
        char.name = e.target.value;
      });
    }
  }

  // ---- Export helpers ----
  function buildCharText() {
    var a = char.attributes;
    var cls = char.class;
    var sp = char.species;
    var bg = char.background;
    if (!cls || !sp || !bg) return null;

    // Compute effective attributes with ASIs
    var ea = {};
    ATTR_NAMES.forEach(function(at) { ea[at] = a[at] || 8; });
    Object.keys(char.selectedASIs).forEach(function(lv) {
      if (Number(lv) <= char.level) {
        var asi = char.selectedASIs[lv];
        if (asi.mode === '+2' && asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 2);
        if (asi.mode === '+1+1') {
          if (asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 1);
          if (asi.attr2) ea[asi.attr2] = Math.min(20, ea[asi.attr2] + 1);
        }
      }
    });

    var endMod = getMod(ea.END);
    var agiMod = getMod(ea.AGI);
    var migMod = getMod(ea.MIG);
    var wisMod = getMod(ea.WIS);
    var preMod = getMod(ea.PRE);
    var hpPerLevel = cls.hp_per_level || Math.floor(parseInt(cls.hit_die.replace('d','')) / 2) + 1;
    var hp = cls.hp_base + endMod + (char.level - 1) * (hpPerLevel + endMod);
    var profBonus = getProfBonus(char.level);
    var totalAP = getTotalAP();

    var text = 'ASHFALL CHARACTER SHEET\n';
    text += '========================================\n';
    text += 'Name: ' + (char.name || 'Unnamed') + '\n';
    text += 'Species: ' + sp.name + ' | Background: ' + bg.name + ' | Class: ' + cls.name + '\n';
    text += 'Level: ' + char.level + ' | HP: ' + hp + ' | DV: ' + calcDV(agiMod, char.selectedArmor, char.selectedShield) + ' | Hit Die: ' + cls.hit_die + '\n';
    text += 'Humanity: ' + calcHumanity(cls) + ' | Speed: ' + GAME.base_movement + ' ft | AP: ' + totalAP + '\n';
    text += 'Initiative: ' + modStr(agiMod + profBonus) + ' | Prof Bonus: +' + profBonus + '\n';
    text += '\nATTRIBUTES\n------------------------------\n';
    GAME.attributes.forEach(function(attr) {
      var s = ea[attr];
      text += attr + ': ' + s + ' (' + modStr(getMod(s)) + ')\n';
    });
    var trainedSavesText = {};
    (cls.save_proficiencies || []).forEach(function(s) { trainedSavesText[s] = true; });
    var fortSave = Math.max(endMod, migMod) + (trainedSavesText.Fortitude ? profBonus : 0);
    var refSave = Math.max(agiMod, wisMod) + (trainedSavesText.Reflex ? profBonus : 0);
    var willSave = Math.max(wisMod, preMod) + (trainedSavesText.Will ? profBonus : 0);
    text += '\nSAVING THROWS (Prof +' + profBonus + ')\n------------------------------\n';
    text += 'FORT: ' + modStr(fortSave) + (trainedSavesText.Fortitude ? '*' : '') + ' | REF: ' + modStr(refSave) + (trainedSavesText.Reflex ? '*' : '') + ' | WILL: ' + modStr(willSave) + (trainedSavesText.Will ? '*' : '') + '\n';
    text += '* = trained | Trained: ' + (cls.save_proficiencies || []).join(', ') + '\n';

    // Attacks
    text += '\nATTACKS\n------------------------------\n';
    if (char.selectedWeapons.length > 0) {
      char.selectedWeapons.forEach(function(w, idx) {
        var info = getWeaponAttackInfo(w, idx, ea, profBonus);
        var hand = idx === 0 ? 'Main Hand' : 'Off-Hand';
        text += '- ' + w.name + ' [' + hand + ']: ' + modStr(info.attackBonus) + ' to hit, ' + info.damageStr + ' dmg';
        if (w.range) text += ' (' + w.range + ')';
        if (w.properties && w.properties.length) text += ' [' + w.properties.join(', ') + ']';
        text += '\n';
      });
    } else {
      text += '- Unarmed Strike: ' + modStr(migMod + profBonus) + ' to hit, 1' + (migMod !== 0 ? (migMod > 0 ? '+' : '') + migMod : '') + ' dmg\n';
    }
    // Spell stats for casters
    var textIsCaster = cls.spell_slots && cls.spell_slots.length > 0;
    if (textIsCaster) {
      var tSpellAttr = (cls.name === 'Channeler' || cls.name === 'Medic') ? 'WIS' : 'INT';
      var tSpellMod = getMod(ea[tSpellAttr]);
      text += '- Spell Save DC: ' + (8 + profBonus + tSpellMod) + ' | Spell Attack: ' + modStr(profBonus + tSpellMod) + ' (' + tSpellAttr + ')\n';
    }
    text += 'MAP: 0 / -3 / -6 (Extra Attack does not trigger MAP)\n';

    // Skill proficiencies
    text += '\nSKILL PROFICIENCIES\n------------------------------\n';
    var textProfSkills = getAllProficientSkills();
    var textExpertSkills = getAllExpertiseSkills();
    GAME.skills.forEach(function(sk) {
      if (textProfSkills[sk.name] || textExpertSkills[sk.name]) {
        var isExpert = !!textExpertSkills[sk.name];
        var primaryAttr = sk.attribute.split('/')[0];
        var attrScore = ea[primaryAttr] || 10;
        var mod = getMod(attrScore);
        var bonus = isExpert ? mod + (profBonus * 2) : mod + profBonus;
        text += '- ' + sk.name + ' (' + sk.attribute + '): ' + modStr(bonus) + (isExpert ? ' [Expert]' : '') + '\n';
      }
    });

    text += '\nFEATURES\n------------------------------\n';
    (cls.level_1_features || []).forEach(function(f) { text += '- ' + f + '\n'; });
    // Doctrine
    if (char.selectedDoctrine) {
      text += '\nDOCTRINE\n------------------------------\n';
      text += '- ' + char.selectedDoctrine.name + ': ' + char.selectedDoctrine.effect + '\n';
    }
    // Feature choices
    var fcKeys = Object.keys(char.featureChoices);
    if (fcKeys.length > 0) {
      text += '\nFEATURE CHOICES\n------------------------------\n';
      fcKeys.forEach(function(feat) {
        text += '- ' + feat + ': ' + char.featureChoices[feat] + '\n';
      });
    }
    if (char.purchasedAbilities.length > 0) {
      text += '\nPURCHASED ABILITIES\n------------------------------\n';
      char.purchasedAbilities.forEach(function(ab) { text += '- ' + ab.abilityName + ' (' + ab.treeName + ') \u2014 ' + ab.ap_cost + ' AP, T' + ab.tier + '\n'; });
    }
    // Spell slots (adjusted for humanity)
    if (cls.spell_slots && cls.spell_slots.length) {
      text += '\nSPELL SLOTS' + (getHumanitySpent() > 0 ? ' (reduced by augmentations)' : '') + '\n------------------------------\n';
      var adjSpells = getSpellSlotsAfterHumanity(cls);
      adjSpells.slots.forEach(function(count, i) {
        if (count > 0) text += '- ' + count + ' x ' + ordinal(i + 1) + '-level\n';
      });
      if (adjSpells.cantrips > 0) text += '- ' + adjSpells.cantrips + ' Cantrips\n';
      if (adjSpells.cantrips === 0 && (cls.starting_cantrips || 0) > 0) text += '- Cantrips LOST (no humanity remaining)\n';
    }
    text += '\nEQUIPMENT\n------------------------------\n';
    if (char.selectedWeapons.length > 0) {
      char.selectedWeapons.forEach(function(w, idx) {
        var hand = idx === 0 ? 'Main Hand' : 'Off-Hand';
        var penalty = '';
        if (idx === 1) {
          var isLight = w.properties && w.properties.indexOf('light') > -1;
          penalty = isLight ? ' (no penalty)' : ' (-2 attack)';
        }
        text += '- ' + w.name + ' [' + hand + '] (' + w.damage + (w.range ? ', ' + w.range : '') + ')' + penalty + '\n';
      });
    }
    if (char.selectedArmor) {
      text += '- ' + char.selectedArmor.name + ' (+' + char.selectedArmor.dv_bonus + ' DV)\n';
    }
    if (char.selectedShield) {
      text += '- ' + char.selectedShield.name + ' (+' + char.selectedShield.dv_bonus + ' DV' + (char.selectedShield.special ? ', ' + char.selectedShield.special : '') + ')\n';
    }
    (cls.starting_equipment || []).forEach(function(item) { text += '- ' + item + '\n'; });
    text += 'Credits: ' + char.startingCredits + ' (Spent: ' + getCreditsSpent() + ', Remaining: ' + getRemainingCredits() + ')\n';
    if (char.selectedAugments.length > 0) {
      text += '\nAUGMENTATIONS\n------------------------------\n';
      char.selectedAugments.forEach(function(aug) {
        text += '- ' + aug.name + ' (' + aug.effect + ') -' + aug.humanity_cost + ' HUM\n';
      });
    }
    if (char.selectedCantrips.length > 0) {
      text += '\nKNOWN CANTRIPS\n------------------------------\n';
      char.selectedCantrips.forEach(function(name) {
        var ct = (GAME.cantrips || []).find(function(c) { return c.name === name; });
        text += '- ' + name + (ct ? ' (' + ct.effect + ')' : '') + '\n';
      });
    }
    // Progression choices
    if (char.level >= 2) {
      text += '\nPROGRESSION (Level ' + char.level + ')\n------------------------------\n';
      if (char.selectedSpecialization && char.level >= 6) {
        text += 'Specialization: ' + char.selectedSpecialization + '\n';
      }
      if (char.selectedDoctrine2 && char.level >= 6) {
        text += 'Doctrine #2: ' + char.selectedDoctrine2.name + ' - ' + char.selectedDoctrine2.effect + '\n';
      }
      // Talents
      var talentKeys = Object.keys(char.selectedTalents).filter(function(lv) { return Number(lv) <= char.level && char.selectedTalents[lv]; });
      if (talentKeys.length) {
        text += '\nTALENTS\n------------------------------\n';
        talentKeys.forEach(function(lv) {
          var t = char.selectedTalents[lv];
          text += '- L' + lv + ': ' + t.name + (t.enhances ? ' (enhances ' + t.enhances + ')' : '') + ' - ' + t.effect + '\n';
        });
      }
      // ASIs
      var asiKeys = Object.keys(char.selectedASIs).filter(function(lv) { return Number(lv) <= char.level; });
      if (asiKeys.length) {
        text += '\nATTRIBUTE IMPROVEMENTS\n------------------------------\n';
        asiKeys.forEach(function(lv) {
          var asi = char.selectedASIs[lv];
          if (asi.mode === '+2' && asi.attr1) text += '- L' + lv + ': ' + asi.attr1 + ' +2\n';
          if (asi.mode === '+1+1' && asi.attr1) text += '- L' + lv + ': ' + asi.attr1 + ' +1, ' + (asi.attr2 || '?') + ' +1\n';
        });
      }
      // Mastery Path
      if (char.selectedMasteryPath && char.level >= 11) {
        text += '\nMASTERY PATH: ' + char.selectedMasteryPath.name.toUpperCase() + '\n------------------------------\n';
        text += 'Requirements: ' + char.selectedMasteryPath.stats + '\n';
        text += 'L11: ' + (char.selectedMasteryPath.features_11 || []).join(', ') + '\n';
        if (char.level >= 13) text += 'L13: ' + (char.selectedMasteryPath.features_13 || []).join(', ') + '\n';
        if (char.level >= 15) text += 'L15: ' + char.selectedMasteryPath.capstone_15 + '\n';
      }
      // Multiclass
      var mcKeys = Object.keys(char.multiclassLevels).filter(function(lv) { return Number(lv) <= char.level && char.multiclassLevels[lv]; });
      if (mcKeys.length) {
        text += '\nMULTICLASS\n------------------------------\n';
        mcKeys.forEach(function(lv) {
          var archName = char.multiclassLevels[lv];
          var mcClass = GAME.classes.find(function(c) { return c.name === archName; });
          text += '- L' + lv + ': ' + archName;
          if (mcClass) text += ' (' + mcClass.hit_die + ' HD, ' + (mcClass.weapon_proficiency || []).join('/') + ')';
          text += '\n';
        });
        text += 'Note: No save proficiencies, armor, or starting equipment from multiclass.\n';
      }
    }

    // Combat Quick Reference
    text += '\nACTION ECONOMY\n------------------------------\n';
    text += '3 Actions + 1 Reaction per turn\n';
    text += '1-Action: Strike, Stride (' + GAME.base_movement + 'ft), Step (5ft), Aim (+2 ranged), Reload, Draw/Stow, Cast Spell, Use Item\n';
    text += '2-Action: Full Auto Burst (3 targets -2), Power Strike (+4 dmg -2 hit), Field Medicine (2d6+WIS DC15)\n';
    text += '3-Action: All-Out Attack (0/-3/-6), Sprint (3x speed)\n';
    text += 'Reactions: Attack of Opportunity, Deflect (1d10+AGI), Dive for Cover, Counterspell, Return Fire\n';

    text += '\nREST & RECOVERY\n------------------------------\n';
    var hdCount = Math.max(1, Math.floor(char.level / 2));
    text += 'Short Rest (8 hrs): Recover ' + hdCount + ' HD, 1 spell slot (3rd or lower), remove 1 Burnout, remove Exhaustion 1-2\n';
    text += 'Long Rest (7 days): Full HP, all HD, all slots, all abilities, remove all Burnout & Exhaustion\n';
    text += 'Stims: Max 2/day (Tier 1: 1d8+2, Tier 2: 2d8+2, Tier 3: 3d8+2 + remove condition)\n';

    return text;
  }

  // Copy as Text
  el('export-text-btn').addEventListener('click', function() {
    var text = buildCharText();
    if (!text) return;
    navigator.clipboard.writeText(text).then(function() {
      var btn = el('export-text-btn');
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = 'Copy as Text'; }, 2000);
    });
  });

  // Download PDF
  el('export-pdf-btn').addEventListener('click', function() {
    generatePDF();
  });

  function generatePDF() {
    var a = char.attributes;
    var cls = char.class;
    var sp = char.species;
    var bg = char.background;
    if (!cls || !sp || !bg) return;

    // Compute effective attributes with ASIs
    var ea = {};
    ATTR_NAMES.forEach(function(at) { ea[at] = a[at] || 8; });
    Object.keys(char.selectedASIs).forEach(function(lv) {
      if (Number(lv) <= char.level) {
        var asi = char.selectedASIs[lv];
        if (asi.mode === '+2' && asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 2);
        if (asi.mode === '+1+1') {
          if (asi.attr1) ea[asi.attr1] = Math.min(20, ea[asi.attr1] + 1);
          if (asi.attr2) ea[asi.attr2] = Math.min(20, ea[asi.attr2] + 1);
        }
      }
    });

    var endMod = getMod(ea.END);
    var agiMod = getMod(ea.AGI);
    var migMod = getMod(ea.MIG);
    var wisMod = getMod(ea.WIS);
    var preMod = getMod(ea.PRE);
    var hpPerLevel = cls.hp_per_level || Math.floor(parseInt(cls.hit_die.replace('d','')) / 2) + 1;
    var hp = cls.hp_base + endMod + (char.level - 1) * (hpPerLevel + endMod);
    var dv = calcDV(agiMod, char.selectedArmor, char.selectedShield);
    var humanity = calcHumanity(cls);
    var profBonus = getProfBonus(char.level);
    var totalAP = getTotalAP();
    var trainedSaves = {};
    (cls.save_proficiencies || []).forEach(function(s) { trainedSaves[s] = true; });

    // PDF generation using raw PDF spec (no dependencies)
    var objects = [];
    var objectOffsets = [];

    function addObj(content) {
      var num = objects.length + 1;
      objects.push(content);
      return num;
    }

    // Colors
    var bg_r = 10/255, bg_g = 10/255, bg_b = 11/255;
    var accent_r = 232/255, accent_g = 99/255, accent_b = 27/255;
    var bone_r = 232/255, bone_g = 224/255, bone_b = 212/255;
    var dust_r = 184/255, dust_g = 169/255, dust_b = 154/255;
    var card_r = 28/255, card_g = 28/255, card_b = 34/255;

    // Build content stream
    var y = 780;
    var stream = '';
    var pageW = 612, pageH = 842;
    var marginL = 40, marginR = 572;
    var colW = (marginR - marginL) / 2;

    function textCmd(x, ty, text, size, r, g, b) {
      // Escape special PDF chars
      text = text.replace(/\\/g, '\\\\').replace(/\(/g, '\\(').replace(/\)/g, '\\)');
      stream += 'BT /F1 ' + size + ' Tf ' + r + ' ' + g + ' ' + b + ' rg ' + x + ' ' + ty + ' Td (' + text + ') Tj ET\n';
    }

    function boldTextCmd(x, ty, text, size, r, g, b) {
      text = text.replace(/\\/g, '\\\\').replace(/\(/g, '\\(').replace(/\)/g, '\\)');
      stream += 'BT /F2 ' + size + ' Tf ' + r + ' ' + g + ' ' + b + ' rg ' + x + ' ' + ty + ' Td (' + text + ') Tj ET\n';
    }

    function rect(x, ry, w, h, r, g, b) {
      stream += r + ' ' + g + ' ' + b + ' rg ' + x + ' ' + ry + ' ' + w + ' ' + h + ' re f\n';
    }

    function line(x1, ly1, x2, ly2, r, g, b) {
      stream += r + ' ' + g + ' ' + b + ' RG 1 w ' + x1 + ' ' + ly1 + ' m ' + x2 + ' ' + ly2 + ' l S\n';
    }

    // Background
    rect(0, 0, pageW, pageH, bg_r, bg_g, bg_b);

    // Title bar
    rect(0, pageH - 50, pageW, 50, accent_r, accent_g, accent_b);
    boldTextCmd(marginL, pageH - 35, 'ASHFALL CHARACTER SHEET', 18, bg_r, bg_g, bg_b);

    y = pageH - 80;

    // Character name and meta
    boldTextCmd(marginL, y, char.name || 'Unnamed Survivor', 16, bone_r, bone_g, bone_b);
    y -= 18;
    textCmd(marginL, y, sp.name + '  |  ' + bg.name + '  |  ' + cls.name + '  |  Level ' + char.level, 10, dust_r, dust_g, dust_b);
    y -= 6;
    line(marginL, y, marginR, y, accent_r, accent_g, accent_b);
    y -= 20;

    // Attributes section
    boldTextCmd(marginL, y, 'ATTRIBUTES', 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginL + colW - 20, y, card_r, card_g, card_b);
    y -= 16;

    var attrX = marginL;
    var attrBoxW = 78;
    GAME.attributes.forEach(function(attr, i) {
      var s = ea[attr] || 8;
      var m = getMod(s);
      var bx = attrX + i * (attrBoxW + 8);
      rect(bx, y - 6, attrBoxW, 36, card_r, card_g, card_b);
      boldTextCmd(bx + 4, y + 18, attr, 8, accent_r, accent_g, accent_b);
      boldTextCmd(bx + 35, y + 14, '' + s, 14, bone_r, bone_g, bone_b);
      textCmd(bx + 35, y + 2, '(' + modStr(m) + ')', 9, dust_r, dust_g, dust_b);
    });
    y -= 40;

    // Combat stats
    boldTextCmd(marginL, y, 'COMBAT', 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginR, y, card_r, card_g, card_b);
    y -= 16;

    var combatStats = [
      ['HP', '' + hp], ['DV', '' + dv], ['Initiative', modStr(agiMod)], ['Speed', GAME.base_movement + ' ft'],
      ['Hit Die', cls.hit_die], ['Humanity', '' + humanity], ['Prof Bonus', '+' + profBonus], ['AP', '' + totalAP]
    ];
    var csX = marginL;
    var csBoxW = 62;
    combatStats.forEach(function(cs, i) {
      var row = Math.floor(i / 4);
      var col = i % 4;
      var bx = csX + col * (csBoxW + 8);
      var by = y - row * 36;
      rect(bx, by - 6, csBoxW, 30, card_r, card_g, card_b);
      textCmd(bx + 4, by + 14, cs[0], 7, dust_r, dust_g, dust_b);
      boldTextCmd(bx + 4, by + 2, cs[1], 11, bone_r, bone_g, bone_b);
    });
    y -= 78;

    // Saving throws
    boldTextCmd(marginL, y, 'SAVING THROWS', 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginR, y, card_r, card_g, card_b);
    y -= 16;

    var saves = [
      ['FORT', Math.max(endMod, migMod), trainedSaves.Fortitude],
      ['REF', Math.max(agiMod, wisMod), trainedSaves.Reflex],
      ['WILL', Math.max(wisMod, preMod), trainedSaves.Will]
    ];
    saves.forEach(function(sv, i) {
      var bx = marginL + i * 90;
      var total = sv[1] + (sv[2] ? profBonus : 0);
      rect(bx, y - 6, 82, 30, card_r, card_g, card_b);
      if (sv[2]) { line(bx, y - 6, bx, y + 24, accent_r, accent_g, accent_b); }
      textCmd(bx + 4, y + 14, sv[0] + (sv[2] ? ' (Prof)' : ''), 7, dust_r, dust_g, dust_b);
      boldTextCmd(bx + 4, y + 2, modStr(total), 11, bone_r, bone_g, bone_b);
    });
    y -= 40;

    // Attacks (pre-calculated)
    boldTextCmd(marginL, y, 'ATTACKS', 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginR, y, card_r, card_g, card_b);
    y -= 16;

    if (char.selectedWeapons.length > 0) {
      char.selectedWeapons.forEach(function(w, idx) {
        var info = getWeaponAttackInfo(w, idx, ea, profBonus);
        var hand = idx === 0 ? 'Main' : 'Off';
        var atkText = w.name + ' [' + hand + ']: ' + modStr(info.attackBonus) + ' to hit, ' + info.damageStr + ' dmg';
        if (w.range) atkText += ' (' + w.range + ')';
        textCmd(marginL + 8, y, '- ' + atkText, 9, dust_r, dust_g, dust_b);
        y -= 13;
      });
    } else {
      textCmd(marginL + 8, y, '- Unarmed: ' + modStr(migMod + profBonus) + ' to hit, 1+' + migMod + ' dmg', 9, dust_r, dust_g, dust_b);
      y -= 13;
    }
    // Spell stats for casters
    var pdfIsCaster = cls.spell_slots && cls.spell_slots.length > 0;
    if (pdfIsCaster) {
      var pdfSpellAttr = (cls.name === 'Channeler' || cls.name === 'Medic') ? 'WIS' : 'INT';
      var pdfSpellMod = getMod(ea[pdfSpellAttr]);
      textCmd(marginL + 8, y, '- Spell Save DC: ' + (8 + profBonus + pdfSpellMod) + ' | Spell Attack: ' + modStr(profBonus + pdfSpellMod) + ' (' + pdfSpellAttr + ')', 9, accent_r, accent_g, accent_b);
      y -= 13;
    }
    textCmd(marginL + 8, y, 'MAP: 0 / -3 / -6 (Extra Attack does not trigger MAP)', 8, dust_r, dust_g, dust_b);
    y -= 18;

    // Features
    boldTextCmd(marginL, y, cls.name.toUpperCase() + ' FEATURES', 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginR, y, card_r, card_g, card_b);
    y -= 14;

    (cls.level_1_features || []).forEach(function(f) {
      textCmd(marginL + 8, y, '- ' + f, 9, dust_r, dust_g, dust_b);
      y -= 13;
    });

    // Doctrine
    if (char.selectedDoctrine) {
      y -= 6;
      boldTextCmd(marginL, y, 'DOCTRINE', 11, accent_r, accent_g, accent_b);
      y -= 5;
      line(marginL, y, marginR, y, card_r, card_g, card_b);
      y -= 14;
      textCmd(marginL + 8, y, '- ' + char.selectedDoctrine.name + ': ' + char.selectedDoctrine.effect, 9, dust_r, dust_g, dust_b);
      y -= 13;
    }

    // Feature choices
    var fcKeys = Object.keys(char.featureChoices);
    if (fcKeys.length > 0) {
      y -= 6;
      boldTextCmd(marginL, y, 'FEATURE CHOICES', 11, accent_r, accent_g, accent_b);
      y -= 5;
      line(marginL, y, marginR, y, card_r, card_g, card_b);
      y -= 14;
      fcKeys.forEach(function(feat) {
        textCmd(marginL + 8, y, '- ' + feat + ': ' + char.featureChoices[feat], 9, dust_r, dust_g, dust_b);
        y -= 13;
      });
    }

    // Purchased abilities
    if (char.purchasedAbilities.length > 0) {
      y -= 6;
      boldTextCmd(marginL, y, 'PURCHASED ABILITIES', 11, accent_r, accent_g, accent_b);
      y -= 5;
      line(marginL, y, marginR, y, card_r, card_g, card_b);
      y -= 14;

      char.purchasedAbilities.forEach(function(ab) {
        textCmd(marginL + 8, y, '- ' + ab.abilityName + ' (' + ab.treeName + ') - ' + ab.ap_cost + ' AP, Tier ' + ab.tier, 9, dust_r, dust_g, dust_b);
        y -= 13;
      });
    }

    // Spell slots (adjusted for humanity)
    if (cls.spell_slots && cls.spell_slots.length) {
      y -= 6;
      var spellTitle = 'SPELL SLOTS' + (getHumanitySpent() > 0 ? ' (REDUCED)' : '');
      boldTextCmd(marginL, y, spellTitle, 11, accent_r, accent_g, accent_b);
      y -= 5;
      line(marginL, y, marginR, y, card_r, card_g, card_b);
      y -= 14;
      var pdfSpells = getSpellSlotsAfterHumanity(cls);
      pdfSpells.slots.forEach(function(count, i) {
        if (count > 0) {
          textCmd(marginL + 8, y, '- ' + count + ' x ' + ordinal(i + 1) + '-level', 9, dust_r, dust_g, dust_b);
          y -= 13;
        }
      });
      if (pdfSpells.cantrips > 0) {
        textCmd(marginL + 8, y, '- ' + pdfSpells.cantrips + ' Cantrips', 9, dust_r, dust_g, dust_b);
        y -= 13;
      }
      if (pdfSpells.cantrips === 0 && (cls.starting_cantrips || 0) > 0) {
        textCmd(marginL + 8, y, '- Cantrips LOST (no humanity)', 9, accent_r, accent_g, accent_b);
        y -= 13;
      }
    }

    // Equipment
    y -= 6;
    boldTextCmd(marginL, y, 'EQUIPMENT', 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginR, y, card_r, card_g, card_b);
    y -= 14;

    // Selected weapons
    char.selectedWeapons.forEach(function(w, idx) {
      var hand = idx === 0 ? 'Main Hand' : 'Off-Hand';
      var penalty = '';
      if (idx === 1) {
        var isLight = w.properties && w.properties.indexOf('light') > -1;
        penalty = isLight ? '' : ' (-2 atk)';
      }
      textCmd(marginL + 8, y, '- ' + w.name + ' [' + hand + '] (' + w.damage + (w.range ? ', ' + w.range : '') + ')' + penalty, 9, dust_r, dust_g, dust_b);
      y -= 13;
    });
    // Selected armor
    if (char.selectedArmor) {
      textCmd(marginL + 8, y, '- ' + char.selectedArmor.name + ' (+' + char.selectedArmor.dv_bonus + ' DV)', 9, dust_r, dust_g, dust_b);
      y -= 13;
    }
    // Selected shield
    if (char.selectedShield) {
      textCmd(marginL + 8, y, '- ' + char.selectedShield.name + ' (+' + char.selectedShield.dv_bonus + ' DV' + (char.selectedShield.special ? ', ' + char.selectedShield.special : '') + ')', 9, dust_r, dust_g, dust_b);
      y -= 13;
    }
    (cls.starting_equipment || []).forEach(function(item) {
      textCmd(marginL + 8, y, '- ' + item, 9, dust_r, dust_g, dust_b);
      y -= 13;
    });
    textCmd(marginL + 8, y, '- 2d6 x 10 credits', 9, dust_r, dust_g, dust_b);
    y -= 20;

    // Augmentations
    if (char.selectedAugments.length > 0) {
      boldTextCmd(marginL, y, 'AUGMENTATIONS', 11, accent_r, accent_g, accent_b);
      y -= 5;
      line(marginL, y, marginR, y, card_r, card_g, card_b);
      y -= 14;
      char.selectedAugments.forEach(function(aug) {
        var augText = aug.name + ' - ' + aug.effect + ' (-' + aug.humanity_cost + ' HUM)';
        if (augText.length > 80) augText = augText.substring(0, 77) + '...';
        textCmd(marginL + 8, y, '- ' + augText, 8, dust_r, dust_g, dust_b);
        y -= 12;
      });
      y -= 6;
    }

    // Cantrips
    if (char.selectedCantrips.length > 0) {
      boldTextCmd(marginL, y, 'KNOWN CANTRIPS', 11, accent_r, accent_g, accent_b);
      y -= 5;
      line(marginL, y, marginR, y, card_r, card_g, card_b);
      y -= 14;
      char.selectedCantrips.forEach(function(name) {
        var ct = (GAME.cantrips || []).find(function(c) { return c.name === name; });
        textCmd(marginL + 8, y, '- ' + name + (ct ? ' - ' + ct.effect : ''), 8, dust_r, dust_g, dust_b);
        y -= 12;
      });
      y -= 6;
    }

    // Progression choices for higher-level characters
    if (char.level >= 2) {
      // Talents
      var pdfTalentKeys = Object.keys(char.selectedTalents).filter(function(lv) { return Number(lv) <= char.level && char.selectedTalents[lv]; });
      if (pdfTalentKeys.length) {
        boldTextCmd(marginL, y, 'TALENTS', 11, accent_r, accent_g, accent_b);
        y -= 5;
        line(marginL, y, marginR, y, card_r, card_g, card_b);
        y -= 14;
        pdfTalentKeys.forEach(function(lv) {
          var t = char.selectedTalents[lv];
          var txt = 'L' + lv + ': ' + t.name + (t.enhances ? ' (enhances ' + t.enhances + ')' : '');
          if (txt.length > 80) txt = txt.substring(0, 77) + '...';
          textCmd(marginL + 8, y, '- ' + txt, 8, dust_r, dust_g, dust_b);
          y -= 12;
        });
        y -= 6;
      }

      // Specialization
      if (char.selectedSpecialization && char.level >= 6) {
        boldTextCmd(marginL, y, 'SPECIALIZATION: ' + char.selectedSpecialization.toUpperCase(), 11, accent_r, accent_g, accent_b);
        y -= 5;
        line(marginL, y, marginR, y, card_r, card_g, card_b);
        y -= 14;
        var pdfSpec = (cls.specialization_details || []).find(function(s) { return s.name === char.selectedSpecialization; });
        if (pdfSpec) {
          (pdfSpec.features || []).filter(function(f) { return f.level <= char.level; }).forEach(function(f) {
            textCmd(marginL + 8, y, '- L' + f.level + ': ' + f.name, 8, dust_r, dust_g, dust_b);
            y -= 12;
          });
        }
        y -= 6;
      }

      // Mastery Path
      if (char.selectedMasteryPath && char.level >= 11) {
        boldTextCmd(marginL, y, 'MASTERY PATH: ' + char.selectedMasteryPath.name.toUpperCase(), 11, accent_r, accent_g, accent_b);
        y -= 5;
        line(marginL, y, marginR, y, card_r, card_g, card_b);
        y -= 14;
        textCmd(marginL + 8, y, 'L11: ' + (char.selectedMasteryPath.features_11 || []).join(', '), 8, dust_r, dust_g, dust_b);
        y -= 12;
        if (char.level >= 13) {
          textCmd(marginL + 8, y, 'L13: ' + (char.selectedMasteryPath.features_13 || []).join(', '), 8, dust_r, dust_g, dust_b);
          y -= 12;
        }
        if (char.level >= 15) {
          textCmd(marginL + 8, y, 'L15: ' + char.selectedMasteryPath.capstone_15, 8, dust_r, dust_g, dust_b);
          y -= 12;
        }
        y -= 6;
      }

      // ASIs
      var pdfAsiKeys = Object.keys(char.selectedASIs).filter(function(lv) { return Number(lv) <= char.level; });
      if (pdfAsiKeys.length) {
        boldTextCmd(marginL, y, 'ATTRIBUTE IMPROVEMENTS', 11, accent_r, accent_g, accent_b);
        y -= 5;
        line(marginL, y, marginR, y, card_r, card_g, card_b);
        y -= 14;
        pdfAsiKeys.forEach(function(lv) {
          var asi = char.selectedASIs[lv];
          var txt = '';
          if (asi.mode === '+2' && asi.attr1) txt = 'L' + lv + ': ' + asi.attr1 + ' +2';
          if (asi.mode === '+1+1') txt = 'L' + lv + ': ' + (asi.attr1 || '?') + ' +1, ' + (asi.attr2 || '?') + ' +1';
          textCmd(marginL + 8, y, '- ' + txt, 8, dust_r, dust_g, dust_b);
          y -= 12;
        });
        y -= 6;
      }

      // Multiclass
      var pdfMcKeys = Object.keys(char.multiclassLevels).filter(function(lv) { return Number(lv) <= char.level && char.multiclassLevels[lv]; });
      if (pdfMcKeys.length) {
        boldTextCmd(marginL, y, 'MULTICLASS', 11, accent_r, accent_g, accent_b);
        y -= 5;
        line(marginL, y, marginR, y, card_r, card_g, card_b);
        y -= 14;
        pdfMcKeys.forEach(function(lv) {
          var archName = char.multiclassLevels[lv];
          var mcClass = GAME.classes.find(function(c) { return c.name === archName; });
          var mcTxt = 'L' + lv + ': ' + archName;
          if (mcClass) mcTxt += ' (' + mcClass.hit_die + ' HD)';
          textCmd(marginL + 8, y, '- ' + mcTxt, 8, dust_r, dust_g, dust_b);
          y -= 12;
        });
        y -= 6;
      }
    }

    // Species traits
    boldTextCmd(marginL, y, 'SPECIES: ' + sp.name.toUpperCase(), 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginR, y, card_r, card_g, card_b);
    y -= 14;

    textCmd(marginL + 8, y, sp.attribute_bonus, 9, accent_r, accent_g, accent_b);
    y -= 14;
    (sp.traits || []).forEach(function(t) {
      // Truncate long trait effects to fit page
      var effectText = t.effect.length > 80 ? t.effect.substring(0, 77) + '...' : t.effect;
      textCmd(marginL + 8, y, t.name + ': ' + effectText, 8, dust_r, dust_g, dust_b);
      y -= 12;
    });

    // Background
    y -= 6;
    boldTextCmd(marginL, y, 'BACKGROUND: ' + bg.name.toUpperCase(), 11, accent_r, accent_g, accent_b);
    y -= 5;
    line(marginL, y, marginR, y, card_r, card_g, card_b);
    y -= 14;
    textCmd(marginL + 8, y, bg.skill_bonus, 9, dust_r, dust_g, dust_b);
    y -= 13;
    var featureText = bg.feature.length > 90 ? bg.feature.substring(0, 87) + '...' : bg.feature;
    textCmd(marginL + 8, y, 'Feature: ' + featureText, 8, dust_r, dust_g, dust_b);
    y -= 20;

    // Action Economy & Combat Reference (compact)
    if (y > 160) {
      boldTextCmd(marginL, y, 'QUICK REFERENCE', 11, accent_r, accent_g, accent_b);
      y -= 5;
      line(marginL, y, marginR, y, card_r, card_g, card_b);
      y -= 14;
      textCmd(marginL + 8, y, 'Actions: 3 per turn + 1 Reaction | MAP: 0 / -3 / -6', 8, dust_r, dust_g, dust_b);
      y -= 11;
      textCmd(marginL + 8, y, '1-Act: Strike, Stride, Step, Aim (+2 ranged), Reload, Draw, Cast, Use Item, Grapple, Shove', 7, dust_r, dust_g, dust_b);
      y -= 10;
      textCmd(marginL + 8, y, '2-Act: Full Auto (-2, 3 tgts), Power Strike (+4 dmg -2 hit), Field Med (2d6+WIS DC15)', 7, dust_r, dust_g, dust_b);
      y -= 10;
      textCmd(marginL + 8, y, '3-Act: All-Out Attack (0/-3/-6), Sprint (3x speed)', 7, dust_r, dust_g, dust_b);
      y -= 10;
      textCmd(marginL + 8, y, 'Flanking +2 melee | High Ground +2 ranged | Cover +2/+5 DV | Nat 20: double dice | Nat 1: auto-miss', 7, dust_r, dust_g, dust_b);
      y -= 14;
      var hdCount = Math.max(1, Math.floor(char.level / 2));
      textCmd(marginL + 8, y, 'Short Rest (8h): ' + hdCount + ' HD, 1 slot (3rd-), -1 Burnout, Exhaust 1-2 | Long Rest (7d): Full recovery', 7, dust_r, dust_g, dust_b);
      y -= 10;
      textCmd(marginL + 8, y, 'Stims: Max 2/day (T1: 1d8+2 / T2: 2d8+2 / T3: 3d8+2 + remove condition)', 7, dust_r, dust_g, dust_b);
    }

    // Footer
    rect(0, 0, pageW, 25, card_r, card_g, card_b);
    textCmd(marginL, 8, 'Generated by Ashfall Character Builder', 7, dust_r, dust_g, dust_b);

    // ============================================================
    // Build PDF structure with AcroForm (fillable fields)
    // ============================================================

    // Helper to escape PDF string
    function pdfEsc(s) { return s.replace(/\\/g, '\\\\').replace(/\(/g, '\\(').replace(/\)/g, '\\)'); }

    // Define form fields — each will become a widget annotation
    var formFields = [];
    var fieldObjIds = [];

    // Default appearance for text fields (dark bg, light text)
    var daText = '/F1 10 Tf 0.91 0.88 0.83 rg'; // bone color text
    var daSmall = '/F1 8 Tf 0.91 0.88 0.83 rg';
    var daLarge = '/F2 14 Tf 0.91 0.88 0.83 rg';

    // Field positions — placed in the combat stats area
    // Current HP field (editable)
    var hpY = pageH - 80 - 18 - 6 - 20 - 5 - 16; // approximate y for combat row
    // We'll place tracking fields at the bottom of the page, above the footer
    var trackY = 120; // tracking section starts here

    // Add tracking section labels to stream
    boldTextCmd(marginL, trackY + 80, 'SESSION TRACKING', 11, accent_r, accent_g, accent_b);
    line(marginL, trackY + 75, marginR, trackY + 75, card_r, card_g, card_b);

    // HP tracking labels
    textCmd(marginL, trackY + 58, 'Current HP', 7, dust_r, dust_g, dust_b);
    textCmd(marginL + 70, trackY + 58, 'Temp HP', 7, dust_r, dust_g, dust_b);
    textCmd(marginL + 130, trackY + 58, 'Exhaustion (0-5)', 7, dust_r, dust_g, dust_b);
    textCmd(marginL + 230, trackY + 58, 'Conditions', 7, dust_r, dust_g, dust_b);

    // Spell slots label (if caster)
    if (pdfIsCaster) {
      textCmd(marginL, trackY + 18, 'Spell Slots Used', 7, dust_r, dust_g, dust_b);
    }
    textCmd(marginL + 260, trackY + 18, 'Hit Dice Used', 7, dust_r, dust_g, dust_b);

    // Notes label
    textCmd(marginL, trackY - 22, 'Session Notes', 7, dust_r, dust_g, dust_b);

    // Form field definitions: {name, type, x, y, w, h, value, maxLen}
    // type: 'text' for text field, 'multiline' for multiline text

    // Current HP
    formFields.push({ name: 'CurrentHP', type: 'text', x: marginL, y: trackY + 35, w: 55, h: 20, value: '' + hp, da: daLarge });
    // Temp HP
    formFields.push({ name: 'TempHP', type: 'text', x: marginL + 70, y: trackY + 35, w: 50, h: 20, value: '0', da: daText });
    // Exhaustion
    formFields.push({ name: 'Exhaustion', type: 'text', x: marginL + 130, y: trackY + 35, w: 85, h: 20, value: '0', da: daText });
    // Conditions
    formFields.push({ name: 'Conditions', type: 'text', x: marginL + 230, y: trackY + 35, w: marginR - marginL - 230, h: 20, value: '', da: daSmall });

    // Spell slots used (if caster)
    if (pdfIsCaster) {
      var slotText = '';
      var pdfAdjSpells = getSpellSlotsAfterHumanity(cls);
      pdfAdjSpells.slots.forEach(function(count, i) {
        if (count > 0) slotText += ordinal(i + 1) + ': ' + '_ '.repeat(count) + '  ';
      });
      formFields.push({ name: 'SpellSlots', type: 'text', x: marginL, y: trackY - 5, w: 245, h: 18, value: slotText.trim(), da: daSmall });
    }
    // Hit Dice used
    formFields.push({ name: 'HitDice', type: 'text', x: marginL + 260, y: trackY - 5, w: marginR - marginL - 260, h: 18, value: char.level + cls.hit_die + ' total', da: daSmall });

    // Session Notes (multiline)
    formFields.push({ name: 'SessionNotes', type: 'multiline', x: marginL, y: 30, w: marginR - marginL, h: trackY - 50, value: '', da: daSmall });

    // Now build the PDF object structure with form support
    // Obj 1: Catalog (with AcroForm reference — will be updated after we know field obj IDs)
    // Obj 2: Pages
    // Obj 3: Page (with Annots referencing field objects)
    // Obj 4: Content stream
    // Obj 5: Font (Helvetica)
    // Obj 6: Font (Helvetica-Bold)
    // Obj 7+: Form field widget annotations

    // Reserve slots for fixed objects
    addObj(''); // 1: Catalog placeholder
    addObj(''); // 2: Pages placeholder
    addObj(''); // 3: Page placeholder
    addObj('4 0 obj\n<< /Length ' + stream.length + ' >>\nstream\n' + stream + 'endstream\nendobj');
    addObj('5 0 obj\n<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica /Encoding /WinAnsiEncoding >>\nendobj');
    addObj('6 0 obj\n<< /Type /Font /Subtype /Type1 /BaseFont /Helvetica-Bold /Encoding /WinAnsiEncoding >>\nendobj');

    // Add form field objects
    formFields.forEach(function(f) {
      var flags = 0;
      if (f.type === 'multiline') flags = 4096; // bit 13: Multiline
      var objNum = objects.length + 1;
      fieldObjIds.push(objNum);
      var fieldObj = objNum + ' 0 obj\n<< /Type /Annot /Subtype /Widget /FT /Tx' +
        ' /T (' + pdfEsc(f.name) + ')' +
        ' /V (' + pdfEsc(f.value) + ')' +
        ' /DV (' + pdfEsc(f.value) + ')' +
        ' /DA (' + f.da + ')' +
        ' /Rect [' + f.x + ' ' + f.y + ' ' + (f.x + f.w) + ' ' + (f.y + f.h) + ']' +
        ' /P 3 0 R' +
        ' /MK << /BG [0.11 0.11 0.13] /BC [0.2 0.2 0.23] >>' +
        (flags ? ' /Ff ' + flags : '') +
        ' >>\nendobj';
      addObj(fieldObj);
    });

    // Now fill in the reserved objects with correct references
    var annotRefs = fieldObjIds.map(function(id) { return id + ' 0 R'; }).join(' ');
    var fieldRefs = annotRefs; // same for AcroForm

    // Obj 1: Catalog with AcroForm
    objects[0] = '1 0 obj\n<< /Type /Catalog /Pages 2 0 R /AcroForm << /Fields [' + fieldRefs + '] /DR << /Font << /F1 5 0 R /F2 6 0 R >> >> /DA (/F1 10 Tf 0 g) /NeedAppearances true >> >>\nendobj';
    // Obj 2: Pages
    objects[1] = '2 0 obj\n<< /Type /Pages /Kids [3 0 R] /Count 1 >>\nendobj';
    // Obj 3: Page with Annots
    objects[2] = '3 0 obj\n<< /Type /Page /Parent 2 0 R /MediaBox [0 0 ' + pageW + ' ' + pageH + '] /Contents 4 0 R /Resources << /Font << /F1 5 0 R /F2 6 0 R >> >> /Annots [' + annotRefs + '] >>\nendobj';

    // Serialize
    var pdf = '%PDF-1.4\n';
    objects.forEach(function(obj, i) {
      objectOffsets.push(pdf.length);
      pdf += obj + '\n';
    });

    var xrefOffset = pdf.length;
    pdf += 'xref\n0 ' + (objects.length + 1) + '\n';
    pdf += '0000000000 65535 f \n';
    objectOffsets.forEach(function(off) {
      var s = '' + off;
      while (s.length < 10) s = '0' + s;
      pdf += s + ' 00000 n \n';
    });

    pdf += 'trailer\n<< /Size ' + (objects.length + 1) + ' /Root 1 0 R >>\n';
    pdf += 'startxref\n' + xrefOffset + '\n%%EOF';

    // Download
    var blob = new Blob([pdf], { type: 'application/pdf' });
    var url = URL.createObjectURL(blob);
    var link = document.createElement('a');
    link.href = url;
    link.download = (char.name || 'ashfall-character').replace(/\s+/g, '-').toLowerCase() + '.pdf';
    link.click();
    URL.revokeObjectURL(url);

    var btn = el('export-pdf-btn');
    btn.textContent = 'Downloaded!';
    setTimeout(function() { btn.textContent = 'Download PDF'; }, 2000);
  }

  // ---- Init ----
  renderSpecies();
  renderBackgrounds();
  renderClasses();
  goToStep(0);
</script>

<style is:global>
  /* ---- Global reset for buttons/inputs in builder ---- */
  .builder-page button,
  .builder-page input {
    font-family: inherit;
    color: inherit;
    background: none;
    border: none;
    outline: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
  }

  /* Remove number spinner arrows */
  .builder-page input[type="number"]::-webkit-outer-spin-button,
  .builder-page input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .builder-page input[type="number"] {
    -moz-appearance: textfield;
  }

  /* ---- Builder page layout ---- */
  .builder-page {
    min-height: calc(100vh - var(--header-height));
    padding: var(--space-xl) 0 var(--space-3xl);
    background:
