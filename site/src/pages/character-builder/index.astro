  /* ---- Class detail ---- */
  .class-stats { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xs); margin: var(--space-md) 0; }
  .stat-row { display: flex; justify-content: space-between; padding: var(--space-xs) var(--space-sm); background: var(--bg-elevated); border-radius: 3px; font-size: 0.85rem; }
  .stat-label { color: var(--text-muted); font-family: var(--font-heading); text-transform: uppercase; letter-spacing: 0.04em; font-size: 0.75rem; }
  .stat-row span:last-child { color: var(--text-secondary); }
  .tag { font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent); margin-left: var(--space-sm); }
