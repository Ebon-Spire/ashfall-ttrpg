---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;

const steps = [
  { title: 'Read The Dead Signal scenario', time: '15 min', href: `${base}rules/starter-scenario/`, desc: 'A complete one-shot with everything you need: read-aloud text, NPC motivations, maps, and encounter stats.' },
  { title: 'Have players pick pregens or build characters', time: '10-20 min', href: `${base}rules/pregens/`, desc: 'Four ready-to-play Level 1 characters with gear, goals, and backstories. Or use the full character creation rules.' },
  { title: 'Skim the Combat rules', time: '5 min', href: `${base}rules/combat/`, desc: '3-action economy, attacks, damage, and reactions. You will reference this the most at the table.' },
  { title: 'Play!', time: '2-3 hours', href: '', desc: 'Describe the world, ask the players what they do, and roll dice when the outcome is uncertain.' },
];

const principles = [
  { title: 'Gritty Rests Shape Everything', desc: 'Short rests take 8 hours. Long rests take a full week. Every fight has consequences that echo for days. Plan your pacing around this economy — it is the engine that drives tension.' },
  { title: 'Ammo and Supplies Are Currency', desc: 'Track consumables. When the party counts their last three magazines and their last stim, that is when Ashfall is at its best. Scarcity creates drama without you having to invent it.' },
  { title: 'The Wasteland Is a Character', desc: 'Radiation zones, toxic atmospheres, ash storms, dimensional anomalies — the environment is as dangerous as any raider band. Use weather tables and hazards to keep it unpredictable.' },
  { title: 'Let Factions Move', desc: 'Between sessions, advance faction goals. The Iron Wolves raid a trade route. Dynaxis opens a new factory. The Ashen Veil pushes deeper into the Voidscars. The world should change whether the players act or not.' },
  { title: 'Bounded Lethality Means Respect', desc: 'A +14 bonus cap (+18 mythic) means even veteran characters respect a well-armed squad. Do not let players feel invincible — the wasteland punishes overconfidence.' },
  { title: 'Start Small, Let Players Drive', desc: 'A single settlement. A few NPCs with conflicting needs. A threat on the horizon. Ashfall shines when the players\' choices create the story, not a pre-written script.' },
];

const coreTools = [
  { title: 'The Setting', desc: 'Kael Morra, factions, religions, cultures, and the galaxy beyond.', href: `${base}rules/setting/`, icon: '🌍' },
  { title: 'Running the Game', desc: 'Full encounter building, CR math, and the lethality dial.', href: `${base}rules/game-mastering/`, icon: '⚔' },
];

const bestiary = [
  { title: 'Mutant Fauna & Flora', desc: 'Razorbacks, blighthounds, spore colonies, and wasteland predators.', href: `${base}rules/bestiary/fauna-flora/` },
  { title: 'Humanoids & Constructs', desc: 'Raiders, warlords, rogue synthetics, and military constructs.', href: `${base}rules/bestiary/humanoids-constructs/` },
  { title: 'Eldritch Horrors & Aliens', desc: 'Breach-spawn, dimensional entities, and alien species.', href: `${base}rules/bestiary/eldritch-aliens/` },
  { title: 'Undead & Arcane Beasts', desc: 'Revenants, ashwalkers, and creatures warped by magic.', href: `${base}rules/bestiary/undead-arcane/` },
  { title: 'Parasites & Apex Predators', desc: 'Symbiotes, hive organisms, and legendary boss creatures.', href: `${base}rules/bestiary/parasites-bosses/` },
];

const quickRef = [
  { title: 'Combat Rules', desc: '3-action economy, attacks, and damage.', href: `${base}rules/combat/` },
  { title: 'Conditions', desc: 'Status effects and exhaustion.', href: `${base}rules/conditions/` },
  { title: 'Equipment', desc: 'Weapons, armor, gear, and chems.', href: `${base}rules/equipment/` },
  { title: 'Magic', desc: 'Spell crafting and burnout.', href: `${base}rules/magic/` },
  { title: 'Exploration', desc: 'Rest, survival, and injuries.', href: `${base}rules/exploration/` },
  { title: 'Reference Tables', desc: 'All tables consolidated.', href: `${base}rules/appendices/tables/` },
];

const difficulties = [
  { label: 'Easy', mult: '0.4' },
  { label: 'Medium', mult: '0.6' },
  { label: 'Hard', mult: '0.8' },
  { label: 'Deadly', mult: '1.0' },
];
---

<BaseLayout title="Game Master's Guide" description="Everything a new GM needs to run their first session of Ashfall, the post-apocalyptic tabletop RPG.">
  <main class="gm">
    <!-- 1. Hero -->
    <section class="gm-hero">
      <div class="gm-hero-bg" aria-hidden="true">
        <img src="/images/illustrations/wasteland-landscape.png" alt="" loading="eager" />
      </div>
      <div class="gm-hero-inner">
        <h1 class="gm-hero-title">Game Master's Guide</h1>
        <p class="gm-hero-subtitle">Everything you need to run Ashfall. Build encounters, generate content, and bring the wasteland to life.</p>
      </div>
      <div class="gm-hero-fade" aria-hidden="true"></div>
    </section>

    <!-- 2. Your First Session -->
    <section class="gm-section">
      <div class="gm-container">
        <h2 class="gm-section-title">Your First Session</h2>
        <p class="gm-section-subtitle">You can be running a game in under 30 minutes. Four steps.</p>
        <div class="gm-steps">
          {steps.map((step, i) => (
            <div class="gm-step">
              <span class="gm-step-number">{i + 1}</span>
              <div class="gm-step-body">
                <div class="gm-step-header">
                  <strong>{step.href ? <a href={step.href}>{step.title}</a> : step.title}</strong>
                  <span class="gm-step-time">{step.time}</span>
                </div>
                <p>{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="gm-reassurance">
          <p>You don't need to memorize anything. The starter scenario tells you what to do, the pregens are ready to go, and the rules are here when you need them. Just describe the world, ask the players what they do, and roll dice when the outcome is uncertain.</p>
        </div>
      </div>
    </section>

    <!-- 3. The Starter Scenario -->
    <section class="gm-section gm-section-alt">
      <div class="gm-container">
        <h2 class="gm-section-title">The Starter Scenario</h2>
        <p class="gm-section-subtitle">A zero-prep one-shot to get your table playing immediately.</p>
        <a href={`${base}rules/starter-scenario/`} class="gm-scenario-card">
          <div class="gm-scenario-img-wrap">
            <img src="/images/illustrations/creature-encounter.png" alt="A tense encounter in a ruined relay station" loading="lazy" />
          </div>
          <div class="gm-scenario-content">
            <h3>The Dead Signal</h3>
            <div class="gm-scenario-meta">
              <span>3-5 Players</span>
              <span>2-3 Hours</span>
              <span>Zero Prep</span>
            </div>
            <p>A pre-war relay station is broadcasting a 60-year-old distress signal. The party investigates — but Iron Wolf scouts got there first. Multiple approaches: fight them head-on, negotiate passage, sneak through the maintenance tunnels, or create a distraction and slip past. The scenario adapts to whatever your players try.</p>
            <span class="gm-scenario-link">Read the Scenario &rarr;</span>
          </div>
        </a>
      </div>
    </section>

    <!-- 4. How Encounters Work -->
    <section class="gm-section">
      <div class="gm-container">
        <h2 class="gm-section-title">How Encounters Work</h2>
        <p class="gm-section-subtitle">Enough to build your first encounter. The full system is in <a href={`${base}rules/game-mastering/`}>Running the Game</a>.</p>
        <div class="gm-encounter-block">
          <div class="gm-encounter-formula">
            <span class="gm-formula-label">CR Budget</span>
            <span class="gm-formula-eq">Party Level Sum &times; Difficulty Multiplier</span>
          </div>
          <div class="gm-difficulty-table">
            <div class="gm-difficulty-header">
              <span>Difficulty</span>
              <span>Multiplier</span>
            </div>
            {difficulties.map(d => (
              <div class={`gm-difficulty-row ${d.label === 'Medium' ? 'gm-difficulty-highlight' : ''}`}>
                <span>{d.label}</span>
                <span class="gm-difficulty-value">{d.mult}</span>
              </div>
            ))}
          </div>
          <p class="gm-encounter-advice">Start with Medium difficulty. Adjust based on how your table handles it. A party of four Level 1 characters has a level sum of 4 — so a Medium encounter has a CR budget of 2.4.</p>
          <a href={`${base}rules/game-mastering/`} class="gm-encounter-link">Full encounter building rules &rarr;</a>
        </div>
      </div>
    </section>

    <!-- 5. Running the Wasteland -->
    <section class="gm-section gm-section-alt">
      <div class="gm-container">
        <h2 class="gm-section-title">Running the Wasteland</h2>
        <p class="gm-section-subtitle">Principles that make Ashfall sessions sing.</p>
        <div class="gm-principles-grid">
          {principles.map(p => (
            <div class="gm-principle">
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 6. Core GM Tools -->
    <section class="gm-section">
      <div class="gm-container">
        <h2 class="gm-section-title">Core GM Tools</h2>
        <p class="gm-section-subtitle">Your essential resources for session prep and improvisation.</p>
        <div class="gm-tools-grid">
          {coreTools.map(tool => (
            <a href={tool.href} class="gm-tool-card">
              <span class="gm-tool-icon">{tool.icon}</span>
              <h3>{tool.title}</h3>
              <p>{tool.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 7. Bestiary -->
    <section class="gm-section gm-section-alt">
      <div class="gm-container">
        <h2 class="gm-section-title">Bestiary</h2>
        <p class="gm-section-subtitle">Over 100 creatures across five categories, ready to drop into your sessions.</p>
        <img src="/images/illustrations/creature-encounter.png" alt="A terrifying mutant creature emerges from radioactive fog in an abandoned subway tunnel" class="gm-bestiary-img" loading="lazy" />
        <div class="gm-bestiary-grid">
          {bestiary.map(b => (
            <a href={b.href} class="gm-bestiary-card">
              <h3>{b.title}</h3>
              <p>{b.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 8. Quick Reference -->
    <section class="gm-section">
      <div class="gm-container">
        <h2 class="gm-section-title">Quick Reference</h2>
        <p class="gm-section-subtitle">Rules you will look up mid-session. Keep these bookmarked.</p>
        <div class="gm-ref-grid">
          {quickRef.map(ref => (
            <a href={ref.href} class="gm-ref-card">
              <h3>{ref.title}</h3>
              <p>{ref.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .gm-hero {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    background: var(--bg-secondary);
    color: var(--text-primary);
  }
  .gm-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .gm-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    opacity: 0.12;
    filter: contrast(1.1);
  }
  .gm-hero-inner {
    position: relative;
    z-index: 2;
    padding: var(--space-3xl) var(--space-lg);
    max-width: 48rem;
  }
  .gm-hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.1;
  }
  .gm-hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-muted);
    font-style: italic;
    line-height: 1.6;
    max-width: 36rem;
    margin: 0 auto;
  }
  .gm-hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 120px;
    background: linear-gradient(to bottom, transparent 0%, var(--bg-primary) 100%);
    z-index: 1;
  }

  /* ---- Sections ---- */
  .gm-section {
    padding: var(--space-3xl) 0;
    background: var(--bg-primary);
  }
  .gm-section-alt {
    background:
      radial-gradient(ellipse 60% 40% at 50% 50%, rgba(232, 99, 27, 0.04) 0%, transparent 60%),
      var(--bg-secondary);
  }
  .gm-container {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }
  .gm-section-title {
    font-family: var(--font-heading);
    font-size: 2rem;
    text-align: center;
    color: var(--text-primary);
    letter-spacing: 0.06em;
    margin-bottom: var(--space-sm);
  }
  .gm-section-subtitle {
    text-align: center;
    color: var(--text-muted);
    max-width: 36rem;
    margin: 0 auto var(--space-2xl);
    font-size: 1.05rem;
  }
  .gm-section-subtitle a {
    color: var(--accent);
  }

  /* ---- 2. Your First Session Steps ---- */
  .gm-steps {
    max-width: 42rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .gm-step {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
    padding: var(--space-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .gm-step:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-sm);
  }
  .gm-step-number {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--accent);
    min-width: 2rem;
    text-align: center;
    line-height: 1;
    margin-top: 0.15rem;
  }
  .gm-step-body {
    flex: 1;
    min-width: 0;
  }
  .gm-step-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .gm-step-header strong {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }
  .gm-step-header strong a {
    color: var(--accent);
    text-decoration: none;
  }
  .gm-step-header strong a:hover {
    text-decoration: underline;
  }
  .gm-step-time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
    background: var(--bg-elevated);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }
  .gm-step p {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: var(--space-xs) 0 0 0;
    line-height: 1.5;
  }
  .gm-reassurance {
    max-width: 42rem;
    margin: var(--space-xl) auto 0;
    padding: var(--space-lg) var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
  }
  .gm-reassurance p {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0;
    font-style: italic;
  }

  /* ---- 3. Starter Scenario ---- */
  .gm-scenario-card {
    display: flex;
    max-width: 52rem;
    margin: 0 auto;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }
  .gm-scenario-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .gm-scenario-img-wrap {
    flex-shrink: 0;
    width: 240px;
    overflow: hidden;
  }
  .gm-scenario-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .gm-scenario-card:hover .gm-scenario-img-wrap img {
    transform: scale(1.05);
  }
  .gm-scenario-content {
    padding: var(--space-xl) var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .gm-scenario-content h3 {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-sm) 0;
  }
  .gm-scenario-meta {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }
  .gm-scenario-meta span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    background: var(--bg-elevated);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .gm-scenario-content p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 var(--space-md) 0;
  }
  .gm-scenario-link {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  /* ---- 4. How Encounters Work ---- */
  .gm-encounter-block {
    max-width: 42rem;
    margin: 0 auto;
  }
  .gm-encounter-formula {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    border-radius: 8px 8px 0 0;
    text-align: center;
  }
  .gm-formula-label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-sm);
  }
  .gm-formula-eq {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }
  .gm-difficulty-table {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top: none;
  }
  .gm-difficulty-header {
    display: flex;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-xl);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border);
  }
  .gm-difficulty-row {
    display: flex;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-xl);
    font-size: 0.9rem;
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    transition: background 0.15s;
  }
  .gm-difficulty-row:last-child {
    border-bottom: none;
  }
  .gm-difficulty-highlight {
    background: rgba(232, 99, 27, 0.06);
    color: var(--text-primary);
  }
  .gm-difficulty-value {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 600;
  }
  .gm-encounter-advice {
    padding: var(--space-lg) var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 8px 8px;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }
  .gm-encounter-link {
    display: block;
    text-align: center;
    margin-top: var(--space-lg);
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .gm-encounter-link:hover {
    text-decoration: underline;
  }

  /* ---- 5. Running the Wasteland Principles ---- */
  .gm-principles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }
  .gm-principle {
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
  }
  .gm-principle h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 var(--space-sm) 0;
  }
  .gm-principle p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  /* ---- 6. Core GM Tools ---- */
  .gm-tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }
  .gm-tool-card {
    display: block;
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top: 3px solid var(--accent);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }
  .gm-tool-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .gm-tool-icon {
    display: block;
    font-size: 2rem;
    margin-bottom: var(--space-md);
  }
  .gm-tool-card h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 var(--space-sm) 0;
  }
  .gm-tool-card p {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.5;
    margin: 0;
  }

  /* ---- 7. Bestiary ---- */
  .gm-bestiary-img {
    display: block;
    max-width: 420px;
    width: 100%;
    margin: 0 auto var(--space-2xl);
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .gm-bestiary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-md);
  }
  .gm-bestiary-card {
    display: block;
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
  }
  .gm-bestiary-card:hover {
